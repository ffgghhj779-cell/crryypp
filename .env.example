# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Telegram Bot Token (from BotFather)
TELEGRAM_BOT_TOKEN="123456789:YOUR_BOT_TOKEN"

# Telegram Channel ID to force subscription.
# Format: @handle  OR  numeric chat_id (-1001234567890)
# The bot defaults to @mycryptoappTT20 if this is unset.
TELEGRAM_CHANNEL_ID="@mycryptoappTT20"

# Webhook secret — generate with: openssl rand -hex 32
# Pass this to Telegram when setting the webhook:
# https://api.telegram.org/bot<TOKEN>/setWebhook?url=<URL>&secret_token=<THIS_VALUE>
# NEVER prefix with NEXT_PUBLIC_
TELEGRAM_WEBHOOK_SECRET="your-random-32-char-hex-string"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ==========================================
# EWA Python Microservice Configuration
# ==========================================
# URL of the Python microservice (default is http://localhost:8001 for dev)
EWA_PYTHON_URL="http://ewa-engine:8001"

# Service-to-Service Secret Key
# Generate a strong key in production (e.g., openssl rand -hex 32)
EWA_SERVICE_KEY="production-secure-key-replace-me-1a2b3c"