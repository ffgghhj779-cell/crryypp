#pg-ts5 .ts5-ss { font-size:11px; color:var(--o); font-family:'Share Tech Mono',monospace; font-weight:700; }
#pg-ts5 .ts5-sbar { width:100%; height:4px; background:var(--b); margin-bottom:12px; border-radius:2px; overflow:hidden; }
#pg-ts5 .ts5-sfill { height:100%; }
#pg-ts5 .ts5-tbl { width:100%; border-collapse:collapse; font-family:'Share Tech Mono',monospace; }
#pg-ts5 .ts5-tl { padding:8px 4px; color:var(--t2); font-size:11px; font-weight:700; width:20%; border-bottom:1px solid var(--bg); }
#pg-ts5 .ts5-tp { padding:8px 4px; font-size:13px; font-weight:900; text-align:center; border-bottom:1px solid var(--bg); width:30%; direction:ltr; }
#pg-ts5 .ts5-tm { padding:8px 4px; color:var(--t3); font-size:9px; text-align:left; border-bottom:1px solid var(--bg); direction:ltr; }
#pg-ts5 .ts5-sep td { padding:3px 0; border-bottom:1px solid var(--b); }
#pg-ts5 .ts5-tf2 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:12px; padding-top:10px; border-top:1px solid var(--b); }
#pg-ts5 .ts5-fi { background:var(--bg); border:1px solid var(--b); padding:8px 4px; text-align:center; font-family:'Share Tech Mono',monospace; border-radius:2px; }
#pg-ts5 .ts5-fl { display:block; font-size:8px; color:var(--t3); margin-bottom:3px; }
#pg-ts5 .ts5-fv { display:block; font-size:11px; color:var(--t); font-weight:900; direction:ltr; }
#pg-ts5 .ts5-ts { display:grid; grid-template-columns:repeat(3,1fr); gap:4px; margin-top:10px; }
#pg-ts5 .ts5-chip { background:var(--bg); border:1px solid var(--b); padding:6px 4px; text-align:center; font-family:'Share Tech Mono',monospace; border-radius:2px; }
#pg-ts5 .ts5-ci { display:block; font-size:9px; color:var(--t); font-weight:900; }
#pg-ts5 .ts5-cg { display:block; font-size:9px; color:var(--o); font-weight:700; margin-top:2px; }
#pg-ts5 .ts5-card { background:var(--s); border:1px solid var(--b); padding:15px; margin-bottom:15px; border-radius:4px; }
#pg-ts5 .ts5-ct { font-size:13px; font-weight:700; color:var(--o); margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid var(--b); letter-spacing:0.5px; font-family:'Share Tech Mono',monospace; }
#pg-ts5 .ts5-mxh { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:6px; padding:8px 0; border-bottom:1px solid var(--b); margin-bottom:6px; text-align:center; font-family:'Share Tech Mono',monospace; font-size:10px; }
#pg-ts5 .ts5-mxr { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:6px; padding:6px 0; border-bottom:1px solid var(--bg); align-items:center; }
#pg-ts5 .ts5-mxt { font-size:11px; color:var(--t); font-weight:700; font-family:'Share Tech Mono',monospace; padding-right:8px; direction:ltr; text-align:left; }
#pg-ts5 .ts5-mxc { background:var(--bg); border:1px solid var(--b); padding:6px 4px; text-align:center; font-family:'Share Tech Mono',monospace; display:flex; flex-direction:column; align-items:center; gap:1px; border-radius:2px; }
#pg-ts5 .ts5-step { padding:12px; background:var(--bg); margin-bottom:10px; border-right:3px solid var(--b); border-radius:2px; }
#pg-ts5 .ts5-step-t { font-size:11px; color:var(--o); font-family:'Share Tech Mono',monospace; font-weight:700; margin-bottom:6px; }
#pg-ts5 .ts5-step-d { font-size:11px; color:var(--t); line-height:1.6; }
#pg-ts5 .ts5-step-note { padding:10px; background:var(--s); border:1px solid var(--b); font-size:10px; color:var(--t3); line-height:1.6; text-align:center; margin-top:8px; border-radius:2px; }
#pg-ts5 .ts5-analysis { background:#060606; border:1px solid var(--b); border-right:4px solid var(--t); padding:18px; margin-bottom:15px; border-radius:4px; }
#pg-ts5 .ts5-at { font-size:10px; color:var(--t3); font-family:'Share Tech Mono',monospace; letter-spacing:2px; margin-bottom:12px; font-weight:bold; }
#pg-ts5 .ts5-atx { font-size:13px; color:var(--t); line-height:2; text-align:justify; margin-bottom:12px; font-family:'Cairo',sans-serif; }
#pg-ts5 .ts5-disc { margin-top:12px; padding:12px; background:var(--bg); border:1px solid var(--b); font-size:10px; color:var(--t3); line-height:1.7; text-align:justify; font-family:'Cairo',sans-serif; border-radius:2px; }
