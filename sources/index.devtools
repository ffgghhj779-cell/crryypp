        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="16" rx="2" stroke="#ffffff"><animate attributeName="opacity" values="0.6; 1; 0.6" dur="4s" repeatCount="indefinite" /></rect>
          <path d="M7 8l4 4-4 4" stroke="var(--o)" stroke-dasharray="12" stroke-dashoffset="12"><animate attributeName="stroke-dashoffset" values="12; 0; 0; 12" dur="2.5s" repeatCount="indefinite" /></path>
          <path d="M13 16h4" stroke="#ffffff"><animate attributeName="opacity" values="1;0;1" dur="0.8s" calcMode="discrete" repeatCount="indefinite" /></path>
