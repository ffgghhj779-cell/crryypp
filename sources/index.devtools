}
#pg-flash .fl-notrade-sub {
    font-size: 11px;
    color: var(--t3);
    font-family: 'Share Tech Mono', monospace;
}
#pg-flash .fl-notrade-hint {
    font-size: 10px;
    color: var(--t2);
    margin-top: 6px;
    font-family: 'Cairo', sans-serif;
}
#pg-flash .fl-signal-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}
#pg-flash .fl-signal-badge {
    padding: 6px 14px;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    font-size: 11px;
    letter-spacing: 1px;
