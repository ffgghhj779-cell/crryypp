/* ================== PO3 Pattern CSS - ARCHITECTURAL FIX ================== */
#pg-po3 .po3-chart-card { background:var(--s); border:1px solid var(--b); padding:12px; margin-bottom:15px; }
#pg-po3 .po3-chart-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; padding-bottom:8px; border-bottom:1px solid var(--b); }
#pg-po3 .po3-chart-title { font-size:11px; color:var(--o); font-family:'Share Tech Mono',monospace; letter-spacing:1px; font-weight:700; }
#pg-po3 .po3-chart-live { display:flex; align-items:center; gap:6px; font-size:9px; color:var(--t2); font-family:'Share Tech Mono',monospace; }
#pg-po3 .po3-live-pulse { width:6px; height:6px; background:var(--o); border-radius:50%; animation:po3Pulse 2s infinite; }
@keyframes po3Pulse { 0%,100% { opacity:1; } 50% { opacity:0.3; } }
#pg-po3 .po3-legend { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; padding-top:10px; margin-top:8px; border-top:1px solid var(--b); font-size:8px; font-family:'Share Tech Mono',monospace; color:var(--t2); }
#pg-po3 .po3-legend-item { display:flex; align-items:center; gap:4px; justify-content:center; }
#pg-po3 .po3-card { background:var(--s); border:1px solid var(--b); padding:15px; margin-bottom:15px; }
#pg-po3 .po3-card-title { font-size:13px; font-weight:700; color:var(--o); margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid var(--b); letter-spacing:0.5px; }
#pg-po3 .po3-phase-card { background:var(--s); border:2px solid var(--t); padding:15px; margin-bottom:15px; }
#pg-po3 .po3-phase-title { font-size:11px; color:var(--t2); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:8px; }
#pg-po3 .po3-phase-big { font-size:26px; font-weight:900; color:var(--t); font-family:'Cairo',sans-serif; text-align:center; padding:10px 0; letter-spacing:1px; }
#pg-po3 .po3-phase-sub { font-size:12px; color:var(--o); font-family:'Share Tech Mono',monospace; text-align:center; margin-bottom:12px; }
#pg-po3 .po3-phase-flow { display:flex; gap:4px; margin-top:12px; }
#pg-po3 .po3-step { flex:1; padding:10px 6px; background:var(--bg); text-align:center; border-top:3px solid var(--b); font-family:'Share Tech Mono',monospace; }
#pg-po3 .po3-step-active { border-top-color:var(--t); background:var(--s); }
#pg-po3 .po3-step-label { font-size:8px; color:var(--t2); margin-bottom:4px; }
#pg-po3 .po3-step-name { font-size:10px; font-weight:700; }
#pg-po3 .po3-progress-bar { width:100%; height:8px; background:var(--b); margin-top:4px; }
#pg-po3 .po3-progress-fill { height:100%; background:var(--t); }
#pg-po3 .po3-entry-card { background:var(--bg); border-right:4px solid var(--t); padding:15px; margin-bottom:15px; }
#pg-po3 .po3-entry-big { font-size:18px; font-weight:900; margin-bottom:10px; }
#pg-po3 .po3-entry-detail { font-size:12px; color:var(--t); line-height:1.6; margin-bottom:10px; }
#pg-po3 .po3-entry-stats { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:10px; }
#pg-po3 .po3-entry-stat { background:var(--bg); border:1px solid var(--b); padding:8px; text-align:center; }
#pg-po3 .po3-entry-stat-label { font-size:8px; color:var(--t2); font-family:'Share Tech Mono',monospace; }
#pg-po3 .po3-entry-stat-val { font-size:13px; font-weight:900; color:var(--t); font-family:'Share Tech Mono',monospace; margin-top:2px; }
#pg-po3 .po3-verdict { background:var(--s); border-right:4px solid var(--o); padding:15px; margin-bottom:15px; }
#pg-po3 .po3-verdict-title { font-size:11px; color:var(--t2); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:8px; }
#pg-po3 .po3-verdict-main { font-size:17px; font-weight:900; color:var(--t); margin-bottom:10px; }
#pg-po3 .po3-verdict-detail { font-size:13px; color:var(--t); line-height:1.8; margin-bottom:10px; }
#pg-po3 .po3-prob-box { display:flex; justify-content:space-between; align-items:center; background:var(--bg); padding:12px; margin-top:10px; }
#pg-po3 .po3-prob-label { font-size:9px; color:var(--t2); font-family:'Share Tech Mono',monospace; }
#pg-po3 .po3-prob-val { font-size:28px; font-weight:900; color:var(--o); font-family:'Share Tech Mono',monospace; }
#pg-po3 .po3-stat-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid var(--b); font-family:'Share Tech Mono',monospace; font-size:12px; }
#pg-po3 .po3-table { width:100%; border-collapse:collapse; font-family:'Share Tech Mono',monospace; font-size:10px; }
#pg-po3 .po3-th { background:var(--bg); color:var(--t2); padding:8px 6px; text-align:right; border-bottom:1px solid var(--b); font-weight:700; font-size:9px; letter-spacing:0.5px; }
#pg-po3 .po3-td { padding:8px 6px; border-bottom:1px solid var(--b); color:var(--t); }
#pg-po3 .po3-badge { display:inline-block; padding:3px 6px; font-size:8px; font-weight:700; letter-spacing:0.5px; font-family:'Share Tech Mono',monospace; }
#pg-po3 .po3-badge-o { background:var(--o); color:var(--bg); }
#pg-po3 .po3-badge-w { background:var(--t); color:var(--bg); }
#pg-po3 .po3-level-section { margin-bottom:12px; padding-bottom:10px; border-bottom:1px solid var(--b); }
#pg-po3 .po3-section-label { font-size:10px; color:var(--o); font-family:'Share Tech Mono',monospace; font-weight:700; margin-bottom:6px; }
#pg-po3 .po3-level-row { display:flex; justify-content:space-between; padding:8px 10px; background:var(--bg); margin-bottom:5px; font-family:'Share Tech Mono',monospace; font-size:12px; }
#pg-po3 .po3-disclaimer { margin-top:12px; padding:10px; background:var(--bg); border:1px solid var(--b); font-size:10px; color:var(--t3); line-height:1.6; text-align:center; }
#pg-po3 .po3-guide { background:var(--bg); border:1px solid var(--b); padding:15px; margin-top:20px; }
#pg-po3 .po3-guide-title { font-size:12px; color:var(--o); font-weight:700; margin-bottom:10px; }
#pg-po3 .po3-guide-text { font-size:12px; color:var(--t3); line-height:1.8; }

