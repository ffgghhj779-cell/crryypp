    margin-bottom: 14px;
}
#pg-flash .fl-card-tf {
    background: var(--o);
    color: var(--bg);
    padding: 10px 14px;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    font-size: 14px;
    min-width: 42px;
