#pg-lsm .lsm-setup-card { background:var(--s); border:2px solid var(--b); padding:15px; margin-bottom:15px; }
#pg-lsm .lsm-setup-title { font-size:11px; color:var(--t3); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:8px; }
#pg-lsm .lsm-setup-big { font-size:22px; font-weight:900; color:var(--t); font-family:'Cairo',sans-serif; text-align:center; padding:10px 0; letter-spacing:1px; }
#pg-lsm .lsm-setup-sub { font-size:11px; color:var(--o); font-family:'Share Tech Mono',monospace; text-align:center; margin-bottom:12px; }
#pg-lsm .lsm-trade-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px; }
#pg-lsm .lsm-trade-box { background:var(--bg); padding:10px; text-align:center; border:1px solid var(--b); }
#pg-lsm .lsm-trade-label { font-size:9px; color:var(--t3); font-family:'Share Tech Mono',monospace; margin-bottom:4px; }
#pg-lsm .lsm-trade-val { font-size:14px; font-weight:900; color:var(--t); font-family:'Share Tech Mono',monospace; }
#pg-lsm .lsm-target-row { display:flex; align-items:center; padding:10px; background:var(--bg); margin-bottom:6px; font-family:'Share Tech Mono',monospace; border:1px solid var(--b); }
#pg-lsm .lsm-target-label { font-size:10px; color:var(--t); font-weight:700; width:40px; }
#pg-lsm .lsm-target-price { font-size:12px; color:var(--t); font-weight:700; flex:1; }
#pg-lsm .lsm-target-rr { font-size:10px; font-weight:700; width:60px; text-align:center; }
#pg-lsm .lsm-target-prob { font-size:10px; color:var(--t3); width:40px; text-align:left; }
#pg-lsm .lsm-verdict { background:var(--s); border:1px solid var(--b); border-right:4px solid var(--o); padding:15px; margin-bottom:15px; }
#pg-lsm .lsm-verdict-title { font-size:11px; color:var(--t3); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:8px; }
#pg-lsm .lsm-verdict-main { font-size:17px; font-weight:900; color:var(--t); margin-bottom:10px; }
#pg-lsm .lsm-verdict-detail { font-size:13px; color:var(--t2); line-height:1.8; margin-bottom:10px; }
#pg-lsm .lsm-prob-box { display:flex; justify-content:space-between; align-items:center; background:var(--bg); padding:12px; margin-top:10px; border:1px solid var(--b); }
#pg-lsm .lsm-prob-label { font-size:9px; color:var(--t3); font-family:'Share Tech Mono',monospace; }
#pg-lsm .lsm-prob-val { font-size:28px; font-weight:900; color:var(--o); font-family:'Share Tech Mono',monospace; }
#pg-lsm .lsm-comp-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
#pg-lsm .lsm-comp-box { background:var(--bg); padding:10px; border:1px solid var(--b); }
#pg-lsm .lsm-comp-label { font-size:9px; color:var(--t3); font-family:'Share Tech Mono',monospace; margin-bottom:4px; }
#pg-lsm .lsm-comp-name { font-size:11px; color:var(--t); font-weight:700; }
#pg-lsm .lsm-stat-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid var(--b); font-family:'Share Tech Mono',monospace; font-size:12px; }
#pg-lsm .lsm-table { width:100%; border-collapse:collapse; font-family:'Share Tech Mono',monospace; font-size:10px; }
#pg-lsm .lsm-th { background:var(--bg); color:var(--t3); padding:8px 6px; text-align:right; border-bottom:1px solid var(--b); font-weight:700; font-size:9px; letter-spacing:0.5px; }
#pg-lsm .lsm-td { padding:8px 6px; border-bottom:1px solid var(--b); color:var(--t2); }
#pg-lsm .lsm-badge { display:inline-block; padding:3px 6px; font-size:8px; font-weight:700; letter-spacing:0.5px; font-family:'Share Tech Mono',monospace; }
#pg-lsm .lsm-badge-o { background:var(--o); color:var(--bg); }
#pg-lsm .lsm-badge-w { background:#fff; color:var(--bg); }
#pg-lsm .lsm-disclaimer { margin-top:12px; padding:10px; background:var(--bg); border:1px solid var(--b); font-size:10px; color:var(--t3); line-height:1.6; text-align:center; }
#pg-lsm .lsm-guide { background:var(--s); border:1px solid var(--b); padding:15px; margin-top:20px; }
#pg-lsm .lsm-guide-title { font-size:12px; color:var(--o); font-weight:700; margin-bottom:10px; }
#pg-lsm .lsm-guide-text { font-size:12px; color:var(--t2); line-height:1.8; }

/* ================== MTFC Confluence Scanner CSS ================== */
#pg-mtfc .mtf-grade-card { background:var(--s); border:3px solid var(--b); padding:20px; margin-bottom:15px; text-align:center; }
#pg-mtfc .mtf-grade-label { font-size:11px; color:var(--t3); font-family:'Share Tech Mono',monospace; letter-spacing:2px; margin-bottom:8px; }
#pg-mtfc .mtf-grade-big { font-size:48px; font-weight:900; font-family:'Share Tech Mono',monospace; letter-spacing:4px; line-height:1; }
#pg-mtfc .mtf-grade-sub { font-size:14px; font-family:'Cairo',sans-serif; font-weight:700; margin-top:10px; letter-spacing:1px; }
#pg-mtfc .mtf-grade-bar { width:100%; height:10px; background:var(--bg); margin-top:15px; border:1px solid var(--b); }
#pg-mtfc .mtf-grade-bar-fill { height:100%; transition:width 0.3s ease; }
#pg-mtfc .mtf-grade-score-row { display:flex; justify-content:space-between; margin-top:15px; font-family:'Share Tech Mono',monospace; font-size:11px; }
#pg-mtfc .mtf-cz-card { background:var(--s); border:1px solid var(--b); padding:15px; margin-bottom:15px; text-align:center; }
#pg-mtfc .mtf-cz-label { font-size:11px; color:var(--t3); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:8px; }
#pg-mtfc .mtf-cz-price { font-size:22px; font-weight:900; font-family:'Share Tech Mono',monospace; padding:8px 0; }
#pg-mtfc .mtf-cz-dist { font-size:11px; color:var(--t); font-family:'Share Tech Mono',monospace; }
#pg-mtfc .mtf-chart-card { background:var(--s); border:1px solid var(--b); padding:12px; margin-bottom:15px; }
#pg-mtfc .mtf-chart-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; padding-bottom:8px; border-bottom:1px solid var(--b); }
#pg-mtfc .mtf-chart-title { font-size:11px; font-family:'Share Tech Mono',monospace; letter-spacing:1px; font-weight:700; }
#pg-mtfc .mtf-chart-live { display:flex; align-items:center; gap:6px; font-size:9px; color:var(--t3); font-family:'Share Tech Mono',monospace; }
#pg-mtfc .mtf-live-pulse { width:6px; height:6px; background:var(--o); border-radius:50%; animation:mtfcPulse 2s infinite; }
@keyframes mtfcPulse { 0%,100% { opacity:1; } 50% { opacity:0.3; } }
#pg-mtfc .mtf-legend { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; padding-top:10px; margin-top:8px; border-top:1px solid var(--b); font-size:8px; font-family:'Share Tech Mono',monospace; color:var(--t3); }
#pg-mtfc .mtf-legend-item { display:flex; align-items:center; gap:4px; justify-content:center; }
#pg-mtfc .mtf-card { background:var(--s); border:1px solid var(--b); padding:15px; margin-bottom:15px; }
#pg-mtfc .mtf-card-title { font-size:13px; font-weight:700; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid var(--b); letter-spacing:0.5px; }
#pg-mtfc .mtf-tf-row { padding:12px; background:var(--bg); margin-bottom:10px; border:1px solid var(--b); border-right-width:3px; border-right-style:solid; }
#pg-mtfc .mtf-tf-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; padding-bottom:8px; border-bottom:1px solid var(--b); }
#pg-mtfc .mtf-tf-title { font-size:16px; font-weight:900; font-family:'Cairo',sans-serif; letter-spacing:1px; }
#pg-mtfc .mtf-tf-count { font-size:11px; color:var(--t); font-family:'Share Tech Mono',monospace; font-weight:700; }
#pg-mtfc .mtf-comp-grid { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
#pg-mtfc .mtf-comp-item { padding:6px 8px; background:var(--s); font-family:'Share Tech Mono',monospace; font-size:10px; display:flex; justify-content:space-between; align-items:center; border:1px solid var(--b); border-right-width:2px; border-right-style:solid; }
#pg-mtfc .mtf-comp-label { color:var(--t3); font-size:9px; }
#pg-mtfc .mtf-comp-value { color:var(--t); font-weight:700; font-size:10px; }
#pg-mtfc .mtf-verdict { background:var(--s); border:1px solid var(--b); border-right-width:4px; border-right-style:solid; padding:15px; margin-bottom:15px; }
#pg-mtfc .mtf-verdict-title { font-size:11px; color:var(--t3); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:8px; }
#pg-mtfc .mtf-verdict-main { font-size:17px; font-weight:900; margin-bottom:10px; color:var(--t); }
#pg-mtfc .mtf-verdict-detail { font-size:13px; color:var(--t2); line-height:1.8; margin-bottom:10px; }
#pg-mtfc .mtf-prob-box { display:flex; justify-content:space-between; align-items:center; background:var(--bg); border:1px solid var(--b); padding:12px; margin-top:10px; }
#pg-mtfc .mtf-prob-label { font-size:9px; color:var(--t3); font-family:'Share Tech Mono',monospace; }
#pg-mtfc .mtf-prob-val { font-size:28px; font-weight:900; font-family:'Share Tech Mono',monospace; }
#pg-mtfc .mtf-trade-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px; }
#pg-mtfc .mtf-trade-box { background:var(--bg); padding:10px; text-align:center; border:1px solid var(--b); border-top-width:2px; border-top-style:solid; }
#pg-mtfc .mtf-trade-label { font-size:9px; color:var(--t3); font-family:'Share Tech Mono',monospace; margin-bottom:4px; }
#pg-mtfc .mtf-trade-val { font-size:14px; font-weight:900; color:var(--t); font-family:'Share Tech Mono',monospace; }
#pg-mtfc .mtf-target-row { display:flex; align-items:center; padding:10px; background:var(--bg); border:1px solid var(--b); margin-bottom:6px; font-family:'Share Tech Mono',monospace; }
#pg-mtfc .mtf-target-label { font-size:10px; font-weight:700; width:40px; }
#pg-mtfc .mtf-target-price { font-size:12px; color:var(--t); font-weight:700; flex:1; }
#pg-mtfc .mtf-target-rr { font-size:10px; font-weight:700; width:60px; text-align:center; }
#pg-mtfc .mtf-target-prob { font-size:10px; color:var(--t3); width:40px; text-align:left; }
#pg-mtfc .mtf-stat-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid var(--b); font-family:'Share Tech Mono',monospace; font-size:12px; }
#pg-mtfc .mtf-disclaimer { margin-top:12px; padding:10px; background:var(--bg); border:1px solid var(--b); font-size:10px; color:var(--t3); line-height:1.6; text-align:center; }
#pg-mtfc .mtf-guide { background:var(--s); border:1px solid var(--b); padding:15px; margin-top:20px; }
#pg-mtfc .mtf-guide-title { font-size:12px; font-weight:700; margin-bottom:10px; color:var(--o); }
#pg-mtfc .mtf-guide-text { font-size:12px; color:var(--t2); line-height:1.8; }


  /* Trading Signal CSS Architecture */
#pg-tsignal .tsig-input-full { width:100%; background:var(--bg); border:1px solid var(--b); color:var(--t); padding:10px; font-family:'Share Tech Mono',monospace; font-size:14px; text-align:center; margin-bottom:10px; box-sizing:border-box; outline:none; border-radius:4px; }
#pg-tsignal .tsig-tier-badge { display:inline-block; font-size:9px; background:var(--o); color:#000; padding:3px 8px; margin-top:8px; font-family:'Share Tech Mono',monospace; font-weight:900; letter-spacing:1px; border-radius:2px; }
#pg-tsignal .tsig-master-card { background:var(--s); border:2px solid var(--t); padding:20px; margin-bottom:15px; text-align:center; border-radius:4px; }
#pg-tsignal .tsig-master-label { font-size:10px; color:var(--t3); font-family:'Share Tech Mono',monospace; letter-spacing:2px; margin-bottom:10px; }
#pg-tsignal .tsig-master-grade { font-size:42px; font-weight:900; font-family:'Share Tech Mono',monospace; letter-spacing:3px; line-height:1; margin-bottom:8px; }
#pg-tsignal .tsig-master-bias { font-size:13px; font-family:'Cairo',sans-serif; font-weight:900; letter-spacing:1px; margin-top:8px; }
#pg-tsignal .tsig-master-bar { width:100%; height:8px; background:var(--bg); margin-top:12px; border-radius:2px; overflow:hidden; border:1px solid var(--b); }
#pg-tsignal .tsig-master-bar-fill { height:100%; background:var(--t); transition:width 1s ease; }
#pg-tsignal .tsig-master-stats { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:15px; }
#pg-tsignal .tsig-master-stat { background:var(--bg); border:1px solid var(--b); padding:10px 6px; text-align:center; border-radius:2px; }
#pg-tsignal .tsig-master-stat-label { font-size:8px; color:var(--t3); font-family:'Share Tech Mono',monospace; margin-bottom:4px; }
#pg-tsignal .tsig-master-stat-val { font-size:13px; font-weight:900; color:var(--o); font-family:'Share Tech Mono',monospace; }
#pg-tsignal .tsig-trade-table-card { background:var(--s); border:1px solid var(--b); padding:15px; margin-bottom:15px; border-radius:4px; }
#pg-tsignal .tsig-trade-header { display:flex; align-items:center; padding-bottom:10px; border-bottom:1px solid var(--b); margin-bottom:12px; }
#pg-tsignal .tsig-trade-tf { background:var(--o); color:#000; padding:6px 10px; font-family:'Share Tech Mono',monospace; font-weight:900; font-size:14px; letter-spacing:1px; border-radius:2px; }
#pg-tsignal .tsig-trade-headings { flex:1; text-align:center; padding:0 10px; }
#pg-tsignal .tsig-trade-arabic { font-size:13px; color:var(--t); font-family:'Cairo',sans-serif; font-weight:700; }
#pg-tsignal .tsig-trade-english { font-size:9px; color:var(--t3); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-top:2px; }
#pg-tsignal .tsig-trade-grade { font-size:22px; font-weight:900; font-family:'Share Tech Mono',monospace; letter-spacing:2px; }
#pg-tsignal .tsig-trade-side-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; }
#pg-tsignal .tsig-side-label { padding:4px 10px; font-family:'Share Tech Mono',monospace; font-weight:900; font-size:11px; letter-spacing:1px; border-radius:2px; }
#pg-tsignal .tsig-signal-strength { font-size:11px; color:var(--o); font-family:'Share Tech Mono',monospace; font-weight:700; }
#pg-tsignal .tsig-strength-bar { width:100%; height:4px; background:var(--b); margin-bottom:12px; border-radius:2px; overflow:hidden; }
#pg-tsignal .tsig-strength-fill { height:100%; }
#pg-tsignal .tsig-trade-table { width:100%; border-collapse:collapse; font-family:'Share Tech Mono',monospace; }
#pg-tsignal .tsig-td-label { padding:8px 4px; color:var(--t2); font-size:11px; font-weight:700; width:22%; border-bottom:1px solid var(--bg); }
#pg-tsignal .tsig-td-price { padding:8px 4px; font-size:13px; font-weight:900; text-align:center; border-bottom:1px solid var(--bg); direction:ltr; }
#pg-tsignal .tsig-td-meta { padding:8px 4px; color:var(--t3); font-size:10px; text-align:left; border-bottom:1px solid var(--bg); direction:ltr; }
#pg-tsignal .tsig-row-separator td { padding:3px 0; border-bottom:1px solid var(--b); }
#pg-tsignal .tsig-trade-footer { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:12px; padding-top:10px; border-top:1px solid var(--b); }
#pg-tsignal .tsig-footer-item { background:var(--bg); border:1px solid var(--b); padding:8px 4px; text-align:center; font-family:'Share Tech Mono',monospace; border-radius:2px; }
#pg-tsignal .tsig-footer-label { display:block; font-size:8px; color:var(--t3); margin-bottom:3px; }
#pg-tsignal .tsig-footer-val { display:block; font-size:11px; color:var(--t); font-weight:900; direction:ltr; }
#pg-tsignal .tsig-tools-strip { display:grid; grid-template-columns:repeat(4,1fr); gap:4px; margin-top:10px; }
#pg-tsignal .tsig-tool-chip { background:var(--bg); padding:6px 4px; text-align:center; border-top:2px solid var(--b); font-family:'Share Tech Mono',monospace; border-radius:2px; }
#pg-tsignal .tsig-chip-icon { display:block; font-size:9px; color:var(--t); font-weight:900; }
#pg-tsignal .tsig-chip-grade { display:block; font-size:9px; color:var(--o); font-weight:700; margin-top:2px; }
#pg-tsignal .tsig-card { background:var(--s); border:1px solid var(--b); padding:15px; margin-bottom:15px; border-radius:4px; }
#pg-tsignal .tsig-card-title { font-size:13px; font-weight:700; color:var(--o); margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid var(--b); letter-spacing:0.5px; font-family:'Share Tech Mono',monospace; }
#pg-tsignal .tsig-matrix-header { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:6px; padding:8px 0; border-bottom:1px solid var(--b); margin-bottom:6px; text-align:center; font-family:'Share Tech Mono',monospace; font-size:10px; }
#pg-tsignal .tsig-comp-matrix-row { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:6px; padding:6px 0; border-bottom:1px solid var(--bg); align-items:center; }
#pg-tsignal .tsig-matrix-tool { font-size:11px; color:var(--t); font-weight:700; font-family:'Share Tech Mono',monospace; padding-right:8px; text-align:left; direction:ltr; }
#pg-tsignal .tsig-matrix-cell { background:var(--bg); border:1px solid var(--b); padding:6px 4px; text-align:center; font-family:'Share Tech Mono',monospace; display:flex; flex-direction:column; align-items:center; gap:2px; border-radius:2px; }
#pg-tsignal .tsig-analysis-card { background:#060606; border:1px solid var(--b); border-right:4px solid var(--t); padding:18px; margin-bottom:15px; border-radius:4px; }
#pg-tsignal .tsig-analysis-title { font-size:10px; color:var(--t3); font-family:'Share Tech Mono',monospace; letter-spacing:2px; margin-bottom:10px; font-weight:bold; }
#pg-tsignal .tsig-analysis-text { font-size:12px; color:var(--t); line-height:1.8; text-align:justify; font-family:'Cairo',sans-serif; }
#pg-tsignal .tsig-disclaimer { margin-top:12px; padding:12px; background:var(--bg); border:1px solid var(--b); border-radius:2px; font-size:10px; color:var(--t3); line-height:1.7; text-align:justify; font-family:'Cairo',sans-serif; }
#pg-tsignal .tsig-guide { background:#060606; border:1px solid var(--b); padding:15px; margin-top:20px; border-radius:4px; border-right:3px solid var(--o); }
#pg-tsignal .tsig-guide-title { font-size:12px; color:var(--o); font-weight:700; margin-bottom:10px; font-family:'Share Tech Mono',monospace; letter-spacing:0.5px; }
#pg-tsignal .tsig-guide-text { font-size:12px; color:var(--t2); line-height:1.8; font-family:'Cairo',sans-serif; text-align:justify; }

/* Trading Signal 2 — Visual Architecture */
