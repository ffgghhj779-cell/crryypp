         <select id="obk-depth" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; font-family:'Share Tech Mono', monospace; outline:none;">
  <option value="50">50 مستوى (سريع وآمن)</option>
  <option value="100" selected>100 مستوى (أقصى حد مسموح)</option>
</select>
        </div>
