    </div>

    <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:14px; margin-bottom:10px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:10px;">
        <div>
          <div style="font-size:0.5rem; color:#888; margin-bottom:3px; font-family:'Share Tech Mono', monospace;">SYMBOL</div>
          <input type="text" id="trip-sym" placeholder="BTC" value="BTC" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; text-transform:uppercase; font-family:'Share Tech Mono', monospace; font-size:0.85rem; text-align:center; outline:none;">
        </div>
        <div>
          <div style="font-size:0.5rem; color:#888; margin-bottom:3px; font-family:'Share Tech Mono', monospace;">TIMEFRAME</div>
          <select id="trip-tf" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; font-family:'Share Tech Mono', monospace; outline:none;">
            <option value="15m">15M</option>
            <option value="1h">1H</option>
            <option value="4h" selected>4H</option>
            <option value="1d">1D</option>
          </select>
        </div>
      </div>
      <button onclick="runTripleSuite()" id="trip-btn" style="width:100%; padding:12px; background:var(--o); color:#000; font-weight:900; border:none; border-radius:4px; cursor:pointer; font-family:'Share Tech Mono', monospace; font-size:1rem; letter-spacing:4px;">ANALYZE ALL</button>
      <div style="text-align:center; margin-top:6px; font-size:0.5rem; color:#555; font-family:'Cairo', sans-serif;">تحليل شامل: Volume Profile + دعم ومقاومة + خطوط الاتجاه</div>
    </div>

    <div id="trip-loading" style="display:none; text-align:center; padding:30px; color:var(--o); font-size:0.85rem; font-family:'Cairo', sans-serif; font-weight:bold;">جاري التحليل المعمق واستخراج البيانات...</div>

    <div id="trip-dashboard" style="display:none;">
      <div id="trip-ticker" class="trip-anim" style="animation-delay: 0.1s; margin-bottom:10px;"></div>
      <div id="trip-vp-sec"></div>
      <div id="trip-sr-sec"></div>
      <div id="trip-tl-sec"></div>

      <div class="trip-anim" style="animation-delay: 0.6s; background:#060606; border:1px solid #1a1a1a; border-radius:4px; padding:10px 12px; border-right:3px solid var(--o); margin-bottom:6px;">
        <div style="font-size:0.6rem; color:#ccc; line-height:1.8; text-align:right; font-family:'Cairo', sans-serif;">
          <span style="color:var(--o); font-weight:bold;">دليل القراءة: </span><br>
          <span style="color:var(--o);">VP:</span> POC = مغناطيس السعر. VAH = مقاومة. VAL = دعم. الأعمدة = كثافة التداول.<br>
          <span style="color:var(--o);">S/R:</span> البرتقالي = مقاومة. الأبيض = دعم. النقاط = الارتكازات واللمسات.<br>
          <span style="color:var(--o);">TREND:</span> الأبيض = دعم صاعد. البرتقالي = مقاومة هابطة. الخطوط تمتد للمستقبل.<br>
          <span style="font-size:0.55rem; color:#555;">هذا تحليل فني آلي ولا يُعتبر توصية مالية.</span>
        </div>
      </div>
      <div style="text-align:center; margin-top:16px; padding:6px;">
        <span style="font-size:0.4rem; color:#444; letter-spacing:2px; font-family:'Share Tech Mono', monospace;">360° TRIPLE ANALYSIS SUITE</span>
      </div>
    </div>

  </div>
</div>


<script>
// Telegram Web App Initialization
if (window.Telegram && window.Telegram.WebApp) {
  const tg = window.Telegram.WebApp;
  tg.expand();
  tg.setHeaderColor('#000000');
  tg.setBackgroundColor('#000000');
}

// UI Nav & User Menu
// وحدة التنبيهات المخصصة (تعالج الروابط وتدعم الهوية البصرية)
function showSysMsg(text, isError = false) {
    const existing = document.getElementById('sys-alert-box');
    if(existing) existing.remove();
    
    const box = document.createElement('div');
    box.id = 'sys-alert-box';
    box.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:99999; display:flex; align-items:center; justify-content:center; backdrop-filter:blur(5px);';
    
    // تحويل المعرف إلى رابط نشط
    const formattedText = text.replace(/@adamskamal144/g, '<a href="https://t.me/adamskamal144" target="_blank" style="color:#ff6a00; font-weight:bold; text-decoration:underline;">@adamskamal144</a>').replace(/\n/g, '<br>');

    box.innerHTML = `
        <div style="background:#111; border:1px solid ${isError ? '#ff4444' : '#ff6a00'}; border-radius:8px; padding:25px; max-width:85%; width:400px; text-align:center; box-shadow:0 10px 30px rgba(0,0,0,0.9); border-top:3px solid ${isError ? '#ff4444' : '#ff6a00'};">
            <div style="font-family:'Cairo', sans-serif; font-size:1rem; color:#fff; font-weight:bold; margin-bottom:20px; line-height:1.8;">
                ${formattedText}
            </div>
            <button onclick="this.parentElement.parentElement.remove()" style="background:${isError ? '#ff4444' : '#ff6a00'}; color:#000; border:none; padding:8px 30px; border-radius:4px; font-weight:900; cursor:pointer; font-family:'Cairo', sans-serif; font-size:1rem;">موافق</button>
        </div>
    `;
    document.body.appendChild(box);
}

// محرك التنقل وإدارة الحصص المحدث
// ==========================================
// 1- وحدة التنبيهات المخصصة (المحسنة بالروابط والهوية البصرية)
// ==========================================
function showSysMsg(text, isError = false) {
    const existing = document.getElementById('sys-alert-box');
    if(existing) existing.remove();
    
    const box = document.createElement('div');
    box.id = 'sys-alert-box';
    // تنسيق الخلفية (تعتيم + تمويه)
    box.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:99999; display:flex; align-items:center; justify-content:center; backdrop-filter:blur(5px);';
    
    // تنفيذ التعديلات المطلوبة على النص وتحويل المعرف لرابط
    const formattedText = text
        .replace(/للاشتراك في باقة VIP/gi, 'للاشتراك الغير محدود تواصل مع')
        .replace(/للاشتراك في باقه vip/gi, 'للاشتراك الغير محدود تواصل مع')
        .replace(/@adamskamal144/g, '<a href="https://t.me/adamskamal144" target="_blank" style="color:#ff6a00; font-weight:900; text-decoration:underline;">@adamskamal144</a>')
        .replace(/\n/g, '<br>');

    box.innerHTML = `
        <div style="background:#111; border:1px solid ${isError ? '#ff4444' : '#ff6a00'}; border-radius:12px; padding:25px; max-width:85%; width:400px; text-align:center; box-shadow:0 20px 50px rgba(0,0,0,1); border-top:4px solid ${isError ? '#ff4444' : '#ff6a00'};">
            <div style="font-family:'Cairo', sans-serif; font-size:1.05rem; color:#fff; font-weight:bold; margin-bottom:20px; line-height:1.8;">
                ${formattedText}
            </div>
            <button onclick="this.parentElement.parentElement.remove()" style="background:${isError ? '#ff4444' : '#ff6a00'}; color:#000; border:none; padding:10px 40px; border-radius:6px; font-weight:900; cursor:pointer; font-family:'Cairo', sans-serif; font-size:1rem; text-transform:uppercase;">موافق</button>
        </div>
    `;
    document.body.appendChild(box);
}

// ==========================================
// 2- محرك التنقل المحدث (نصوصك الحرفية المفروضة)
// ==========================================
async function nav(p){
  // تشغيل نظام التتبع والحماية للأدوات فقط (استثناء الرئيسية والإحصائيات)
  if(p !== 'home' && p !== 'analytics') {
    try {
      let res = await fetch('/api/track', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({tool: p, action: 'view'})
      });
      let data = await res.json();
      
      // أ- حالة المنع النهائي (تجاوز الـ 5 محاولات)
      if(!res.ok || !data.ok) {
         showSysMsg("🚫 عذراً، لقد استنفدت الحد الأقصى للمحاولات المجانية اليوم.<br>للاشتراك الغير محدود تواصل مع @adamskamal144", true);
         return; 
      }
      
      // ب- حالة التحذير (المحاولة 4 و 5) - تظهر الرسالة ويفتح القسم
      if(data.message && data.message.trim() !== '') {
         showSysMsg("⚠️ تنبيه: يتبقى لك محاولة واحدة مجانية اليوم.<br>للاشتراك الغير محدود تواصل مع @adamskamal144", false);
      }
    } catch(e) {
       console.error("Track Error:", e);
    }
  }

  // تنفيذ عملية فتح القسم وتغيير الواجهة
  document.querySelectorAll('.pg').forEach(x=>x.classList.remove('active'));
  document.getElementById('pg-'+p).classList.add('active');
  document.querySelectorAll('[data-p]').forEach(a=>a.classList.toggle('active', a.dataset.p === p));
  window.scrollTo({top:0});
  history.replaceState(null, null, '#'+p);

  // تشغيل المحركات الخاصة بالأدوات الفلكية عند الطلب
  if (p === 'astro' && typeof loadAstroEngine === 'function') loadAstroEngine();
  if (p === 'astropro' && typeof loadAstroPro === 'function') loadAstroPro();
}
  
  function toggleM(){document.getElementById('mn').classList.toggle('open')}
function closeM(){document.getElementById('mn').classList.remove('open')}
function toggleUserMenu(){document.getElementById('uMenu').classList.toggle('open')}

// Close dropdowns if clicked outside
document.addEventListener('click', (e) => {
  if(!e.target.closest('#uDropdown')) document.getElementById('uMenu').classList.remove('open');
});

window.addEventListener('DOMContentLoaded',()=>{
  const h=location.hash.replace('#','');
  if(h&&document.getElementById('pg-'+h))nav(h);else nav('home');
  initHalving();
  loadFnG();
  initWorkspace();
  initDailyCloseTimer();
});

// Workspace Local Storage
function initWorkspace() {
  const inputs = document.querySelectorAll('input, select');
  inputs.forEach(inp => {
    if(inp.id) {
      const saved = localStorage.getItem('ws_' + inp.id);
      if(saved !== null) inp.value = saved;
      inp.addEventListener('input', () => localStorage.setItem('ws_' + inp.id, inp.value));
      inp.addEventListener('change', () => localStorage.setItem('ws_' + inp.id, inp.value));
    }
  });
}
// خوارزمية الإغلاق اليومي للبيتكوين (00:00 UTC)
function initDailyCloseTimer() {
  function updateTimer() {
    const now = new Date();
    // استخراج الوقت الحالي بناءً على توقيت غرينتش (UTC)
    const h = now.getUTCHours();
    const m = now.getUTCMinutes();
    const s = now.getUTCSeconds();

    // حساب الوقت المتبقي حتى منتصف الليل (24:00:00)
    let remH = (23 - h).toString().padStart(2, '0');
    let remM = (59 - m).toString().padStart(2, '0');
    let remS = (59 - s).toString().padStart(2, '0');

    const display = document.getElementById('btc-countdown');
    if(display) {
      // تحديث الواجهة بصيغة HH:MM:SS
      display.innerText = `${remH}:${remM}:${remS}`;
    }
  }
  updateTimer(); // الاستدعاء الأولي الفوري
  setInterval(updateTimer, 1000); // التحديث الدوري كل ثانية
}

// 1. Halving Countdown
function initHalving(){
  const target=new Date('2028-04-14T00:00:00Z').getTime();
  const halvStart=new Date('2024-04-20T00:09:00Z').getTime();
  const totalSpan=target-halvStart;
  function tick(){
    const now=Date.now(),left=target-now;
    if(left<=0){document.getElementById('halvingNums').innerHTML='<div style="color:var(--o);font-size:1.2rem;font-weight:700">تم تفعيل الهالفينج.</div>';return}
    const d=Math.floor(left/86400000),h=Math.floor(left%86400000/3600000),m=Math.floor(left%3600000/60000),s=Math.floor(left%60000/1000);
    document.getElementById('hDays').textContent=d;document.getElementById('hHours').textContent=h;
    document.getElementById('hMins').textContent=m;document.getElementById('hSecs').textContent=s;
    const pct=((now-halvStart)/totalSpan*100).toFixed(1);
    document.getElementById('hBar').style.width=Math.min(pct,100)+'%';
  }
  tick();setInterval(tick,1000);
}

// 2. F&G Index (Live Fetch - No Cache)
async function loadFnG() {
    let fng = null;
    try {
        // إضافة الختم الزمني Date.now() لمنع تجميد المتصفح للقراءة
        const r = await fetch(`https://api.alternative.me/fng/?limit=1&t=${Date.now()}`);
        const data = await r.json();
        if (data && data.data) {
            fng = data.data[0];
            // مسح أي كاش قديم عالق في متصفحات المستخدمين
            localStorage.removeItem('fng_data');
            localStorage.removeItem('fng_time');
        }
    } catch(e) {
        // في حال فشل الاتصال، يتم وضع قيمة حيادية
        fng = {value: 50, value_classification: 'Neutral'};
    }

  if (fng) renderFnG(fng);
}

function renderFnG(fng) {
    const targetValue = parseInt(fng.value) || 50;
    const classification = fng.value_classification || 'Neutral';
    
    // تحويل القيمة إلى زاوية للإبرة (-90 يسار إلى +90 يمين)
    const degree = -90 + (targetValue / 100 * 180);
    
    // تحديد لون النتيجة بما يتطابق مع القطاعات (من الأبيض للبرتقالي)
    let zoneColor = '#ffffff'; 
    if (targetValue >= 20 && targetValue < 40) zoneColor = '#e6e6e6'; 
    else if (targetValue >= 40 && targetValue < 60) zoneColor = '#ffccb3'; 
    else if (targetValue >= 60 && targetValue < 80) zoneColor = '#ff8c33'; 
    else if (targetValue >= 80) zoneColor = '#ff6a00'; 

    // دالة لتحديث الشاشة الرئيسية وصفحة التحليل في نفس الوقت
    function updateWidget(prefix) {
        const needleWrap = document.getElementById(`${prefix}NeedleWrap`);
        const needleBody = document.getElementById(`${prefix}NeedleBody`);
        const pivot = document.getElementById(`${prefix}Pivot`);
        const valEl = document.getElementById(`${prefix}GaugeVal`);
        const labelEl = document.getElementById(`${prefix}LabelText`);

        if (needleWrap && needleBody && valEl && labelEl && pivot) {
            // انطلاق الإبرة
            needleWrap.style.transform = `rotate(${degree}deg)`;
            
            // تطبيق الألوان 
            needleBody.style.backgroundColor = zoneColor;
            pivot.style.borderColor = zoneColor;
            valEl.style.color = zoneColor;
            labelEl.style.color = zoneColor;
            labelEl.textContent = classification;

            // العداد المتحرك (يعد تصاعدياً مع انطلاق الإبرة)
            let currentVal = 0;
            const duration = 1500; // 1.5 ثانية (لتتطابق مع سرعة الإبرة)
            const intervalTime = 30;
            const steps = duration / intervalTime;
            const increment = targetValue / steps;

            const counter = setInterval(() => {
                currentVal += increment;
                if (currentVal >= targetValue) {
                    currentVal = targetValue;
                    clearInterval(counter);
                }
                valEl.textContent = Math.floor(currentVal);
            }, intervalTime);
        }
    }

    updateWidget('home');
    updateWidget('sent');
}
  
  // ============================================================
// نظام إرسال نبضات القلب (Heartbeat) لمعرفة مدة بقاء المستخدم
// ============================================================
setInterval(() => {
  // إرسال طلب صامت إلى الخادم كل 60 ثانية (دقيقة واحدة)
  fetch('/api/heartbeat', { 
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  }).catch((err) => {
    // تجاهل الأخطاء بصمت كي لا تزعج المستخدم إذا انقطع الإنترنت لحظياً
    console.log('Heartbeat skipped');
  });
}, 60000); // 60000 مللي ثانية = 1 دقيقة

  
</script>
<style id="radar-engine-styles">
    /* 1. حركيات المجلد والورقة المنزلقة 3D */
    @keyframes paperSlideDrop {
        0%   { transform: translateY(-14px); opacity: 0; }
        15%  { transform: translateY(-14px); opacity: 1; }
        40%  { transform: translateY(4px); opacity: 1; }
        55%  { transform: translateY(8px); opacity: 0; }
        100% { transform: translateY(-14px); opacity: 0; }
    }
    @keyframes folderFrontOpen {
        0%, 100% { transform: scaleY(1) translateY(0); }
        25%, 55% { transform: scaleY(0.85) translateY(2px); }
    }
    .radar-paper-slide { animation: paperSlideDrop 2.5s cubic-bezier(0.34, 1.56, 0.64, 1) infinite; }
    .radar-folder-front { transform-origin: center bottom; animation: folderFrontOpen 2.5s cubic-bezier(0.34, 1.56, 0.64, 1) infinite; }

    /* 2. زر الحفظ العائم (الهيكل الديناميكي الدقيق) */
    #radar-floating-btn {
        position: fixed; bottom: calc(25px + env(safe-area-inset-bottom, 0px)); left: 20px; z-index: 99999;
        background: rgba(10, 10, 10, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--o); color: var(--o); border-radius: 50px;
        font-family: 'Cairo', sans-serif; font-weight: 900; font-size: 0.95rem; cursor: pointer;
        box-shadow: 0 4px 20px rgba(0,0,0,0.8), inset 0 0 10px rgba(255,106,0,0.1);
        display: none; align-items: center; justify-content: center; gap: 8px;
        
        /* ضبط الأبعاد الهندسية لمنع التشوه */
        height: 46px; padding: 0 24px; box-sizing: border-box;
        overflow: hidden; white-space: nowrap; max-width: 250px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    #radar-floating-btn:hover { background: rgba(255, 106, 0, 0.15); box-shadow: 0 6px 25px rgba(0,0,0,0.9), inset 0 0 15px rgba(255,106,0,0.3); transform: translateY(-2px); }
    #radar-floating-btn:active { transform: scale(0.92); }
    #radar-floating-btn.saved { background: var(--o) !important; color: #000 !important; box-shadow: 0 0 25px rgba(255, 106, 0, 0.6) !important; }
    
    /* حالة الانكماش (دائرة هندسية مربوطة الأقطار بنسبة 1:1) */
    #radar-floating-btn.radar-shrunk {
        width: 46px; max-width: 46px; padding: 0; gap: 0; opacity: 0.5; backdrop-filter: blur(4px);
    }
    #radar-floating-btn.radar-shrunk #radar-save-text {
        opacity: 0; visibility: hidden; width: 0; max-width: 0; margin: 0; padding: 0;
    }
    #radar-save-text {
        transition: all 0.3s ease; opacity: 1; visibility: visible; max-width: 150px;
    }

    /* 3. شريط تحذير التجميد (عند استرجاع الأرقام) */
    .radar-archive-banner {
        background: rgba(255, 106, 0, 0.15); border: 1px dashed var(--o); color: var(--o);
        padding: 10px 15px; border-radius: 8px; margin-bottom: 20px; text-align: center;
        font-family: 'Cairo', sans-serif; font-size: 0.85rem; font-weight: bold;
        display: flex; align-items: center; justify-content: space-between; gap: 10px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5), inset 0 0 10px rgba(255,106,0,0.2);
        animation: pulseSoft 2s infinite;
    }

    /* 4. القائمة المنسدلة للرادار */
    #radar-dropdown {
        display: none; position: fixed; top: 55px; left: 15px; width: 320px; max-width: 90vw;
        background: rgba(20, 10, 0, 0.95); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
        border: 1px solid var(--o); border-radius: 12px; box-shadow: 0 20px 50px rgba(0,0,0,0.95), inset 0 2px 15px rgba(255,106,0,0.2);
        z-index: 100000; flex-direction: column; overflow: hidden; animation: radarFadeIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @keyframes radarFadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    
    .radar-header { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: rgba(0,0,0,0.8); border-bottom: 1px solid var(--o); }
    .radar-title { color: #fff; font-family: 'Cairo', sans-serif; font-weight: 900; font-size: 0.95rem; }
    .radar-close { color: #fff; font-family: 'Cairo', sans-serif; font-size: 0.75rem; font-weight: 900; cursor: pointer; padding: 4px 12px; background: rgba(255,106,0,0.1); border-radius: 6px; border: 1px solid var(--o); transition: 0.2s; }
    .radar-close:hover { background: #ff4444; color: #fff; border-color: #ff4444; }

    .radar-body { max-height: 400px; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 8px; scrollbar-width: thin; }
    .radar-body::-webkit-scrollbar { width: 5px; } .radar-body::-webkit-scrollbar-thumb { background: var(--o); border-radius: 5px; }
    
    .radar-item {
        background: rgba(0,0,0,0.6); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px;
        padding: 12px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; transition: all 0.2s ease; border-right: 3px solid transparent;
    }
    .radar-item:hover { border-color: var(--o); border-right-color: var(--o); background: rgba(255,106,0,0.15); transform: translateX(-4px); }
    
    .radar-item-info { display: flex; flex-direction: column; gap: 3px; flex: 1; text-align: right; }
    .radar-item-tool { color: #fff; font-size: 0.85rem; font-weight: 900; font-family: 'Cairo', sans-serif; }
    .radar-item-meta { color: var(--o); font-size: 0.8rem; font-family: 'Share Tech Mono', monospace; font-weight: bold; }
    .radar-item-time { color: #888; font-size: 0.65rem; font-family: 'Share Tech Mono', monospace; }
    
    .radar-del-btn { background: transparent; border: none; padding: 8px; cursor: pointer; color: #fff; display: flex; align-items: center; justify-content: center; transition: 0.2s; border-radius: 6px; }
    .radar-del-btn:hover { color: #ff4444; background: rgba(255,68,68,0.15); transform: scale(1.1); }
    .radar-del-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

    .radar-empty { text-align: center; padding: 30px 15px; color: #ccc; font-size: 0.85rem; font-family: 'Cairo', sans-serif; line-height: 1.8; }
    .radar-clear-all { text-align: center; padding: 12px; background: rgba(0,0,0,0.8); color: #ff4444; font-size: 0.85rem; font-family: 'Cairo', sans-serif; font-weight: 900; cursor: pointer; border-top: 1px solid rgba(255,106,0,0.4); transition: 0.2s; }
    .radar-clear-all:hover { background: #ff4444; color: #000; }
</style>

<button id="radar-floating-btn" onclick="radarSaveCurrentAnalysis(event)">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 4h5l2 3h9a2 2 0 0 1 2 2v2H2V6a2 2 0 0 1 2-2z"></path>
      <path d="M2 10h20l-1.5 9a2 2 0 0 1-2 2H5.5a2 2 0 0 1-2-2z"></path>
  </svg>
  <span id="radar-save-text">حفظ التحليل</span>
</button>

<div id="radar-dropdown">
  <div class="radar-header">
      <span class="radar-title">أرشيف التحليلات</span>
      <button class="radar-close" onclick="closeRadarMenu(event)">إغلاق</button>
  </div>
