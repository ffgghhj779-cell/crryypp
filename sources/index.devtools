<div class="btb-overlay" id="btbSearchModal">
  <div class="btb-modal">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; border-bottom:1px solid #1a1a1a; padding-bottom:10px;">
      <div style="color:#fff; font-family:'Cairo', sans-serif; font-weight:900; font-size:1.1rem; display:flex; align-items:center; gap:8px;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        البحث السريع
      </div>
      <div onclick="document.getElementById('btbSearchModal').classList.remove('open')" style="color:var(--o); font-size:1.8rem; line-height:1; font-weight:bold; cursor:pointer;">&times;</div>
    </div>
    <input type="text" id="btbSearchInput" class="btb-input" placeholder="اكتب اسم الأداة للوصول السريع..." autocomplete="off">
    <div id="btbSearchResults" style="max-height: 50vh; overflow-y: auto;">
      <div style="text-align:center; color:#555; font-size:0.8rem; padding:20px; font-family:'Cairo', sans-serif;">ابدأ الكتابة للعثور على الأداة فوراً</div>
    </div>
  </div>
</div>

<div id="btbToast" class="btb-toast"></div>


 

<script>
/* ===================================================================
   محرك شريط التنقل السفلي (Bottom Tab Bar) - 360°
   =================================================================== */
(function(){
  'use strict';

  // دالة إظهار التنبيهات
  function btbShowToast(msg){
    const t = document.getElementById('btbToast');
    if (!t) return;
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(t._timer);
    t._timer = setTimeout(() => t.classList.remove('show'), 2500);
  }

  // 1. الرئيسية
  window.btbGoHome = function() {
    if(typeof nav === 'function') nav('home');
    if(typeof closeM === 'function') closeM();
    window.scrollTo({top:0, behavior:'smooth'});
  };

  // 2. الباحث الذكي (فهرسة تلقائية للأدوات)
  let searchIndex = [];
  function buildIndex() {
    searchIndex = [];
    const cards = document.querySelectorAll('.tc[onclick*="nav("]');
    cards.forEach(card => {
      const match = (card.getAttribute('onclick')||'').match(/nav\(['"]([^'"]+)['"]\)/);
      if(!match) return;
      const id = match[1];
      const titleEn = card.querySelector('.tc-n') ? card.querySelector('.tc-n').innerText.trim() : '';
      const titleAr = card.querySelector('.tc-d') ? card.querySelector('.tc-d').innerText.trim() : '';
      // منع التكرار في الفهرس
      if(!searchIndex.find(t => t.id === id)) {
        searchIndex.push({ id, en: titleEn, ar: titleAr });
      }
    });
  }

  window.btbOpenSearch = function() {
    if(searchIndex.length === 0) buildIndex();
    const modal = document.getElementById('btbSearchModal');
    const input = document.getElementById('btbSearchInput');
    modal.classList.add('open');
    input.value = '';
    document.getElementById('btbSearchResults').innerHTML = '<div style="text-align:center; color:#555; font-size:0.8rem; padding:20px; font-family:\'Cairo\', sans-serif;">ابدأ الكتابة للعثور على الأداة فوراً</div>';
    setTimeout(() => input.focus(), 100);
  };

  document.getElementById('btbSearchInput')?.addEventListener('input', function(e) {
    const query = e.target.value.toLowerCase().trim();
    const resBox = document.getElementById('btbSearchResults');
    
    if(query.length < 1) {
      resBox.innerHTML = '<div style="text-align:center; color:#555; font-size:0.8rem; padding:20px; font-family:\'Cairo\', sans-serif;">ابدأ الكتابة للعثور على الأداة فوراً</div>';
      return;
    }

    const matches = searchIndex.filter(item => 
      item.en.toLowerCase().includes(query) || item.ar.toLowerCase().includes(query)
    );

    if(matches.length === 0) {
      resBox.innerHTML = '<div style="text-align:center; color:var(--o); font-size:0.8rem; padding:20px; font-family:\'Cairo\', sans-serif;">لم يتم العثور على أداة مطابقة</div>';
      return;
    }

    resBox.innerHTML = matches.map(item => `
      <div class="btb-result-item" onclick="btbSelectTool('${item.id}')">
        <div class="btb-result-en">${item.en || item.id}</div>
        <div class="btb-result-ar">${item.ar}</div>
      </div>
    `).join('');
  });

  window.btbSelectTool = function(id) {
    document.getElementById('btbSearchModal').classList.remove('open');
    if(typeof nav === 'function') nav(id);
    if(typeof closeM === 'function') closeM();
    window.scrollTo({top:0, behavior:'smooth'});
  };

  // إغلاق نافذة البحث عند النقر خارجها
  document.getElementById('btbSearchModal')?.addEventListener('click', function(e) {
    if(e.target === this) this.classList.remove('open');
  });


// 3. إدارة المخاطر (استبدلت لقطة الشاشة)
window.btbGoRisk = function() {
  if(typeof nav === 'function') nav('risk');
  if(typeof closeM === 'function') closeM();
  window.scrollTo({top:0, behavior:'smooth'});
};

  
  // 4. تحديث المنصة (Refresh)
  window.btbRefreshApp = function() {
    btbShowToast('جاري تحديث المنصة...');
    setTimeout(() => {
      // يدعم متصفح تليجرام الداخلي والمتصفحات العادية
      if (window.Telegram && window.Telegram.WebApp) {
        window.location.reload(); 
      } else {
        // تحديث إجباري مع إزالة الكاش من الروابط
        window.location.href = window.location.pathname + window.location.hash;
      }
    }, 300);
  };

  // تهيئة الفهرس بعد ثانية من فتح الموقع لضمان تحميل الكروت
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(buildIndex, 1500);
  });

})();
</script>
<script>
/* ===================================================================
   الاعتراض الذكي: خصم المحاولات فقط عند تشغيل التحليل
   =================================================================== */
document.addEventListener('click', async function(e) {
    let btn = e.target.closest('button');
    if (!btn) return;
    
    const onclickAttr = btn.getAttribute('onclick') || '';
    
    // التحقق التلقائي هل الزر يقوم بتشغيل تحليل (باستثناء أزرار التنقل)
    const analysisKeywords = ['run', 'calc', 'execute', 'buildSq9', 'cfRun', 'cddRun', 'lsm_', 'mtfc_', 'connectWS'];
    const isAnalysisBtn = analysisKeywords.some(k => onclickAttr.includes(k));
                          
    if (isAnalysisBtn && !onclickAttr.includes('nav(') && !onclickAttr.includes('switch') && !btn.hasAttribute('data-verified')) {
        e.preventDefault();
        e.stopPropagation();
        
        // استثناء أدوات معينة لا تتطلب خصماً كإدارة المخاطر
        const activePg = document.querySelector('.pg.active');
        const toolName = activePg ? activePg.id.replace('pg-', '') : 'unknown';
        if (toolName === 'risk' || toolName === 'calc') {
            btn.setAttribute('data-verified', 'true');
            btn.click();
            setTimeout(() => btn.removeAttribute('data-verified'), 1000);
            return;
        }

        const originalText = btn.innerHTML;
        btn.innerHTML = 'جاري التحقق من الرصيد... ⏳';
        btn.style.opacity = '0.7';
        btn.style.pointerEvents = 'none'; // منع النقر المزدوج
        
        try {
            // إرسال طلب أمر بالتنفيذ (ليتم خصم المحاولة)
            let res = await fetch('/api/track', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({tool: toolName, action: 'execute'}) 
            });
            let data = await res.json();
            
            btn.innerHTML = originalText;
            btn.style.opacity = '1';
            btn.style.pointerEvents = 'auto';

            // إذا انتهى الرصيد نوقف كل شيء ونظهر التنبيه
            if (!res.ok || !data.ok) {
                if(typeof showSysMsg === 'function') showSysMsg(data.error || "🚫 عذراً، لقد استنفدت الحد الأقصى للمحاولات المجانية.", true);
                return;
            }
            
            // الرصيد يكفي -> أظهر ملاحظة التبقي إن وجدت، ثم شغل التحليل
            if (data.message && typeof showSysMsg === 'function') showSysMsg(data.message, false);
            
            btn.setAttribute('data-verified', 'true');
            btn.click(); // إكمال تنفيذ التحليل
            
            // فك القفل عن الزر بعد ثانيتين
            setTimeout(() => btn.removeAttribute('data-verified'), 2000);

        } catch(err) {
            console.error('Execution Check Error:', err);
            btn.innerHTML = originalText;
            btn.style.opacity = '1';
            btn.style.pointerEvents = 'auto';
        }
    }
}, true); // UseCapture لمعالجة الضغطة قبل التنفيذ
</script>
<div class="ftr-modal-bg" id="ftr-modal-about">
  <div class="ftr-modal-card">
    <div class="ftr-modal-head">
      <div class="ftr-modal-title">عن منصة 360°</div>
      <div class="ftr-modal-close" onclick="ftrCloseModal('about')">إغلاق &times;</div>
    </div>
    <div class="ftr-modal-content">
      <p>منصة <strong>360°</strong> هي "محطة عمل كميّة" (Quantitative Terminal) متكاملة للتحليل الفني للعملات الرقمية، صُممت وبُنيت خصيصاً للمتداول العربي المحترف.</p>
      <h4>رسالتنا وهدفنا</h4>
      <p>القضاء على العشوائية والعاطفة في التداول من خلال توفير أدوات تحليل تعتمد حصراً على الرياضيات والاحتمالات، لتمكين المتداول من اتخاذ قرارات مبنية على بيانات مؤسسية صلبة.</p>
      <h4>ماذا نقدم؟</h4>
      <ul>
        <li>أكثر من 30 محرك تحليل فني وكمّي عالي الدقة.</li>
        <li>معالجة حية لبيانات السوق (Order Book, CVD, Heatmap).</li>
        <li>خوارزميات مدمجة لمدارس (SMC، وايكوف، الهارمونيك، وجان).</li>
        <li>أدوات حماية رأس المال والمحاكاة الاحتمالية (GARCH, Markov).</li>
      </ul>
    </div>
  </div>
</div>

<div class="ftr-modal-bg" id="ftr-modal-terms">
  <div class="ftr-modal-card">
    <div class="ftr-modal-head">
      <div class="ftr-modal-title">شروط الاستخدام</div>
      <div class="ftr-modal-close" onclick="ftrCloseModal('terms')">إغلاق &times;</div>
    </div>
    <div class="ftr-modal-content">
      <h4>1. طبيعة الخدمة والبيانات</h4>
      <p>منصة 360° هي أداة رياضية وتقنية. تعتمد المنصة على واجهات برمجة (APIs) خارجية لجلب الأسعار، ولا نتحمل مسؤولية أي تأخير أو خطأ في مزودي البيانات.</p>
      <h4>2. غياب التوصيات المالية</h4>
      <p>الإشارات، الدعوم، المقاومات، وأهداف النماذج (مثل الهارمونيك والأوتاد) هي قياسات رياضية وليست توجيهات مالية. لا يوجد شيء مضمون 100% في الأسواق المالية.</p>
      <h4>3. التداول الفوري (Spot)</h4>
      <p>جميع استراتيجيات المنصة موجهة للتداول الفوري (Spot) حصراً. استخدامك لهذه التحليلات في أسواق العقود الآجلة أو برافعة مالية هو تصرف عالي الخطورة يقع على مسؤوليتك وحدك.</p>
      <h4>4. تقييد الحسابات</h4>
      <p>تحتفظ الإدارة بالحق في تعليق أو حظر أي حساب يسيء استخدام واجهات المنصة، أو يقوم بمحاولات خرق أمني، أو يشارك الوصول بشكل غير مصرح به.</p>
    </div>
  </div>
</div>

<div class="ftr-modal-bg" id="ftr-modal-privacy">
  <div class="ftr-modal-card">
    <div class="ftr-modal-head">
      <div class="ftr-modal-title">سياسة الخصوصية</div>
      <div class="ftr-modal-close" onclick="ftrCloseModal('privacy')">إغلاق &times;</div>
    </div>
    <div class="ftr-modal-content">
      <h4>حماية هويتك</h4>
      <p>المنصة تعمل بالربط المباشر مع تطبيق تليجرام (Telegram WebApp). نحن لا نطلب إدخال أي كلمات مرور، ولا بريد إلكتروني، ولا أرقام هواتف.</p>
      <h4>بيانات الاستخدام</h4>
      <p>نقوم بتتبع "إحصائيات استخدام الأدوات" فقط (مثال: أداة X تم استخدامها 50 مرة اليوم) بغرض قياس أداء الخادم وتطوير الخوارزميات، دون ربط هذه التحليلات بهويتك الشخصية.</p>
      <h4>التخزين المحلي</h4>
      <p>المفضلة (Workspace)، وأرشيف التحليلات، وإعداداتك الشخصية يتم تخزينها محلياً في ذاكرة متصفحك (LocalStorage) فقط، ولا يتم رفعها لخوادمنا لحماية خصوصية تداولاتك.</p>
    </div>
  </div>
</div>

<script>
/* ===================================================================
   محرك النوافذ المنبثقة للفوتر (Footer Modals)
   =================================================================== */
(function(){
  'use strict';
  window.ftrOpenModal = function(id){
    const m = document.getElementById('ftr-modal-' + id);
    if (m) m.classList.add('show');
  };
  window.ftrCloseModal = function(id){
    const m = document.getElementById('ftr-modal-' + id);
    if (m) m.classList.remove('show');
  };
  // الإغلاق عند النقر في المساحة الفارغة خارج النافذة
  document.addEventListener('DOMContentLoaded', function(){
    document.querySelectorAll('.ftr-modal-bg').forEach(function(m){
      m.addEventListener('click', function(e){
        if (e.target === m) m.classList.remove('show');
      });
    });
  });
})();
</script>

<!-- TOKEN SCANNER -->
<div class="pg" id="pg-tscan">
  <div class="tp" style="max-width: 650px; margin: 0 auto; padding: 10px;">

    <!-- الترويسة العلوية -->
    <div style="background:var(--s); border:1px solid var(--b); border-radius:4px; padding:8px 12px; margin-bottom:6px; display:flex; justify-content:space-between; align-items:center; margin-top:56px;">
      <div style="display:flex; align-items:center; gap:8px;">
        <span style="color:var(--o); font-size:0.9rem; font-weight:bold; font-family:'Share Tech Mono',monospace; letter-spacing:1px;">TOKEN SCANNER</span>
        <span style="color:var(--t3);">|</span>
        <span style="color:var(--t2); font-size:0.55rem; font-family:'Share Tech Mono',monospace; letter-spacing:1px;">SCAM DETECTION & AUDIT</span>
      </div>
      <div class="tscan-tier-badge" style="margin-top:0;">REAL-TIME</div>
    </div>

    <!-- لوحة المدخلات -->
    <div style="background:var(--s); border:1px solid var(--b); border-radius:4px; padding:16px; margin-bottom:10px;">
      <div style="margin-bottom:14px;">
        <label style="font-size:0.7rem; color:var(--t2); margin-bottom:5px; display:block; font-weight:600;">رمز العملة للفحص (مثال: BTCUSDT)</label>
        <input type="text" id="tscan-symbol" placeholder="BTCUSDT" value="BTCUSDT" class="tscan-input-full" />
      </div>

      <button onclick="runTokenScanner()" style="width:100%; padding:12px; background:var(--o); color:var(--bg); font-weight:900; border:none; border-radius:4px; cursor:pointer; font-family:'Cairo',sans-serif; font-size:0.9rem; letter-spacing:1px; margin-top:4px;">فحص أمان المشروع</button>
    </div>

    <!-- لوحة النتائج -->
    <div id="tscan-loading" style="display:none; text-align:center; padding:30px; color:var(--o); font-family:'Share Tech Mono',monospace; font-size:13px; font-weight:bold;">جاري الفحص المالي وربط بيانات GitHub API...</div>
    <div id="tscan-dashboard" style="display:none; flex-direction:column; gap:6px;"></div>

  </div>
</div>

              
              
</body>
</html>
