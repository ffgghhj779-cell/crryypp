          <tr><td colspan="3" style="text-align:center">جاري استرجاع السجلات...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
 // الباتش الأمني والجدولة: إعادة تعريف fetch لحقن التوكن ومنع هجوم الفيضان (WAF Bypass)
(function() {
    const originalFetch = window.fetch;
    let klinesQueue = Promise.resolve(); // طابور الطلبات
    let lastKlinesFetch = 0;

    window.fetch = function(url, options = {}) {
        // 1. حقن التوكن للطلبات الداخلية
        if (typeof url === 'string' && url.startsWith('/api/')) {
            let token = '';
            try {
                const match = document.cookie.match(/s360=([^;]+)/);
                if (match) token = match[1];
            } catch(e) {}
            
            if (!token) {
                try { token = localStorage.getItem('s360') || ''; } catch(e) {}
            }

            if (token) {
                options.headers = options.headers || {};
                if (options.headers instanceof Headers) {
                    options.headers.set('Authorization', 'Bearer ' + token);
                } else {
                    options.headers['Authorization'] = 'Bearer ' + token;
                }
            }
        }

        // 2. جدولة طلبات الشموع (Global Request Throttling)
        if (typeof url === 'string' && url.includes('/api/binance-klines')) {
            return new Promise((resolve, reject) => {
                klinesQueue = klinesQueue.then(() => {
                    const now = Date.now();
                    // ضمان فارق 250 ملي ثانية كحد أدنى بين الطلب والآخر
                    const delay = Math.max(0, 250 - (now - lastKlinesFetch));
                    return new Promise(r => setTimeout(r, delay)).then(() => {
                        lastKlinesFetch = Date.now();
                        return originalFetch.call(window, url, options).then(resolve).catch(reject);
                    });
                }).catch(reject); // حماية الطابور من الانهيار في حال فشل أحد الطلبات
            });
        }

        // تمرير الطلبات العادية بدون تأخير
        return originalFetch.call(this, url, options);
    };
})();

</script>

<style>
  /* التنسيقات الهندسية للشريط العلوي المتزن */
  .hdr-box {
    background: rgba(255, 106, 0, 0.12);
    border: 1px solid rgba(255, 106, 0, 0.3);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    box-sizing: border-box;
    cursor: pointer;
    height: 36px; /* توحيد الارتفاع لجميع الكتل */
  }
  .hdr-box:hover {
    background: rgba(255, 106, 0, 0.22);
    border-color: rgba(255, 106, 0, 0.6);
  }
  .hdr-moon {
    width: 36px;
    padding: 0;
    animation: glowPulse 2.5s infinite alternate;
  }
  .hdr-session {
    padding: 0 16px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .hdr-user {
    padding: 0 16px;
    position: relative;
  }
  .logo-box {
    background: var(--o);
    color: #fff;
    font-weight: 900;
    font-size: 15px;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    font-family: 'Share Tech Mono', monospace;
  }
  /* حركة التوهج النبضي */
  @keyframes glowPulse {
    0% { box-shadow: 0 0 2px rgba(255, 106, 0, 0.1); }
    100% { box-shadow: 0 0 12px rgba(255, 106, 0, 0.45); }
  }
  /* حركة دوران القمر في المدار */
  @keyframes orbitSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
 /* ========================================================
   🚀 ترقيات Web3 & 3D Solid UI (تباين عالي، تجويف واضح، أرقام حادة) 🚀
   ======================================================== */

/* 1. خلفية رئيسية داكنة جداً (وليس أسود 100%) لإبراز الكروت */
body {
    background: #050505 !important;
}

/* 2. الكروت (Cards) - تجسيم 3D صلب وحواف بارزة جداً مريحة للعين */
.tc, .rc, .halving, .widget-box, .garch-bounds-panel, .hero-btc-card, 
.moon-wrap, div[style*="background: #0a0a0a"], div[style*="background: #060606"], div[style*="background: #080808"], .risk-panel {
    /* لون رمادي صلب يفصل الكارت تماماً عن الخلفية السوداء (لا للشفافية) */
    background: linear-gradient(180deg, #1c1c1c 0%, #111111 100%) !important;
    border: 1px solid #222222 !important; 
    /* 💡 السر هنا: إضاءة علوية وجانبية تعطي إيحاء البروز والـ 3D (Bevel Effect) */
    border-top: 1px solid #444444 !important; 
    border-left: 1px solid #333333 !important; 
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.9), 0 2px 5px rgba(0,0,0,0.5) !important; 
    border-radius: 12px !important;
    backdrop-filter: none !important; /* إيقاف التمويه الزجاجي */
}

/* 3. حركة الطفو العنيفة والملموسة (Hover Effects) */
.tc {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease, border-color 0.4s ease, background 0.4s ease !important;
    will-change: transform;
}
.tc:hover {
    /* قفزة صريحة وواضحة للأعلى مع تكبير طفيف */
    transform: translateY(-8px) scale(1.02) !important; 
    border-color: var(--o) !important; 
    border-top-color: #ff8c33 !important; /* لمعة برتقالية علوية */
    border-left-color: #ff8c33 !important;
    background: linear-gradient(180deg, #242424 0%, #151515 100%) !important;
    /* ظل أسود عميق يرفع الكارت + توهج برتقالي خارجي للإطار فقط وليس للنص */
    box-shadow: 0 20px 40px rgba(0, 0, 0, 1), 0 0 25px rgba(255, 106, 0, 0.25) !important; 
    z-index: 10;
}

/* 4. أيقونات الكروت - تظهر كأزرار لوحة المفاتيح الميكانيكية */
.tc-i {
    border-radius: 10px !important;
    background: linear-gradient(135deg, #1f1f1f, #0a0a0a) !important; 
    border: 1px solid #111 !important;
    border-top: 1px solid #3d3d3d !important; /* إضاءة علوية للأيقونة */
    box-shadow: 0 4px 10px rgba(0,0,0,0.8), inset 0 1px 1px rgba(255,255,255,0.05) !important;
    transition: all 0.3s ease !important;
}
.tc:hover .tc-i {
    background: rgba(255, 106, 0, 0.15) !important;
    border-color: var(--o) !important;
    box-shadow: 0 0 15px rgba(255, 106, 0, 0.4), inset 0 0 10px rgba(255, 106, 0, 0.2) !important;
}

/* 5. حقول الإدخال (Inputs & Selects) - تجويف محفور واضح جداً (Engraved) */
input[type="number"], input[type="text"], input[type="date"], select {
    background: #000000 !important; /* أسود قاتم لتمييزها عن الكارت الرمادي */
    border: 1px solid #111111 !important; 
    border-top: 2px solid #000000 !important; /* تأكيد التجويف العميق من الأعلى */
    /* 💡 إضاءة سفلية خفيفة تعكس الضوء لتبدو الحقول محفورة حقاً في الشاشة */
    border-bottom: 1px solid #4a4a4a !important; 
    box-shadow: inset 0 4px 12px rgba(0,0,0,1) !important; /* ظل داخلي قوي جداً */
    color: #ffffff !important;
    border-radius: 8px !important;
    padding: 10px 14px !important;
    font-size: 0.95rem !important;
    transition: all 0.2s ease !important;
}
input:focus, select:focus {
    background: #080808 !important;
    border-color: var(--o) !important;
    border-bottom-color: var(--o) !important;
    border-top-color: #cc5500 !important;
    box-shadow: inset 0 2px 6px rgba(0,0,0,0.9), 0 0 12px rgba(255, 106, 0, 0.3) !important;
    outline: none !important;
}

/* 6. الأزرار البرتقالية (Buttons) - مسطحة وأنيقة بدون 3D أو حركة */
.btn {
    background: linear-gradient(135deg, #ff8c33 0%, #ff6a00 100%) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    box-shadow: 0 4px 15px rgba(255, 106, 0, 0.2) !important; /* توهج ناعم يعزل الزر عن الخلفية */
    color: #000000 !important;
    font-weight: 900 !important;
    border-radius: 8px !important;
    text-transform: uppercase;
    letter-spacing: 1px !important;
    transition: all 0.2s ease !important;
    transform: none !important; /* إلغاء أي حركة فيزيائية */
    margin-bottom: 0 !important; /* إلغاء مساحة الظل السفلية */
}
.btn:hover {
    filter: brightness(1.1) !important;
    box-shadow: 0 6px 20px rgba(255, 106, 0, 0.4) !important;
    transform: none !important; /* إلغاء حركة الطفو */
}
.btn:active {
    transform: scale(0.98) !important; /* انكماش بسيط جداً للنقر بدلاً من النزول 3D */
    box-shadow: 0 2px 8px rgba(255, 106, 0, 0.3) !important;
}

/* الأزرار الرمادية الثانوية (مثل التبويبات والمقاسات) */
.btn2, .risk-tab, .sq9-sz {
    background: linear-gradient(180deg, #2a2a2a 0%, #151515 100%) !important;
    border: 1px solid #333 !important;
    border-top: 1px solid #555 !important;
    box-shadow: 0 4px 0 #000, 0 6px 10px rgba(0,0,0,0.6) !important;
    color: var(--t2) !important;
    transition: all 0.1s ease !important;
    margin-bottom: 4px !important;
}
.btn2:hover, .risk-tab:hover {
    border-color: var(--o) !important;
    color: #fff !important;
}
.btn2:active, .risk-tab:active {
    transform: translateY(4px) !important;
    box-shadow: 0 0 0 #000, inset 0 3px 6px rgba(0,0,0,0.9) !important;
}
.risk-tab.active, .sq9-sz-active {
    background: rgba(255, 106, 0, 0.15) !important;
    border-color: var(--o) !important;
    color: #fff !important;
    box-shadow: inset 0 2px 5px rgba(0,0,0,0.5), 0 0 0 transparent !important;
    transform: translateY(4px) !important;
}

/* 7. الجداول (Tables) - فواصل صريحة وأنيقة */
.rt th {
    background: #111111 !important;
    border-bottom: 2px solid #333 !important;
    color: var(--t2) !important;
}
.rt td {
    border-bottom: 1px solid #1a1a1a !important;
    background: #0d0d0d !important;
}
.rt tr:hover td {
    background: #161616 !important;
}

/* 8. شريط التنقل العلوي (Navbar) */
.top-nav a {
    transition: all 0.3s ease;
    border: 1px solid transparent;
}
.top-nav a.active {
    background: rgba(255, 106, 0, 0.1) !important;
    border: 1px solid rgba(255, 106, 0, 0.3) !important;
    border-bottom: 2px solid var(--o) !important;
    border-radius: 6px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    color: #fff !important;
}

/* 9. أرقام حادة وصلبة بدون توهج لقراءة دقيقة (Crisp Typography) */
.n, .digital-clock, .hbc-price, .res-val, [id*="price"] {
    text-shadow: none !important; /* إلغاء التوهج تماماً */
    letter-spacing: -0.5px !important; /* تقارب بسيط يعطي طابعاً احترافياً للأرقام */
    font-weight: 900 !important; /* زيادة السماكة لتعويض غياب التوهج */
    -webkit-font-smoothing: antialiased !important; /* تنعيم حواف الخط */
}

/* حل مشكلة تغطية الزر للتحليلات (مساحة تنفس سفلية) */
.pg { padding-bottom: 95px !important; }

/* ========================================================
   ⏱️ مؤشر الخوف والطمع (التصميم الكلاسيكي بالهوية البصرية) ⏱️
   ======================================================== */
.fng-classic-wrap {
    display: flex; flex-direction: column; align-items: center; margin: 15px 0 10px 0;
}
.fng-gauge-container {
    position: relative; width: 240px; height: 120px; overflow: hidden;
}
/* القوس الملون والمقسم */
.fng-track {
    position: absolute; top: 0; left: 0; width: 240px; height: 240px; border-radius: 50%;
    background: conic-gradient(from 270deg at 50% 50%,
        #ffffff 0deg 36deg,       /* خوف شديد (أبيض) */
        #e6e6e6 36deg 72deg,      /* خوف (رمادي) */
        #ffccb3 72deg 108deg,     /* محايد (برتقالي باهت) */
        #ff8c33 108deg 144deg,    /* طمع (برتقالي متوسط) */
        #ff6a00 144deg 180deg,    /* طمع شديد (برتقالي ساطع) */
        transparent 180deg 360deg
    );
    -webkit-mask-image: radial-gradient(circle at 50% 50%, transparent 58%, black 59%);
    mask-image: radial-gradient(circle at 50% 50%, transparent 58%, black 59%);
}
/* الفواصل السوداء بين القطاعات */
.fng-track::after {
    content: ''; position: absolute; inset: 0; border-radius: 50%;
    background: repeating-conic-gradient(from 270deg at 50% 50%,
        transparent 0deg 35.5deg, var(--s) 35.5deg 36.5deg,
        transparent 36.5deg 71.5deg, var(--s) 71.5deg 72.5deg,
        transparent 72.5deg 107.5deg, var(--s) 107.5deg 108.5deg,
        transparent 108.5deg 143.5deg, var(--s) 143.5deg 144.5deg,
        transparent 144.5deg 180deg, transparent 180deg 360deg
    );
}
/* الإبرة المتحركة */
.fng-needle-wrap {
    position: absolute; bottom: 0; left: 50%; width: 4px; height: 110px;
    margin-left: -2px; transform-origin: bottom center;
    transform: rotate(-90deg); /* بداية من الصفر يساراً */
    transition: transform 1.5s cubic-bezier(0.34, 1.56, 0.64, 1.2); z-index: 5;
}
.fng-needle {
    position: absolute; bottom: 0; left: 0; width: 4px; height: 90px;
    background: #ffffff; border-radius: 2px 2px 0 0;
    box-shadow: -2px 0 4px rgba(0,0,0,0.5); transition: background 1.5s ease;
}
/* مسمار الارتكاز */
.fng-pivot {
    position: absolute; bottom: -8px; left: 50%; transform: translateX(-50%);
    width: 16px; height: 16px; background: #111; border: 2px solid #fff;
    border-radius: 50%; z-index: 6; transition: border-color 1.5s ease;
}
/* الرقم في المنتصف */
.fng-value {
    position: absolute; bottom: 15px; left: 50%; transform: translateX(-50%);
    font-family: 'Share Tech Mono', monospace; font-size: 2.6rem; font-weight: 900;
    color: #fff; line-height: 1; z-index: 4; text-shadow: 0 4px 10px rgba(0,0,0,0.8);
    transition: color 1.5s ease;
}
/* كلمة الخوف/الطمع أسفل العداد */
.fng-label-text {
    margin-top: 10px; font-family: 'Cairo', sans-serif; font-size: 1.1rem;
    font-weight: 900; text-transform: uppercase; letter-spacing: 1px;
    color: #ffffff; transition: color 1.5s ease;
}
.fng-mini-scale { transform: scale(0.65); margin: -25px 0 -30px 0; }
  
  /* ========================================================
   ⏳ ترقية العدادات الزمنية (Halving 3D & Clean Balanced Daily Close) ⏳
   ======================================================== */

/* --- 1. هندسة العناوين --- */
.halving-title, .widget-box .halving-title {
    color: var(--o) !important;
    font-family: 'Share Tech Mono', 'Cairo', monospace !important;
    letter-spacing: 1.5px !important;
    font-size: 0.75rem !important;
    font-weight: 900 !important;
    border-bottom: 1px dashed #333333 !important;
    padding-bottom: 10px !important;
    margin-bottom: 15px !important;
    text-transform: uppercase !important;
}

/* =======================================
   🔶 2. كارت الهالفينج (باقي كما هو تماماً) 🔶
   ======================================= */
.halving-nums { gap: 12px !important; }

.halving-box {
    background: #000000 !important;
    border: 1px solid #111111 !important;
    border-top: 2px solid #000000 !important;
    border-bottom: 1px solid #3a3a3a !important;
    box-shadow: inset 0 5px 15px rgba(0,0,0,1) !important;
    border-radius: 8px !important;
    padding: 12px 5px !important;
    flex: 1 !important;
    position: relative;
    overflow: hidden;
}

.halving-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 45%;
    background: linear-gradient(180deg, rgba(255,255,255,0.05) 0%, transparent 100%);
    pointer-events: none;
    z-index: 1;
}

.halving-box .n {
    position: relative; z-index: 2;
    font-family: 'Share Tech Mono', monospace !important;
    color: #ffffff !important;
    font-size: 1.85rem !important;
    font-weight: 900 !important;
    line-height: 1 !important;
    text-shadow: none !important;
    margin-bottom: 5px !important;
    letter-spacing: -1px !important;
}

.halving-box .l {
    position: relative; z-index: 2;
    color: var(--o) !important;
    font-weight: 800 !important;
    font-size: 0.65rem !important;
    letter-spacing: 0.5px !important;
}

.halving-bar {
    background: #000000 !important;
    border: 1px solid #111111 !important;
    border-top: 2px solid #000000 !important;
    border-bottom: 1px solid #333333 !important;
    box-shadow: inset 0 4px 8px rgba(0,0,0,1) !important;
    height: 14px !important;
    border-radius: 8px !important;
    overflow: hidden !important;
    margin: 18px 0 10px 0 !important;
    position: relative;
}

.halving-bar-fill {
    background: linear-gradient(180deg, #ff8c33 0%, #ff6a00 50%, #cc5500 100%) !important;
    box-shadow: inset 0 1px 3px rgba(255,255,255,0.4), inset 0 -2px 3px rgba(0,0,0,0.5) !important;
    border-radius: 6px !important;
    position: relative;
}

.halving-bar-fill::after {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(-45deg, transparent, transparent 10px, rgba(0, 0, 0, 0.15) 10px, rgba(0, 0, 0, 0.15) 20px) !important;
}

.halving > div:last-child {
    font-family: 'Share Tech Mono', 'Cairo', monospace !important;
    color: #777777 !important;
    border-top: 1px dashed #222222 !important;
    padding-top: 10px !important;
    margin-top: 15px !important;
    font-size: 0.65rem !important;
}

/* =======================================
   ⏱️ 3. كارت الإغلاق اليومي (أنيق، بسيط، ومتناسق) ⏱️
   ======================================= */
/* إجبار الكارت الحاوي على توسيط المحتوى بالكامل */
.widget-box {
    display: flex !important;
    flex-direction: column !important;
    justify-content: center !important;
    align-items: center !important;
    padding: 15px 10px !important;
}

/* تنسيق الساعة: حجم ممتاز يتنفس داخل الكارت بدون الالتصاق بالحواف */
.digital-clock {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    
    color: #ffffff !important;
    font-family: 'Share Tech Mono', monospace !important;
    
    /* تصغير الخط ليكون متناسقاً جداً مع المساحة المتاحة */
    font-size: 1.8rem !important; 
    font-weight: 900 !important;
    letter-spacing: 3px !important; /* مسافات مريحة بين الأرقام */
    line-height: 1 !important;
    
    /* هوامش تمنع الالتصاق وتوفر مساحة تنفس */
    margin: 15px auto !important; 
    padding: 0 !important;
    
    /* ظل أسود خفيف يعزز ثبات الرقم ووضوحه */
    text-shadow: 0 4px 6px rgba(0,0,0,0.6) !important;
    
    display: block !important;
    text-align: center !important;
    width: 100% !important;
}

/* إلغاء أي مربعات سوداء أو تأثيرات أو لمبات من الكود القديم */
.digital-clock::before,
.digital-clock::after {
    display: none !important;
    content: none !important;
    animation: none !important;
}

/* النص السفلي (متبقي على إغلاق شمعة اليوم) */
.digital-clock + div {
    font-family: 'Cairo', sans-serif !important;
    color: #888888 !important;
    font-size: 0.7rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.5px !important;
    border-top: 1px solid rgba(255, 255, 255, 0.05) !important; /* خط فاصل خفيف جداً */
    padding-top: 12px !important;
    margin-top: 5px !important;
    width: 90% !important; /* عرض أنيق متمركز */
    text-align: center !important;
}
/* ========================================================
   🎛️ ترقية الشريط العلوي والأزرار (Mechanical Top Header Keys) 🎛️
   ======================================================== */

/* 1. الشريط العلوي (Header Bar) - صلب وداكن بدون شفافية زجاجية */
.top {
    background: #050505 !important;
    backdrop-filter: none !important; 
    -webkit-backdrop-filter: none !important;
    border-bottom: 1px solid #1a1a1a !important;
    box-shadow: 0 4px 15px rgba(0,0,0,0.9) !important;
}

/* 2. أزرار الأدوات في الشريط (Hardware Buttons) */
/* يشمل أدوات الهيدر، زر القائمة، وأي زر علوي */
.hdr-box, .mbtn {
    background: linear-gradient(180deg, #1c1c1c 0%, #0d0d0d 100%) !important;
    border: 1px solid #000000 !important;
    border-top: 1px solid #3d3d3d !important; /* لمعة الإضاءة العلوية */
    border-radius: 6px !important;
    /* ظل سفلي أسود يعطي الزر سُمكاً فيزيائياً (3D) */
    box-shadow: 0 4px 0 #000000, 0 6px 8px rgba(0,0,0,0.5) !important;
    transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1) !important;
    transform: translateY(0) !important;
    margin-bottom: 4px !important; /* مساحة للسُمك السفلي حتى لا يُقص الظل */
}

/* حالة مرور الماوس (Hover) - ارتفاع وإضاءة برتقالية للحواف */
.hdr-box:hover, .mbtn:hover {
    background: linear-gradient(180deg, #242424 0%, #151515 100%) !important;
    border-color: var(--o) !important;
    border-top-color: #ff8c33 !important;
    transform: translateY(-2px) !important; /* الزر يرتفع لأعلى */
    box-shadow: 0 6px 0 #000000, 0 8px 12px rgba(0,0,0,0.8), 0 0 12px rgba(255,106,0,0.2) !important;
}

/* حالة النقر (Active) - انضغاط الزر للأسفل ميكانيكياً */
.hdr-box:active, .mbtn:active {
    transform: translateY(4px) !important; /* الزر ينزل للأسفل */
    box-shadow: 0 0 0 #000000, inset 0 3px 6px rgba(0,0,0,0.9) !important; /* يختفي السُمك ويُحفر */
    border-top-color: #111111 !important; /* اختفاء اللمعة عند الضغط */
    background: #0a0a0a !important;
}

/* 3. إسقاط ظل للأيقونات المتحركة (SVG) لتبدو بارزة ومحفورة */
.hdr-box svg, .mbtn svg {
    filter: drop-shadow(0 2px 2px rgba(0,0,0,0.8)) !important;
}

/* إيقاف تأثير الوميض القديم (Glow) حول الأزرار للحفاظ على الصلابة */
.hdr-box {
    animation: none !important;
}

/* 4. القائمة المنسدلة لحساب المستخدم والجوال (Dropdown Menus) - متماشية مع الكروت */
.user-menu, .mnav {
    background: linear-gradient(180deg, #1c1c1c 0%, #111111 100%) !important;
    border: 1px solid #222222 !important;
    border-top: 1px solid #444444 !important;
    border-left: 1px solid #333333 !important;
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.9), 0 5px 10px rgba(0,0,0,0.5) !important;
    border-radius: 8px !important;
    padding: 8px !important;
}

.user-menu a, .mnav a {
    border: 1px solid transparent !important;
    background: transparent !important;
    margin-bottom: 4px !important;
    transition: all 0.2s ease !important;
}

.user-menu a:hover, .mnav a:hover {
    background: #0a0a0a !important;
    border-color: var(--o) !important;
    color: #ffffff !important;
    transform: translateX(-4px) !important; /* حركة ناعمة لليسار عند المرور */
    box-shadow: 0 2px 5px rgba(0,0,0,0.5) !important;
}
/* ========================================================
   ضبط المحاذاة البصرية لزر الشعار القديم مع الأزرار ثلاثية الأبعاد
   ======================================================== */
.top-logo {
    margin-bottom: 4px !important; /* توحيد مساحة القاعدة السفلية */
    transform: translateY(-1px) scale(0.96) !important; /* تصغير طفيف + إزاحة للمنتصف بدقة */
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
}

/* ========================================= */
/* تنسيقات أداة MFI MTF (تدفق المال متعدد الفريمات) - مسطحة بالكامل */
/* ========================================= */
#pg-mfimtf .mfi-input-full { width:100%; padding:12px; background:var(--bg); border:1px solid var(--b); border-radius:4px; color:var(--t); text-transform:uppercase; font-family:'Share Tech Mono',monospace; font-size:1.1rem; text-align:center; outline:none; font-weight:bold; margin-bottom:12px; }
#pg-mfimtf .mfi-chart-card { background:var(--s); border:1px solid var(--b); padding:16px; margin-bottom:15px; border-radius:4px; border-top:3px solid var(--o); }
#pg-mfimtf .mfi-chart-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; padding-bottom:10px; border-bottom:1px solid var(--b); }
#pg-mfimtf .mfi-chart-title { font-size:0.85rem; color:var(--o); font-family:'Share Tech Mono',monospace; font-weight:900; letter-spacing:1px; }
#pg-mfimtf .mfi-chart-live { display:flex; align-items:center; gap:6px; font-size:0.7rem; color:var(--t2); font-family:'Share Tech Mono',monospace; font-weight:bold; }
#pg-mfimtf .mfi-live-pulse { width:6px; height:6px; background:var(--o); border-radius:50%; }
#pg-mfimtf .mfi-legend { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; padding-top:14px; margin-top:10px; border-top:1px dashed var(--b); font-size:0.7rem; font-family:'Share Tech Mono',monospace; color:var(--t2); font-weight:bold; }
#pg-mfimtf .mfi-legend-item { display:flex; align-items:center; gap:6px; justify-content:center; }
#pg-mfimtf .mfi-card { background:var(--s); border:1px solid var(--b); padding:16px; margin-bottom:15px; border-radius:4px; }
#pg-mfimtf .mfi-card-title { font-size:0.9rem; font-weight:900; color:var(--o); margin-bottom:12px; padding-bottom:10px; border-bottom:1px solid var(--b); font-family:'Cairo',sans-serif; }
#pg-mfimtf .mfi-confluence-card { background:var(--bg); border:1px solid var(--o); padding:18px; margin-bottom:15px; border-radius:4px; text-align:center; }
#pg-mfimtf .mfi-confluence-title { font-size:0.8rem; color:var(--t2); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:10px; font-weight:bold; }
#pg-mfimtf .mfi-confluence-big { font-size:1.6rem; font-weight:900; font-family:'Cairo',sans-serif; padding:10px 0; letter-spacing:1px; line-height:1.2; }
#pg-mfimtf .mfi-confluence-bar { width:100%; height:8px; background:var(--b); margin-top:10px; border-radius:4px; overflow:hidden; }
#pg-mfimtf .mfi-confluence-fill { height:100%; background:var(--o); }
#pg-mfimtf .mfi-verdict { background:var(--s); border-right:4px solid var(--o); padding:18px; margin-bottom:15px; border-top:1px solid var(--b); border-bottom:1px solid var(--b); }
#pg-mfimtf .mfi-verdict-title { font-size:0.8rem; color:var(--t2); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:10px; font-weight:bold; }
#pg-mfimtf .mfi-verdict-main { font-size:1.3rem; font-weight:900; color:var(--o); margin-bottom:12px; font-family:'Cairo',sans-serif; }
#pg-mfimtf .mfi-verdict-detail { font-size:0.85rem; color:var(--t); line-height:1.8; margin-bottom:12px; font-family:'Cairo',sans-serif; }
#pg-mfimtf .mfi-prob-box { display:flex; justify-content:space-between; align-items:center; background:var(--bg); padding:14px; border:1px solid var(--b); border-radius:4px; }
#pg-mfimtf .mfi-prob-label { font-size:0.7rem; color:var(--t2); font-family:'Share Tech Mono',monospace; font-weight:bold; }
#pg-mfimtf .mfi-prob-val { font-size:1.9rem; font-weight:900; color:var(--o); font-family:'Share Tech Mono',monospace; line-height:1; }
#pg-mfimtf .mfi-table { width:100%; border-collapse:collapse; font-family:'Share Tech Mono',monospace; font-size:0.8rem; }
#pg-mfimtf .mfi-th { background:var(--bg); color:var(--t2); padding:12px 8px; text-align:right; border-bottom:1px solid var(--b); font-weight:900; font-size:0.75rem; letter-spacing:0.5px; }
#pg-mfimtf .mfi-td { padding:12px 8px; border-bottom:1px solid var(--bg); color:var(--t); font-weight:bold; }
#pg-mfimtf .mfi-badge { display:inline-block; padding:4px 8px; font-size:0.7rem; font-weight:900; letter-spacing:0.5px; font-family:'Share Tech Mono',monospace; border-radius:4px; border:1px solid transparent; }
#pg-mfimtf .mfi-badge-o { background:var(--o); color:#000; }
#pg-mfimtf .mfi-badge-w { background:#fff; color:#000; }
#pg-mfimtf .mfi-level-section { margin-bottom:14px; padding-bottom:12px; border-bottom:1px dashed var(--b); }
#pg-mfimtf .mfi-section-label { font-size:0.8rem; color:var(--o); font-family:'Share Tech Mono',monospace; font-weight:900; margin-bottom:8px; }
#pg-mfimtf .mfi-level-row { display:flex; justify-content:space-between; padding:10px 12px; background:var(--bg); margin-bottom:6px; border:1px solid var(--b); border-radius:4px; font-family:'Share Tech Mono',monospace; font-size:0.9rem; font-weight:bold; }
#pg-mfimtf .mfi-disclaimer { margin-top:14px; padding:12px; background:var(--bg); border:1px solid var(--b); border-radius:4px; font-size:0.75rem; color:var(--t3); line-height:1.7; text-align:center; font-family:'Cairo',sans-serif; }
#pg-mfimtf .mfi-guide { background:var(--s); border:1px solid var(--b); padding:16px; margin-top:20px; border-radius:4px; }
#pg-mfimtf .mfi-guide-title { font-size:0.9rem; color:var(--o); font-weight:900; margin-bottom:12px; font-family:'Cairo',sans-serif; border-bottom:1px solid var(--b); padding-bottom:8px; }
#pg-mfimtf .mfi-guide-text { font-size:0.85rem; color:var(--t2); line-height:1.9; font-family:'Cairo',sans-serif; }

/* ========================================= */
/* تنسيقات أداة Confluence Detector - مسطحة بالكامل */
/* ========================================= */
#pg-cf .cf-chart-card { background:var(--s); border:1px solid var(--b); padding:16px; margin-bottom:15px; border-radius:4px; border-top:3px solid var(--o); }
#pg-cf .cf-chart-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; padding-bottom:10px; border-bottom:1px solid var(--b); }
#pg-cf .cf-chart-title { font-size:0.85rem; color:var(--o); font-family:'Share Tech Mono',monospace; font-weight:900; letter-spacing:1px; }
#pg-cf .cf-chart-live { display:flex; align-items:center; gap:6px; font-size:0.7rem; color:var(--t2); font-family:'Share Tech Mono',monospace; font-weight:bold; }
#pg-cf .cf-live-pulse { width:6px; height:6px; background:var(--o); border-radius:50%; animation:cfPulse 2s infinite; }
@keyframes cfPulse { 0%,100% { opacity:1; } 50% { opacity:0.3; } }
#pg-cf .cf-legend { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; padding-top:14px; margin-top:10px; border-top:1px dashed var(--b); font-size:0.7rem; font-family:'Share Tech Mono',monospace; color:var(--t2); font-weight:bold; text-align:center; }
#pg-cf .cf-legend-item { display:flex; align-items:center; gap:6px; justify-content:center; }
#pg-cf .cf-card { background:var(--s); border:1px solid var(--b); padding:18px; margin-bottom:15px; border-radius:4px; }
#pg-cf .cf-card-title { font-size:0.9rem; font-weight:900; color:var(--o); margin-bottom:14px; padding-bottom:10px; border-bottom:1px solid var(--b); font-family:'Cairo',sans-serif; }
#pg-cf .cf-active-card { background:var(--bg); border:2px solid #fff; padding:18px; margin-bottom:15px; border-radius:6px; }
#pg-cf .cf-active-title { font-size:0.8rem; color:var(--t2); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:10px; font-weight:bold; }
#pg-cf .cf-active-big { font-size:1.7rem; font-weight:900; font-family:'Cairo',sans-serif; text-align:center; padding:10px 0; line-height:1.2; }
#pg-cf .cf-active-price { font-size:1.4rem; color:var(--o); font-family:'Share Tech Mono',monospace; text-align:center; margin-bottom:14px; font-weight:900; direction:ltr; }
#pg-cf .cf-stats-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:14px; }
#pg-cf .cf-stat { background:var(--s); padding:12px; text-align:center; border:1px solid var(--b); border-radius:4px; }
#pg-cf .cf-stat-label { font-size:0.65rem; color:var(--t2); font-family:'Share Tech Mono',monospace; margin-bottom:6px; font-weight:bold; }
#pg-cf .cf-stat-val { font-size:1.1rem; font-weight:900; color:var(--o); font-family:'Share Tech Mono',monospace; }
#pg-cf .cf-quality-bar { width:100%; height:8px; background:var(--b); margin-top:8px; border-radius:4px; overflow:hidden; }
#pg-cf .cf-quality-fill { height:100%; background:var(--o); transition:width 0.5s ease; }
#pg-cf .cf-comp-row { display:flex; gap:6px; margin-top:14px; }
#pg-cf .cf-chip { flex:1; padding:10px 4px; background:var(--s); text-align:center; border-top:3px solid var(--b); font-family:'Share Tech Mono',monospace; border-radius:0 0 4px 4px; }
#pg-cf .cf-chip-active { border-top-color:#fff; background:rgba(255,255,255,0.05); }
#pg-cf .cf-chip-label { font-size:0.65rem; color:var(--t3); margin-bottom:4px; }
#pg-cf .cf-chip-name { font-size:0.8rem; font-weight:900; color:#fff; }
#pg-cf .cf-comp-detail { background:var(--bg); padding:14px; margin-bottom:8px; border-radius:4px; border:1px solid var(--b); }
#pg-cf .cf-comp-detail-title { font-size:0.75rem; color:var(--o); font-weight:900; margin-bottom:6px; font-family:'Share Tech Mono',monospace; }
#pg-cf .cf-comp-detail-label { font-size:0.85rem; color:#fff; margin-bottom:6px; font-family:'Cairo',sans-serif; }
#pg-cf .cf-comp-detail-str { font-size:0.7rem; color:var(--t2); font-family:'Share Tech Mono',monospace; font-weight:bold; }
#pg-cf .cf-verdict { background:var(--s); border-right:4px solid var(--o); padding:18px; margin-bottom:15px; border-top:1px solid var(--b); border-bottom:1px solid var(--b); border-radius:4px; }
#pg-cf .cf-verdict-title { font-size:0.8rem; color:var(--t2); font-family:'Share Tech Mono',monospace; letter-spacing:1px; margin-bottom:10px; font-weight:bold; }
#pg-cf .cf-verdict-main { font-size:1.3rem; font-weight:900; color:#fff; margin-bottom:12px; font-family:'Cairo',sans-serif; }
#pg-cf .cf-verdict-detail { font-size:0.85rem; color:var(--t); line-height:1.8; margin-bottom:12px; font-family:'Cairo',sans-serif; }
#pg-cf .cf-prob-box { display:flex; justify-content:space-between; align-items:center; background:var(--bg); padding:14px; border:1px solid var(--b); border-radius:4px; margin-top:12px; }
#pg-cf .cf-prob-label { font-size:0.7rem; color:var(--t2); font-family:'Share Tech Mono',monospace; font-weight:bold; }
#pg-cf .cf-prob-val { font-size:1.9rem; font-weight:900; color:var(--o); font-family:'Share Tech Mono',monospace; line-height:1; }
#pg-cf .cf-table { width:100%; border-collapse:collapse; font-family:'Share Tech Mono',monospace; font-size:0.8rem; }
#pg-cf .cf-th { background:var(--bg); color:var(--t2); padding:12px 8px; text-align:right; border-bottom:1px solid var(--b); font-weight:900; font-size:0.75rem; letter-spacing:0.5px; }
#pg-cf .cf-td { padding:12px 8px; border-bottom:1px solid var(--bg); color:var(--t); font-weight:bold; }
#pg-cf .cf-badge { display:inline-block; padding:4px 8px; font-size:0.7rem; font-weight:900; letter-spacing:0.5px; font-family:'Share Tech Mono',monospace; border-radius:4px; }
#pg-cf .cf-badge-o { background:var(--o); color:#000; }
#pg-cf .cf-badge-w { background:#fff; color:#000; }
#pg-cf .cf-stat-row { display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid var(--bg); font-family:'Share Tech Mono',monospace; font-size:0.85rem; font-weight:bold; }
#pg-cf .cf-level-section { margin-bottom:14px; padding-bottom:12px; border-bottom:1px dashed var(--b); }
#pg-cf .cf-section-label { font-size:0.8rem; color:var(--o); font-family:'Share Tech Mono',monospace; font-weight:900; margin-bottom:8px; }
#pg-cf .cf-level-row { display:flex; justify-content:space-between; padding:10px 12px; background:var(--bg); margin-bottom:6px; border:1px solid var(--b); border-radius:4px; font-family:'Share Tech Mono',monospace; font-size:0.9rem; font-weight:bold; }
#pg-cf .cf-disclaimer { margin-top:14px; padding:12px; background:var(--bg); border:1px solid var(--b); border-radius:4px; font-size:0.75rem; color:var(--t3); line-height:1.7; text-align:center; font-family:'Cairo',sans-serif; }
#pg-cf .cf-guide { background:var(--s); border:1px solid var(--b); padding:16px; margin-top:20px; border-radius:4px; }
#pg-cf .cf-guide-title { font-size:0.9rem; color:var(--o); font-weight:900; margin-bottom:12px; font-family:'Cairo',sans-serif; border-bottom:1px solid var(--b); padding-bottom:8px; }
#pg-cf .cf-guide-text { font-size:0.85rem; color:var(--t2); line-height:1.9; font-family:'Cairo',sans-serif; }

