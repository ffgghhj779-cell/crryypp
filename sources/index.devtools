      .liq-stat-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #060606; font-family: 'Share Tech Mono', monospace; font-size: 12px; }
      .liq-label { color: #666; }
      .liq-val { color: #fff; font-weight: 700; }
      .liq-val-o { color: var(--o); font-weight: 700; }
      
      .liq-level-row { display: grid; grid-template-columns: 50px 1fr 60px 60px; gap: 8px; padding: 10px 8px; border-bottom: 1px solid #060606; font-family: 'Share Tech Mono', monospace; font-size: 11px; align-items: center; }
      .liq-badge { display: inline-block; padding: 3px 8px; font-size: 9px; font-weight: 700; letter-spacing: 0.5px; font-family: 'Share Tech Mono', monospace; border-radius: 2px; text-align: center; }
      .liq-badge-eqh, .liq-badge-bsl { background: var(--o); color: #000; }
      .liq-badge-eql, .liq-badge-ssl { background: #fff; color: #000; }
      
      .liq-strength-bar { width: 100%; height: 4px; background: #1a1a1a; margin-top: 4px; border-radius: 2px; overflow: hidden; }
      .liq-strength-fill { height: 100%; background: var(--o); border-radius: 2px; }
      
      .liq-verdict { background: #0a0a0a; border-right: 4px solid var(--o); padding: 15px; margin-bottom: 15px; border-radius: 4px; }
      .liq-verdict-title { font-size: 11px; color: #666; font-family: 'Share Tech Mono', monospace; letter-spacing: 1px; margin-bottom: 8px; }
      .liq-verdict-main { font-size: 18px; font-weight: 900; color: var(--o); margin-bottom: 10px; font-family: 'Share Tech Mono', monospace; }
      .liq-verdict-detail { font-size: 13px; color: #fff; line-height: 1.7; margin-bottom: 10px; font-family: 'Cairo', sans-serif; }
      
      .liq-prob-box { display: flex; justify-content: space-between; align-items: center; background: #000; padding: 10px; margin-top: 10px; border-radius: 4px; border: 1px solid #111; }
      .liq-prob-label { font-size: 10px; color: #666; font-family: 'Share Tech Mono', monospace; }
      .liq-prob-val { font-size: 24px; font-weight: 900; color: var(--o); font-family: 'Share Tech Mono', monospace; }
      
      .liq-zone-card { background: #000; border: 1px solid #1a1a1a; padding: 12px; margin-bottom: 10px; border-radius: 4px; }
      .liq-zone-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
      .liq-zone-range { font-family: 'Share Tech Mono', monospace; font-size: 13px; color: #fff; font-weight: 700; direction: ltr; text-align: left;}
      .liq-zone-stat { display: flex; justify-content: space-between; font-size: 10px; font-family: 'Share Tech Mono', monospace; color: #666; margin-top: 4px; }
      
      .liq-sweep-card { background: #000; border: 1px solid #1a1a1a; padding: 10px; margin-bottom: 8px; display: grid; grid-template-columns: 60px 1fr 70px; gap: 8px; align-items: center; font-family: 'Share Tech Mono', monospace; font-size: 11px; border-radius: 4px; }
      
      .liq-guide { background: #060606; border: 1px solid #1a1a1a; padding: 15px; margin-top: 20px; border-radius: 4px; border-right: 3px solid var(--o); }
      .liq-guide-title { font-size: 12px; color: var(--o); font-weight: 700; margin-bottom: 10px; letter-spacing: 0.5px; font-family: 'Share Tech Mono', monospace; }
      .liq-guide-text { font-size: 12px; color: #999; line-height: 1.8; font-family: 'Cairo', sans-serif; }

      .liq-chart-card { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 4px; padding: 12px; margin-bottom: 15px; }
      .liq-chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px solid #1a1a1a; }
      .liq-chart-title { font-size: 11px; color: var(--o); font-family: 'Share Tech Mono', monospace; letter-spacing: 1px; font-weight: 700; }
      .liq-chart-live { display: flex; align-items: center; gap: 6px; font-size: 9px; color: #666; font-family: 'Share Tech Mono', monospace; }
      .liq-live-pulse { width: 6px; height: 6px; background: var(--o); border-radius: 50%; animation: liqPulse 2s infinite; }
      .liq-chart-legend { display: flex; justify-content: space-around; padding-top: 10px; margin-top: 8px; border-top: 1px solid #1a1a1a; font-size: 9px; font-family: 'Share Tech Mono', monospace; color: #666; }
      .liq-legend-item { display: flex; align-items: center; gap: 5px; }
    </style>

    <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:8px 12px; margin-bottom:6px; display:flex; justify-content:space-between; align-items:center;">
      <div style="display:flex; align-items:center; gap:8px;">
        <span style="color:var(--o); font-size:0.9rem; font-weight:bold; font-family:'Share Tech Mono', monospace;">LIQ</span>
        <span style="color:#333;">|</span>
        <span style="color:#ccc; font-size:0.55rem; font-family:'Share Tech Mono', monospace; letter-spacing:1px;">LIQUIDITY TRACKER</span>
      </div>
      <span style="color:#888; font-size:0.5rem; font-family:'Share Tech Mono', monospace;">SMC ADVANCED</span>
    </div>

    <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:14px; margin-bottom:10px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:10px;">
        <div>
          <div style="font-size:0.5rem; color:#888; margin-bottom:3px; font-family:'Share Tech Mono', monospace;">SYMBOL</div>
          <input type="text" id="liq-sym" placeholder="BTC" value="BTC" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; text-transform:uppercase; font-family:'Share Tech Mono', monospace; font-size:0.85rem; text-align:center; outline:none;">
        </div>
        <div>
          <div style="font-size:0.5rem; color:#888; margin-bottom:3px; font-family:'Share Tech Mono', monospace;">TIMEFRAME</div>
          <select id="liq-tf" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; font-family:'Share Tech Mono', monospace; outline:none;">
            <option value="15m">15M</option>
            <option value="1h">1H</option>
            <option value="4h" selected>4H</option>
            <option value="1d">1D</option>
          </select>
        </div>
      </div>
      <button onclick="runLiquidityTracker()" id="liq-btn" style="width:100%; padding:12px; background:var(--o); color:#000; font-weight:900; border:none; border-radius:4px; cursor:pointer; font-size:1rem; letter-spacing:2px; font-family:'Share Tech Mono', monospace;">SCAN LIQUIDITY ZONES</button>
      <div style="text-align:center; margin-top:6px; font-size:0.5rem; color:#555; font-family:'Cairo', sans-serif;">اكتشاف قمم/قيعان متساوية، مناطق صيد السيولة، والكسر الوهمي (Sweeps)</div>
    </div>

    <div id="liq-loading" style="display:none; text-align:center; padding:30px; color:var(--o); font-size:0.85rem; font-family:'Share Tech Mono', monospace; font-weight:bold;">SCANNING LIQUIDITY...</div>

