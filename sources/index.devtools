    text-align: center;
}
#pg-flash .fl-tp-prob {
    font-size: 10px;
    color: var(--t3);
    font-family: 'Share Tech Mono', monospace;
    text-align: center;
}
#pg-flash .fl-sl-cond {
    background: var(--bg);
    border: 1px solid var(--b);
