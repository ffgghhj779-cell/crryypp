</div>

<script>
(function() {
    // ==========================================
    // 1. حقن المجلد في الشريط العلوي (الرادار)
    // ==========================================
    document.addEventListener('DOMContentLoaded', () => {
        let targetBtn = document.querySelector('.tools-scroll button[title="مقياس الاستثمار المعاكس"]');
        if (!targetBtn) {
            const toolsScroll = document.querySelector('.tools-scroll');
            if (toolsScroll) targetBtn = toolsScroll.lastElementChild;
        }

        if (targetBtn) {
            targetBtn.id = 'radar-header-btn';
            targetBtn.title = 'أرشيف التحليلات';
            targetBtn.setAttribute('onclick', 'toggleRadarMenu(event)');
            
            targetBtn.innerHTML = `
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h5l2 3h9a2 2 0 0 1 2 2v2H2V6a2 2 0 0 1 2-2z" stroke="var(--o)" stroke-width="1.5" fill="none"></path>
                    <g class="radar-paper-slide">
                        <rect x="7" y="1" width="10" height="12" rx="1" fill="#ffffff" stroke="none"></rect>
                        <line x1="9" y1="4" x2="15" y2="4" stroke="var(--o)" stroke-width="1.5"></line>
                        <line x1="9" y1="7" x2="13" y2="7" stroke="var(--o)" stroke-width="1.5"></line>
                        <line x1="9" y1="10" x2="15" y2="10" stroke="var(--o)" stroke-width="1.5"></line>
                    </g>
                    <g class="radar-folder-front">
                        <path d="M2 10h20l-1.5 9a2 2 0 0 1-2 2H5.5a2 2 0 0 1-2-2z" fill="#0d0d0d" stroke="var(--o)" stroke-width="1.5"></path>
                        <line x1="2" y1="10" x2="22" y2="10" stroke="var(--o)" stroke-width="1.5"></line>
                    </g>
                </svg>
            `;
        }
    });

    // ==========================================
    // 2. المراقب الجذري (متى يظهر الزر؟)
    // ==========================================
    setInterval(() => {
        const activePg = document.querySelector('.pg.active');
        const floatBtn = document.getElementById('radar-floating-btn');
        if (!activePg || !floatBtn) return;

        const pageId = activePg.id.replace('pg-', '');
        const nonTools = ['home', 'sentiment', 'mining', 'dclose', 'risk', 'live', 'ecoModal', 'briefModal', 'analytics', 'calc'];
        
        const hasInput = activePg.querySelector('input');
        
        const dashboardEl = activePg.querySelector('[id$="-dashboard"], [id$="_dashboard"], [id$="-results"], [id$="-result"], [id$="res"], #cR, #yR, #lrR, #cbR, #lR, #sq9-grid-wrap');
        let hasResults = false;
        if (dashboardEl && dashboardEl.style.display !== 'none' && dashboardEl.innerHTML.trim() !== '') {
            hasResults = true;
        }

        if (!nonTools.includes(pageId) && hasInput && hasResults) {
            if (floatBtn.style.display !== 'flex') {
                floatBtn.style.display = 'flex';
                if(typeof resetRadarShrink === 'function') resetRadarShrink();
            }
        } else {
            if (floatBtn.style.display !== 'none') floatBtn.style.display = 'none';
        }
    }, 500);

    // ==========================================
    // 2.5 إدارة الانكماش المرن للزر العائم
    // ==========================================
    let radarShrinkTimer;
    window.resetRadarShrink = function() {
        const floatBtn = document.getElementById('radar-floating-btn');
        if (!floatBtn) return;
        
        floatBtn.classList.remove('radar-shrunk');
        clearTimeout(radarShrinkTimer);
        
        radarShrinkTimer = setTimeout(() => {
            floatBtn.classList.add('radar-shrunk');
        }, 3000);
    };

    document.addEventListener('DOMContentLoaded', () => {
        const floatBtnEl = document.getElementById('radar-floating-btn');
        if(floatBtnEl) {
            // الإبقاء على mouseenter للحواسيب فقط، مع إزالة touchstart لمنع التعارض
            floatBtnEl.addEventListener('mouseenter', resetRadarShrink);
        }
    });

    window.addEventListener('scroll', () => {
        const floatBtn = document.getElementById('radar-floating-btn');
        if (floatBtn && floatBtn.style.display !== 'none' && !floatBtn.classList.contains('radar-shrunk')) {
            floatBtn.classList.add('radar-shrunk');
            clearTimeout(radarShrinkTimer);
        }
    }, {passive: true});

    // ==========================================
    // 3. التقاط اللقطة (تجميد الـ HTML الكامل)
    // ==========================================
    window.radarSaveCurrentAnalysis = function(e) {
        const btn = document.getElementById('radar-floating-btn');
        
        // إزالة البوابة المنطقية المانعة: 
        // سيتم التمديد بصرياً، ولكن دون إيقاف أمر الحفظ (No Return)
        if (btn && btn.classList.contains('radar-shrunk')) {
            if (typeof resetRadarShrink === 'function') resetRadarShrink();
        }

        const activePg = document.querySelector('.pg.active');
        if(!activePg) return;

        const pageId = activePg.id.replace('pg-', '');
        
        activePg.querySelectorAll('input').forEach(inp => {
            if(inp.type === 'checkbox' || inp.type === 'radio') {
                if(inp.checked) inp.setAttribute('checked', 'checked'); else inp.removeAttribute('checked');
            } else {
                inp.setAttribute('value', inp.value);
            }
        });
        activePg.querySelectorAll('select').forEach(sel => {
            Array.from(sel.options).forEach(opt => {
                if(opt.selected) opt.setAttribute('selected', 'selected'); else opt.removeAttribute('selected');
            });
        });

        const existingBanner = activePg.querySelector('.radar-archive-banner');
        if (existingBanner) existingBanner.remove();

        const snapshotHTML = activePg.innerHTML;

        let toolName = 'أداة تحليل';
        const titleH1 = activePg.querySelector('.th h1');
        const titleSpan = activePg.querySelector('span[style*="var(--o)"]');
        if (titleH1) toolName = titleH1.innerText.trim();
        else if (titleSpan) toolName = titleSpan.innerText.trim();
        if(toolName.includes('|')) toolName = toolName.split('|')[0].trim();
        if(toolName.includes('\n')) toolName = toolName.split('\n')[0].trim();

        const inputEl = activePg.querySelector('input[type="text"]') || activePg.querySelector('input[id*="sym"]') || activePg.querySelector('input');
        const symbol = inputEl ? inputEl.value.trim().toUpperCase() : '';

        const selectEl = activePg.querySelector('select');
        const tfText = selectEl && selectEl.options.length > 0 ? selectEl.options[selectEl.selectedIndex].text : '';

        const now = new Date();
        const timeStr = `${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')} | ${now.getDate()} ${now.toLocaleString('en-US',{month:'short'})}`;

        const record = {
            id: Date.now().toString(),
            pageId,
            toolName,
            symbol,
            tfText,
            timeStr,
            snapshotHTML
        };

        let history = JSON.parse(localStorage.getItem('360_radar_snapshots') || '[]');
        history.unshift(record);
        
        while (history.length > 15) history.pop();
        
        let saved = false;
        while(!saved && history.length > 0) {
            try {
                localStorage.setItem('360_radar_snapshots', JSON.stringify(history));
                saved = true;
            } catch(error) {
                history.pop();
            }
        }

        if(!saved) { alert("فشل الحفظ: ذاكرة المتصفح ممتلئة."); return; }

        const span = document.getElementById('radar-save-text');
        span.innerText = 'تم الحفظ 📂';
        btn.classList.add('saved');
        setTimeout(() => { span.innerText = 'حفظ التحليل'; btn.classList.remove('saved'); }, 1500);

        if (document.getElementById('radar-dropdown').style.display === 'flex') renderRadarMenu();
    };

    // ==========================================
    // 4. عرض الأرشيف
    // ==========================================
    window.renderRadarMenu = function() {
        const list = document.getElementById('radar-list');
        let history = JSON.parse(localStorage.getItem('360_radar_snapshots') || '[]');
        
        if (history.length === 0) {
            list.innerHTML = `
                <div class="radar-empty">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:10px; opacity:0.5; color:var(--o);">
                        <path d="M4 4h5l2 3h9a2 2 0 0 1 2 2v2H2V6a2 2 0 0 1 2-2z" stroke="var(--o)" fill="transparent"></path>
                        <path d="M2 10h20l-1.5 9a2 2 0 0 1-2 2H5.5a2 2 0 0 1-2-2z" fill="transparent" stroke="var(--o)"></path>
                    </svg>
                    <br>الأرشيف فارغ حالياً.<br>
                    <span style="font-size:0.75rem; color:#888;">استخدم زر "حفظ التحليل" العائم داخل أي أداة لتجميد النتائج والعودة إليها مستقبلاً.</span>
                </div>`;
            return;
        }

        list.innerHTML = history.map(item => `
            <div class="radar-item" onclick="radarRestoreSnapshot('${item.id}')">
                <div class="radar-item-info">
                    <div class="radar-item-tool">${item.toolName}</div>
                    <div class="radar-item-meta">${item.symbol} ${item.tfText ? `<span style="background:var(--o); color:#000; padding:2px 4px; border-radius:4px; font-size:0.6rem; margin-right:4px;">${item.tfText}</span>` : ''}</div>
                    <div class="radar-item-time">تم الحفظ: ${item.timeStr}</div>
                </div>
                <button class="radar-del-btn" onclick="radarDeleteSnapshot(event, '${item.id}')" title="حذف التحليل">
                    <svg viewBox="0 0 24 24">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                </button>
            </div>
        `).join('');
    };

    // ==========================================
    // 5. الاسترجاع (لصق الكود المجمد)
    // ==========================================
    window.radarRestoreSnapshot = function(id) {
        let history = JSON.parse(localStorage.getItem('360_radar_snapshots') || '[]');
        const record = history.find(r => r.id === id);
        if (!record) return;

        closeRadarMenu();
        if(window.nav) window.nav(record.pageId);

        setTimeout(() => {
            const activePg = document.getElementById('pg-' + record.pageId);
            if (!activePg) return;

            activePg.innerHTML = record.snapshotHTML;

            const loaders = activePg.querySelectorAll('[id*="loading"]');
            loaders.forEach(l => l.style.display = 'none');

            const tpEl = activePg.querySelector('.tp') || activePg;
            const banner = document.createElement('div');
            banner.className = 'radar-archive-banner';
            banner.innerHTML = `
                <div style="display:flex; align-items:center; gap:8px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h5l2 3h9a2 2 0 0 1 2 2v2H2V6a2 2 0 0 1 2-2z"></path>
                        <path d="M2 10h20l-1.5 9a2 2 0 0 1-2 2H5.5a2 2 0 0 1-2-2z"></path>
                    </svg>
                    <span>أنت تشاهد تحليلاً محفوظاً بتاريخ: ${record.timeStr}</span>
                </div>
                <button onclick="this.parentElement.remove()" style="background:var(--o); color:#000; border:none; padding:4px 10px; border-radius:4px; font-weight:bold; cursor:pointer; font-family:'Cairo', sans-serif; font-size:0.75rem;">إخفاء</button>
            `;
            tpEl.insertBefore(banner, tpEl.firstChild);

            if (typeof initWorkspace === 'function') initWorkspace();

            window.scrollTo({top: 0, behavior: 'smooth'});

        }, 100); 
    };

    // ==========================================
    // 6. أحداث الواجهة
    // ==========================================
    window.toggleRadarMenu = function(e) {
        if(e) e.stopPropagation();
        const favMenu = document.getElementById('favMenu');
        if(favMenu && favMenu.classList.contains('open')) favMenu.classList.remove('open');
        const menu = document.getElementById('radar-dropdown');
        if (menu.style.display === 'flex') menu.style.display = 'none';
        else { menu.style.display = 'flex'; renderRadarMenu(); }
    };

    window.closeRadarMenu = function(e) {
        if(e) e.stopPropagation();
        const menu = document.getElementById('radar-dropdown');
        if(menu) menu.style.display = 'none';
    };

    window.radarDeleteSnapshot = function(e, id) {
        e.stopPropagation();
        let history = JSON.parse(localStorage.getItem('360_radar_snapshots') || '[]');
        history = history.filter(r => r.id !== id);
        localStorage.setItem('360_radar_snapshots', JSON.stringify(history));
        renderRadarMenu();
    };

    window.radarClearAll = function(e) {
        if(e) e.stopPropagation();
        if (confirm('هل أنت متأكد من حذف الأرشيف بالكامل؟ لا يمكن التراجع عن هذا الإجراء.')) {
            localStorage.removeItem('360_radar_snapshots');
            renderRadarMenu();
        }
    };

    document.addEventListener('click', (e) => {
        const menu = document.getElementById('radar-dropdown');
        const toolsScroll = document.querySelector('.tools-scroll');
        if (menu && menu.style.display === 'flex') {
            if (!menu.contains(e.target) && (!toolsScroll || !toolsScroll.contains(e.target))) {
                closeRadarMenu();
            }
        }
    });

})();
</script>
<script>
/* ===================================================================
   محرك حساب نسبة رأس المال (Drawdown Recovery + Compound Growth)
   Pure Math | No API | 360° Terminal
   القاعدة اللونية الصارمة: أبيض = صعود/ربح/إيجابي | برتقالي = هبوط/خسارة/سلبي
   =================================================================== */
(function(){
  'use strict';

  window.capSwitchTab = function(name){
    const isRecovery = (name === 'recovery');
    document.getElementById('cap-pane-recovery').style.display  = isRecovery ? 'block' : 'none';
    document.getElementById('cap-pane-compound').style.display = isRecovery ? 'none'  : 'block';

    const tabR = document.getElementById('cap-tab-recovery');
    const tabC = document.getElementById('cap-tab-compound');
    
    if (isRecovery) {
      tabR.style.borderColor = 'var(--o)'; tabR.style.color = 'var(--o)'; tabR.style.background = '#0a0a0a';
      tabC.style.borderColor = '#1a1a1a';  tabC.style.color = '#888';     tabC.style.background = '#060606';
      capCalcRecovery();
    } else {
      tabC.style.borderColor = '#ffffff';  tabC.style.color = '#ffffff';  tabC.style.background = '#0a0a0a';
      tabR.style.borderColor = '#1a1a1a';  tabR.style.color = '#888';     tabR.style.background = '#060606';
      capCalcCompound();
    }
  };

  // ===================== 1. محرك النسبة المطلوبة للعودة =====================
  function ddRequired(dropPct){
    const d = dropPct / 100;
    if (d >= 0.999) return Infinity;
    if (d <= 0) return 0;
    return (d / (1 - d)) * 100;
  }

  function ddVerdict(drop){
    if (drop <= 0) return 'لا يوجد تراجع. حافظ على رأس مالك ولا تتساهل في أوامر الوقف لتبقى في هذه المنطقة الآمنة.';
    if (drop < 10) return 'تراجع طبيعي وصحي يمكن تعويضه. حافظ على خطة تداولك وانضباطك العاطفي.';
    if (drop < 25) return 'تنبيه: لقد دخلت منطقة تحتاج فيها إلى جهد رياضي أكبر للتعافي. لا تكابر وراجع خطة المخاطرة.';
    if (drop < 50) return 'خطر شديد! الفجوة بين الخسارة والمطلوب للتعافي تتسع بقوة. الخسارة رياضياً أسهل بكثير من الربح.';
    if (drop < 75) return 'وضع كارثي. تحتاج لمضاعفة المتبقي من محفظتك للعودة للصفر فقط. تجنب الرافعة المالية للتعويض.';
    return 'انهيار حسابي هيكلي. التعافي يتطلب سنوات من التداول المثالي. تقبل الخسارة كدرس في الانضباط.';
  }

  function buildDdTable(){
    const rows = [5, 10, 20, 30, 40, 50, 75, 90];
    const tb = document.getElementById('cap-dd-table');
    if (!tb) return;
    tb.innerHTML = rows.map(d => {
      const r = ddRequired(d);
      const gap = r - d;
      return `
        <tr style="border-bottom:1px solid #111;">
          <td style="padding:6px 4px; text-align:center; color:var(--o); direction:ltr; font-weight:bold;">-${d}%</td>
          <td style="padding:6px 4px; text-align:center; color:#ffffff; direction:ltr; font-weight:bold;">+${r.toFixed(2)}%</td>
          <td style="padding:6px 4px; text-align:center; color:var(--o); direction:ltr; opacity:0.8;">-${gap.toFixed(2)}%</td>
        </tr>
      `;
    }).join('');
  }

  window.capCalcRecovery = function(){
    let v = parseFloat(document.getElementById('cap-dd-input').value);
    if (isNaN(v)) v = 0; if (v < 0) v = 0; if (v > 99.9) v = 99.9;

    const slider = document.getElementById('cap-dd-slider');
    if (Math.abs(parseFloat(slider.value) - v) > 0.5) slider.value = Math.min(95, Math.round(v));

    const r = ddRequired(v);
    const mult = isFinite(r) ? (1 + r/100) : Infinity;

    document.getElementById('cap-dd-result').textContent = isFinite(r) ? ('+' + r.toFixed(2) + '%') : '∞';
    document.getElementById('cap-dd-multiplier').textContent = isFinite(mult) ? ('×' + mult.toFixed(2) + ' من القاع') : 'تعافٍ مستحيل رياضياً';

    const max = Math.max(v, isFinite(r) ? r : 100);
    const dropW = max > 0 ? (v / max) * 50 : 0;
    const recW  = max > 0 ? ((isFinite(r) ? r : 100) / max) * 50 : 0;
    
    document.getElementById('cap-bar-drop').style.width = dropW + '%';
    document.getElementById('cap-bar-recovery').style.width = recW + '%';
    document.getElementById('cap-bar-drop-lbl').textContent = '-' + v.toFixed(1) + '%';
    document.getElementById('cap-bar-recovery-lbl').textContent = isFinite(r) ? ('+' + r.toFixed(1) + '%') : '+∞';

    document.getElementById('cap-dd-verdict').textContent = ddVerdict(v);
  };

  window.capSliderSync = function(){
    document.getElementById('cap-dd-input').value = document.getElementById('cap-dd-slider').value;
    capCalcRecovery();
  };

  // ===================== 2. محرك النمو المركب =====================
  function fmtMoney(n){
    if (!isFinite(n)) return '∞';
    const sign = n < 0 ? '-' : '';
    const abs = Math.abs(n);
    if (abs >= 1e9) return sign + '$' + (abs/1e9).toFixed(2) + 'B';
    if (abs >= 1e6) return sign + '$' + (abs/1e6).toFixed(2) + 'M';
    return sign + '$' + abs.toLocaleString('en-US', {maximumFractionDigits: 2, minimumFractionDigits: 2});
  }

  function buildCgChart(series, capital, isLoss){
    const svg = document.getElementById('cap-cg-chart');
    if (!svg || !series.length) return;
    const W = 400, H = 180, padL = 8, padR = 8, padT = 10, padB = 10;
    const minV = Math.min(...series), maxV = Math.max(...series);
    const range = maxV - minV || 1;

    const xs = series.map((_, i) => padL + (i / (series.length - 1 || 1)) * (W - padL - padR));
    const ys = series.map(v => H - padB - ((v - minV) / range) * (H - padT - padB));

    let path = `M ${xs[0].toFixed(2)},${ys[0].toFixed(2)}`;
    for (let i = 1; i < xs.length; i++) path += ` L ${xs[i].toFixed(2)},${ys[i].toFixed(2)}`;

    const baseY = H - padB - ((capital - minV) / range) * (H - padT - padB);
    const areaPath = path + ` L ${xs[xs.length-1].toFixed(2)},${(H - padB).toFixed(2)} L ${xs[0].toFixed(2)},${(H - padB).toFixed(2)} Z`;

    const color = isLoss ? 'var(--o)' : '#ffffff';
    const gradId = isLoss ? 'capCgGradOrange' : 'capCgGradWhite';

    svg.innerHTML = `
      <defs>
        <linearGradient id="${gradId}" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="${color}" stop-opacity="0.35"/>
          <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <line x1="${padL}" y1="${baseY.toFixed(2)}" x2="${W-padR}" y2="${baseY.toFixed(2)}" stroke="#333" stroke-width="1" stroke-dasharray="2 3"/>
      <path d="${areaPath}" fill="url(#${gradId})" stroke="none"/>
      <path d="${path}" fill="none" stroke="${color}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="${xs[xs.length-1].toFixed(2)}" cy="${ys[ys.length-1].toFixed(2)}" r="3" fill="${color}" stroke="#000" stroke-width="1.5"/>
    `;
  }

  function buildCgTable(series, capital){
    const tb = document.getElementById('cap-cg-table');
    if (!tb) return;
    tb.innerHTML = series.map((v, i) => {
      const profit = v - capital;
      const isLoss = profit < 0;
      const pColor = isLoss ? 'var(--o)' : '#ffffff';
      const pSign = isLoss ? '' : '+';
      return `
        <tr style="border-bottom:1px solid #111;">
          <td style="padding:6px 4px; text-align:center; color:#888; direction:ltr;">M${i}</td>
          <td style="padding:6px 4px; text-align:center; color:#ffffff; direction:ltr;">${fmtMoney(v)}</td>
          <td style="padding:6px 4px; text-align:center; color:${pColor}; font-weight:bold; direction:ltr;">${pSign}${fmtMoney(profit)}</td>
        </tr>
      `;
    }).join('');
  }

  window.capCalcCompound = function(){
    let cap    = parseFloat(document.getElementById('cap-cg-capital').value);
    let months = parseInt(document.getElementById('cap-cg-months').value, 10);
    let rate   = parseFloat(document.getElementById('cap-cg-rate').value);

    if (isNaN(cap) || cap <= 0) cap = 1000;
    if (isNaN(months) || months < 1) months = 12;
    if (months > 120) months = 120;
    if (isNaN(rate)) rate = 0;
    if (rate > 100) rate = 100;
    if (rate < -99) rate = -99;

    const sliderEl = document.getElementById('cap-cg-rate-slider');
    if (Math.abs(parseFloat(sliderEl.value) - rate) > 0.25) {
      sliderEl.value = rate;
    }

    const r = rate / 100;
    const series = [];
    for (let m = 0; m <= months; m++) {
      series.push(cap * Math.pow(1 + r, m));
    }

    const finalV = series[series.length - 1];
    const totalRetPct = ((finalV / cap) - 1) * 100;
    const cagrPct = (Math.pow(finalV / cap, 12 / months) - 1) * 100;
    const isLoss = totalRetPct < 0;

    const colorStr = isLoss ? 'var(--o)' : '#ffffff';

    document.getElementById('cap-cg-final').textContent = fmtMoney(finalV);
    document.getElementById('cap-cg-final').style.color = colorStr;

    document.getElementById('cap-cg-totalret').textContent = (isLoss ? '' : '+') + totalRetPct.toFixed(2) + '%';
    document.getElementById('cap-cg-totalret').style.color = colorStr;

    document.getElementById('cap-cg-cagr').textContent = (cagrPct >= 0 ? '+' : '') + cagrPct.toFixed(2) + '%';
    document.getElementById('cap-cg-cagr').style.color = cagrPct < 0 ? 'var(--o)' : '#ffffff';

    document.getElementById('cap-cg-final-box').style.borderTopColor = colorStr;
    document.getElementById('cap-cg-ret-box').style.borderTopColor = colorStr;
    document.getElementById('cap-cg-verdict-box').style.borderRightColor = colorStr;
    document.getElementById('cap-cg-verdict-title').style.color = colorStr;
    
    document.getElementById('cap-cg-rate').style.color = colorStr;
    document.getElementById('cap-cg-rate').style.borderColor = colorStr;
    document.getElementById('cap-cg-rate-slider').style.accentColor = colorStr;
    
    document.getElementById('cap-cg-col-profit').style.color = colorStr;
    document.getElementById('cap-cg-chart-title').style.color = colorStr;

    document.getElementById('cap-cg-x-start').textContent = 'M0';
    document.getElementById('cap-cg-x-end').textContent   = 'M' + months;

    buildCgChart(series, cap, isLoss);
    buildCgTable(series, cap);
    
    let verdict = "";
    if (rate < 0) verdict = "تحذير: معدل التراكم السلبي يؤدي لتآكل مدمر وسريع في المحفظة. راجع خطتك فوراً.";
    else if (rate === 0) verdict = "لا يوجد نمو. باحتفاظك برأس المال فأنت تخسر قيمته الشرائية ضد التضخم بمرور الوقت.";
    else if (rate <= 4) verdict = "نمو هادئ وواقعي. قوة التراكم تصنع المعجزات بمرور الزمن دون مخاطرة تذكر أو توتر نفسي.";
    else if (rate <= 10) verdict = "نسبة طموحة جداً وتتطلب انضباطاً حاداً في اختيار الصفقات وتفادي الخسائر الكبيرة.";
    else verdict = "معدل مضاربي خطير! الاستمرار عليه طويلاً شبه مستحيل رياضياً وسيعرض حسابك لخطر التصفية.";
    
    document.getElementById('cap-cg-verdict').textContent = verdict;
  };

  window.capCgSliderSync = function(){
    document.getElementById('cap-cg-rate').value = document.getElementById('cap-cg-rate-slider').value;
    capCalcCompound();
  };

  let capInitDone = false;
  window.capInitOnce = function(){
    if (capInitDone) return;
    capInitDone = true;
    buildDdTable();
    capCalcRecovery();
    capCalcCompound();
  };

  document.addEventListener('DOMContentLoaded', function(){
    const modal = document.getElementById('capitalModal');
    if (!modal) return;
    setTimeout(window.capInitOnce, 100);
    new MutationObserver(mutations => {
      mutations.forEach(m => {
        if (m.attributeName === 'style' && modal.style.display === 'flex') window.capInitOnce();
      });
    }).observe(modal, { attributes: true, attributeFilter: ['style'] });
  });

})();
</script>

