/* --- FIBONACCI GUIDE CSS --- */
#pg-fib .fb-cat-btn{padding:10px 14px;background:#050505;color:#666;border:1px solid #111;font-family:'Share Tech Mono',monospace;font-size:9px;font-weight:700;white-space:nowrap;cursor:pointer;letter-spacing:1px}
#pg-fib .fb-cat-active{background:#1a1a1a;color:var(--o);border-color:var(--o)}
#pg-fib .fb-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
#pg-fib .fb-card{background:#050505;border:1px solid #111;padding:12px;cursor:pointer}
#pg-fib .fb-card-svg{width:100%;height:70px;margin-bottom:8px}
#pg-fib .fb-card-name{font-family:'Share Tech Mono',monospace;font-size:8px;color:#fff;font-weight:900;margin-bottom:2px}
#pg-fib .fb-card-ar{font-family:'Cairo',sans-serif;font-size:12px;color:var(--o);font-weight:700;margin-bottom:4px}
#pg-fib .fb-card-type{font-family:'Share Tech Mono',monospace;font-size:7px;color:#888;letter-spacing:1px;margin-bottom:5px}
#pg-fib .fb-card-rel-row{display:flex;justify-content:space-between}
#pg-fib .fb-card-rel-l{font-family:'Share Tech Mono',monospace;font-size:9px;color:#999}
#pg-fib .fb-card-rel-v{font-family:'Share Tech Mono',monospace;font-size:12px;font-weight:900}
#pg-fib .fb-card-bar{width:100%;height:3px;background:#111;margin-top:3px}
#pg-fib .fb-card-fill{height:100%}
#pg-fib .fb-back{display:inline-block;background:none;border:1px solid #1a1a1a;color:var(--o);padding:8px 16px;font-family:'Share Tech Mono',monospace;font-size:11px;cursor:pointer;margin-bottom:14px;font-weight:700}
#pg-fib .fb-detail{background:#050505;border:1px solid #111;padding:20px}
#pg-fib .fb-detail-svg{width:100%;height:160px;margin-bottom:16px}
#pg-fib .fb-detail-name{font-family:'Share Tech Mono',monospace;font-size:13px;color:#fff;font-weight:900}
#pg-fib .fb-detail-ar{font-family:'Cairo',sans-serif;font-size:20px;color:var(--o);font-weight:900;margin-top:4px;margin-bottom:6px}
#pg-fib .fb-detail-badge{display:inline-block;background:#1a1a1a;border:1px solid #333;color:#fff;padding:4px 12px;font-family:'Share Tech Mono',monospace;font-size:9px;font-weight:700;letter-spacing:1px;margin-bottom:14px}
#pg-fib .fb-detail-rel-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;margin-top:10px}
#pg-fib .fb-detail-rel-l{font-family:'Share Tech Mono',monospace;font-size:12px;color:#bbb}
#pg-fib .fb-detail-rel-v{font-family:'Share Tech Mono',monospace;font-size:22px;font-weight:900}
#pg-fib .fb-detail-bar{width:100%;height:6px;background:#111;margin-bottom:18px}
#pg-fib .fb-detail-fill{height:100%}
#pg-fib .fb-detail-desc-wrap{border-right:3px solid var(--o);padding-right:14px;margin-bottom:18px}
#pg-fib .fb-detail-desc-label{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--o);letter-spacing:2px;margin-bottom:10px;font-weight:700}
#pg-fib .fb-detail-desc{font-family:'Cairo',sans-serif;font-size:14px;color:#ddd;line-height:2.2}
#pg-fib .fb-detail-fib-wrap{background:#080808;border:1px solid #111;border-right:3px solid #fff;padding:16px;margin-bottom:18px}
#pg-fib .fb-detail-fib-label{font-family:'Share Tech Mono',monospace;font-size:11px;color:#fff;letter-spacing:2px;margin-bottom:12px;font-weight:700}
#pg-fib .fb-fib-row{display:flex;gap:8px;margin-bottom:8px}
#pg-fib .fb-fib-arrow{font-size:6px;color:var(--o);margin-top:5px}
