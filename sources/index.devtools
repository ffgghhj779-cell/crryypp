        <div>
          <div style="font-size:0.5rem; color:#888; margin-bottom:3px; font-family:'Share Tech Mono', monospace;">SYMBOL</div>
          <input type="text" id="obk-sym" placeholder="BTC" value="BTC" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; text-transform:uppercase; font-family:'Share Tech Mono', monospace; font-size:0.85rem; text-align:center; outline:none;">
