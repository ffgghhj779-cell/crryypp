#pg-ts5 .ts5-gt { font-size:12px; color:var(--o); font-weight:700; margin-bottom:10px; font-family:'Share Tech Mono',monospace; letter-spacing:0.5px; }
#pg-ts5 .ts5-gx { font-size:12px; color:var(--t2); line-height:1.8; font-family:'Cairo',sans-serif; text-align:justify; }

