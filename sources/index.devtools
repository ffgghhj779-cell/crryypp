            <option value="4h">4 ساعات (4H)</option>
            <option value="1d" selected>يومي (1D)</option>
            <option value="1w">أسبوعي (1W)</option>
          </select>
        </div>
      </div>
      <button onclick="runCycleConfluence()" id="cc-btn" style="width:100%; padding:12px; background:var(--o); color:#000; font-weight:700; border:none; border-radius:6px; cursor:pointer; font-size:0.95rem; font-family:'Cairo',sans-serif;">تحليل توافق الدورات</button>
    </div>

    <div id="cc-dashboard" style="display:none; animation:fadeIn 0.5s ease;">
      <div style="display:flex; justify-content:center; align-items:center; gap:20px; padding:10px 0; margin-bottom:16px; border-top:1px solid #111; border-bottom:1px solid #111;">
        <div style="text-align:center;">
          <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#444; margin-bottom:2px;">PAIR</div>
          <div id="cc-pair" style="font-family:'Share Tech Mono',monospace; font-size:0.85rem; color:var(--o); font-weight:bold;">--</div>
        </div>
        <div style="width:1px; height:24px; background:#222;"></div>
        <div style="text-align:center;">
          <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#444; margin-bottom:2px;">SWING</div>
          <div id="cc-swing" style="font-family:'Share Tech Mono',monospace; font-size:0.85rem; color:#fff; font-weight:bold;">--</div>
        </div>
        <div style="width:1px; height:24px; background:#222;"></div>
        <div style="text-align:center;">
          <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#444; margin-bottom:2px;">SYSTEMS</div>
          <div style="font-family:'Share Tech Mono',monospace; font-size:0.85rem; color:#888;">3</div>
        </div>
      </div>

      <div style="display:flex; justify-content:center; gap:16px; margin-bottom:20px;">
        <div style="display:flex; align-items:center; gap:5px;"><div style="width:8px; height:8px; border-radius:50%; background:var(--o);"></div><span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#888;">Fibonacci</span></div>
        <div style="display:flex; align-items:center; gap:5px;"><div style="width:8px; height:8px; border-radius:50%; background:#ffffff;"></div><span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#888;">Gann</span></div>
        <div style="display:flex; align-items:center; gap:5px;"><div style="width:8px; height:8px; border-radius:50%; background:#888888;"></div><span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#888;">Statistical</span></div>
      </div>

      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:10px; padding:16px; margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
          <span style="font-size:0.8rem; color:var(--o); font-weight:700;">المحور الزمني المتعدد</span>
          <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#333; letter-spacing:1px;">MULTI-TIMELINE</span>
        </div>
        <div id="cc-timelines"></div>
      </div>

      <div id="cc-confluences-wrap" style="margin-bottom:16px;"></div>

      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:10px; padding:14px; margin-bottom:14px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
          <span style="font-size:0.8rem; color:var(--o); font-weight:700;">جميع المناطق الزمنية</span>
          <span style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:#333; letter-spacing:1px;">ALL ZONES</span>
        </div>
        <div style="overflow-x:auto;">
          <table style="width:100%; border-collapse:collapse; text-align:center;">
            <thead>
              <tr style="border-bottom:1px solid #222;">
                <th style="padding:8px 4px; font-size:0.65rem; color:#888;">النظام</th>
                <th style="padding:8px 4px; font-size:0.65rem; color:#888;">القيمة</th>
                <th style="padding:8px 4px; font-size:0.65rem; color:#888;">التاريخ</th>
                <th style="padding:8px 4px; font-size:0.65rem; color:#888;">الحالة</th>
              </tr>
            </thead>
            <tbody id="cc-table-body"></tbody>
          </table>
        </div>
      </div>

      <div style="background:#080808; border:1px solid #1a1a1a; border-right:3px solid var(--o); border-radius:10px; padding:16px; margin-bottom:14px;">
        <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:var(--o); margin-bottom:8px; letter-spacing:1px;">CONCLUSION</div>
        <div id="cc-conclusion" style="font-size:0.82rem; line-height:1.7; color:#bbb;">--</div>
      </div>

      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:10px; padding:14px; border-right:3px solid var(--o);">
        <div style="font-size:0.68rem; color:#777; line-height:1.7; text-align:right;">
          <span style="color:var(--o); font-weight:bold;">دليل القراءة: </span>
          البرتقالي = فيبوناتشي. الأبيض = جان. الرمادي = إحصائي.
          كل نظام يحسب مناطقه بشكل مستقل انطلاقاً من نقطة الارتكاز.
          عندما يتقاطع نظامان أو أكثر في تاريخ متقارب يتشكل "كلاستر زمني قوي".
          التوافق الثلاثي هو الأقوى ويمثل نقطة انعكاس عالية الموثوقية.
        </div>
      </div>
    </div>
  </div>
</div>
<div class="pg" id="pg-mooncorr">
