              <tr style="border-bottom:1px solid #222;">
                <th style="padding:8px 4px; font-size:0.65rem; color:#888;">Fib</th>
                <th style="padding:8px 4px; font-size:0.65rem; color:#888;">الشموع</th>
                <th style="padding:8px 4px; font-size:0.65rem; color:#888;">التاريخ</th>
                <th style="padding:8px 4px; font-size:0.65rem; color:#888;">النوع</th>
                <th style="padding:8px 4px; font-size:0.65rem; color:#888;">الحالة</th>
              </tr>
            </thead>
            <tbody id="ft-table-body"></tbody>
          </table>
        </div>
      </div>

      <div style="background:#080808; border:1px solid #1a1a1a; border-right:3px solid var(--o); border-radius:10px; padding:16px; margin-bottom:14px;">
        <div style="font-family:'Share Tech Mono',monospace; font-size:0.6rem; color:var(--o); margin-bottom:8px; letter-spacing:1px;">CONCLUSION</div>
        <div id="ft-conclusion" style="font-size:0.82rem; line-height:1.7; color:#bbb;">--</div>
      </div>

      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:10px; padding:14px; border-right:3px solid var(--o);">
        <div style="font-size:0.68rem; color:#777; line-height:1.7; text-align:right;">
          <span style="color:var(--o); font-weight:bold;">دليل القراءة: </span>
          الأداة تكتشف تلقائياً آخر نقطة ارتكاز (قمة أو قاع) وتحسب مناطق فيبوناتشي الزمنية الممتدة.
          الأرقام الرئيسية (5, 8, 13, 21, 34, 55, 89, 144, 233) تمثل دورات الانعكاس الأقوى.
          تقارب المناطق يولد (كلاستر زمني) يعزز من احتمالية تسارع أو انعكاس الاتجاه.
        </div>
      </div>
    </div>
  </div>
</div>
<div class="pg" id="pg-confluence">
  <div class="tp" style="max-width: 500px; margin: 0 auto;">
    <div class="th" style="text-align: center; margin-bottom: 24px; padding-top: 10px;">
      <div style="font-family:'Share Tech Mono',monospace; font-size:0.5rem; color:#333; letter-spacing:5px; margin-bottom:6px;">MULTI-SYSTEM TIME ANALYSIS</div>
      <h1 style="color:var(--o); font-weight:900; font-size:1.4rem; margin:0;">Cycle Confluence</h1>
      <p style="color:var(--t3); font-size:0.7rem; margin-top:4px;">توافق 3 أنظمة دورية لكشف مناطق الانعكاس الزمني</p>
    </div>

    <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:10px; padding:18px; margin-bottom:20px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:14px;">
        <div>
          <label style="font-size:0.7rem; color:#555; margin-bottom:5px; display:block; font-weight:600;">رمز العملة</label>
          <input type="text" id="cc-symbol" placeholder="BTC" value="BTC" style="width:100%; padding:11px; background:#111; border:1px solid #222; border-radius:6px; color:#fff; text-transform:uppercase; font-family:'Share Tech Mono',monospace; font-size:1rem; text-align:center; outline:none;">
