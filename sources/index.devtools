}
#pg-flash .fl-trade-price {
    font-size: 14px;
    font-weight: 900;
    font-family: 'Share Tech Mono', monospace;
}
#pg-flash .fl-trade-meta {
    font-size: 9px;
    color: var(--t3);
    margin-top: 4px;
    font-family: 'Share Tech Mono', monospace;
}
#pg-flash .fl-tp-section {
