  /* ICT Analysis Engine — Visual Architecture */
#pg-ict .ict-input-full {
    width: 100%;
    background: var(--bg);
    border: 2px solid var(--b);
    color: var(--t);
    padding: 14px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 16px;
    text-align: center;
    letter-spacing: 3px;
    margin-bottom: 10px;
    border-radius: 4px;
    outline: none;
}
#pg-ict .ict-input-full:focus {
    border-color: var(--o);
}
#pg-ict .ict-tf-row {
    display: flex;
    gap: 6px;
    margin-bottom: 12px;
}
#pg-ict .ict-tf-btn {
    flex: 1;
    padding: 10px;
    background: var(--s);
    color: var(--t3);
    border: 2px solid var(--b);
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 2px;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.3s ease;
}
#pg-ict .ict-tf-active {
    background: var(--o);
    color: var(--bg);
    border-color: var(--o);
}
#pg-ict .ict-tier-badge {
    display: inline-block;
    font-size: 9px;
    background: var(--o);
    color: var(--bg);
    padding: 4px 12px;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    letter-spacing: 2px;
    margin-top: 8px;
    border-radius: 2px;
}
#pg-ict .ict-chart-wrap {
