      <div id="wedge-pattern-card"></div>
      <div id="wedge-breakout-card" style="margin-bottom:6px;"></div>
      <div id="wedge-measurements" style="margin-bottom:6px;"></div>
      <div id="wedge-stats-card" style="margin-bottom:6px;"></div>
      <div id="wedge-targets-card" style="margin-bottom:6px;"></div>

      <div style="background:#080808; border:1px solid #1a1a1a; border-right:3px solid var(--o); border-radius:4px; padding:12px; margin-bottom:6px;">
        <div style="color:var(--o); font-size:0.5rem; font-weight:bold; font-family:'Share Tech Mono',monospace; letter-spacing:2px; margin-bottom:8px;">WEDGE VERDICT</div>
        <div id="wedge-conclusion" style="font-size:0.72rem; line-height:1.8; color:#ccc; font-family:'Cairo', sans-serif;">--</div>
      </div>

      <div style="background:#060606; border:1px solid #1a1a1a; border-radius:4px; padding:10px 12px; border-right:3px solid var(--o);">
        <div style="font-size:0.6rem; color:#ccc; line-height:1.8; text-align:right; font-family:'Cairo', sans-serif;">
          <span style="color:var(--o); font-weight:bold;">دليل القراءة: </span>
          الوتد الصاعد (Rising Wedge) = انعكاسي هبوطي.<br>
          الوتد الهابط (Falling Wedge) = انعكاسي صعودي.<br>
          U = نقاط ارتكاز علوية. L = سفلية.<br>
          الحجم المتناقص = تأكيد كلاسيكي. CONFIRM = سعر تفعيل النموذج.<br>
          هذا تحليل فني موضوعي ولا يُعتبر توصية شراء أو بيع.
        </div>
      </div>

      <div style="text-align:center; margin-top:12px; padding:6px;">
        <span style="font-family:'Share Tech Mono',monospace; font-size:0.4rem; color:#111; letter-spacing:2px;">360° WEDGE SCANNER</span>
      </div>
    </div>

  </div>
</div>

