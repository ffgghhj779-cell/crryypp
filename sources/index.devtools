}
#pg-flash .fl-comps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
}
#pg-flash .fl-comp-chip {
    background: var(--bg);
    border: 1px solid var(--b);
    border-top: 3px solid var(--b);
