      <div style="background:var(--s); border:1px solid var(--b); border-right:3px solid var(--o); border-radius:4px; padding:16px; margin-top:10px;">
        <div style="color:var(--o); font-size:0.75rem; font-weight:bold; font-family:'Cairo',sans-serif; margin-bottom:10px;">هندسة المخاطر وإخلاء المسؤولية</div>
        <div style="font-size:0.65rem; line-height:1.8; color:var(--t3); text-align:justify; font-family:'Cairo',sans-serif;">
