      <div class="fng-value" id="sentGaugeVal">0</div>
    </div>
  </div>
  <div class="fng-label-text" id="sentLabelText" style="font-size: 1.2rem; text-align: center;">جاري المزامنة...</div>
</div>
    </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 15px;">
      <div class="widget-box">
        <div style="font-size: 0.7rem; color: var(--t3);">القيمة السوقية الكلية</div>
        <div id="market-cap" style="font-family: 'Share Tech Mono'; font-size: 1.2rem; color: var(--o); margin: 5px 0;">$--</div>
        <div id="mcap-change" style="font-size: 0.6rem; color: #ffffff;">--%</div>
      </div>
      <div class="widget-box">
        <div style="font-size: 0.7rem; color: var(--t3);">حجم التداول (24h)</div>
        <div id="trading-vol" style="font-family: 'Share Tech Mono'; font-size: 1.2rem; color: #ffffff; margin: 5px 0;">$--</div>
        <div style="font-size: 0.6rem; color: var(--t2);">إجمالي تداولات السوق</div>
      </div>
    </div>
