          <input type="text" id="ft-symbol" placeholder="BTC" value="BTC" style="width:100%; padding:11px; background:#111; border:1px solid #222; border-radius:6px; color:#fff; text-transform:uppercase; font-family:'Share Tech Mono',monospace; font-size:1rem; text-align:center; outline:none;">
        </div>
