    overflow: hidden;
}
#pg-flash .fl-signal-fill {
    height: 100%;
}
#pg-flash .fl-trade-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    margin-bottom: 14px;
}
#pg-flash .fl-trade-item {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 12px 8px;
