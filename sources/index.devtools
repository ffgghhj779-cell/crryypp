}
#pg-flash .fl-card {
    background: var(--s);
    border: 1px solid var(--b);
    padding: 18px;
    margin-bottom: 16px;
    border-radius: 4px;
}
#pg-flash .fl-card-notrade {
    border-right: 4px solid var(--b);
}
#pg-flash .fl-card-head {
    display: flex;
