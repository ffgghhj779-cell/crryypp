<div class="hero-btc-card">
  <div class="hbc-header">
    <div class="hbc-info">
      <div class="hbc-title-wrap">
        <div class="hbc-live-dot"></div>
        <span class="hbc-title">BTC/USDT <span>LIVE</span></span>
      </div>
      <div class="hbc-subtitle">HOURLY MACRO TREND (1H)</div>
    </div>
    <div class="hbc-price-wrap">
      <div class="hbc-price" id="hbc-price">LOADING...</div>
      <div class="hbc-change" id="hbc-change" style="border: 1px solid transparent; transition: all 0.3s ease;">--%</div>
    </div>
  </div>
  
  <div class="hbc-stats" style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; position: relative; z-index: 2; margin-bottom: 10px; width: 100%;">
    <div style="text-align: left; direction: ltr;">
      <div class="hbc-stat-lbl">24H LOW</div>
      <div class="hbc-stat-val" id="hbc-low" style="color: var(--o);">--</div>
    </div>
    <div style="text-align: right; direction: ltr;">
      <div class="hbc-stat-lbl">24H HIGH</div>
      <div class="hbc-stat-val" id="hbc-high" style="color: #ffffff;">--</div>
    </div>
  </div>

  <div class="hbc-chart-wrap" id="hbc-chart-container">
    <svg id="hbc-svg" width="100%" height="100%" preserveAspectRatio="none" style="display: block;">
      <defs>
        <linearGradient id="hbc-line-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#555555" />
          <stop offset="50%" stop-color="#cccccc" />
          <stop offset="100%" stop-color="#ff6a00" />
        </linearGradient>
        <linearGradient id="hbc-area-grad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="rgba(255, 106, 0, 0.3)" />
          <stop offset="100%" stop-color="rgba(255, 106, 0, 0)" />
        </linearGradient>
        <filter id="hbc-glow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="4" stdDeviation="4" flood-color="#ff6a00" flood-opacity="0.5"/>
        </filter>
      </defs>
      
      <line x1="0" y1="25%" x2="100%" y2="25%" stroke="#ffffff" stroke-opacity="0.03" stroke-width="1" stroke-dasharray="4 4" />
      <line x1="0" y1="50%" x2="100%" y2="50%" stroke="#ffffff" stroke-opacity="0.03" stroke-width="1" stroke-dasharray="4 4" />
      <line x1="0" y1="75%" x2="100%" y2="75%" stroke="#ffffff" stroke-opacity="0.03" stroke-width="1" stroke-dasharray="4 4" />
      
      <polygon id="hbc-area" fill="url(#hbc-area-grad)" points=""></polygon>
      <path id="hbc-line" fill="none" stroke="url(#hbc-line-grad)" stroke-width="2.5" filter="url(#hbc-glow)" stroke-linecap="round" stroke-linejoin="round" d=""></path>
      
      <g id="hbc-crosshair" style="display: none;">
        <line id="hbc-vline" x1="0" y1="0" x2="0" y2="100%" stroke="#ffffff" stroke-width="1" stroke-dasharray="3 3" opacity="0.3" />
        <circle id="hbc-hover-dot" cx="0" cy="0" r="4.5" fill="#000000" stroke="#ffffff" stroke-width="2" />
      </g>

      <circle id="hbc-pulse" cx="0" cy="0" r="15" fill="none" stroke="var(--o)" stroke-width="1.5" opacity="0"></circle>
      <circle id="hbc-dot" cx="0" cy="0" r="4.5" fill="#ffffff" filter="drop-shadow(0 0 6px #ff6a00)"></circle>
    </svg>
    
    <div id="hbc-tooltip" class="hbc-tooltip">--</div>
  </div>
</div>

<div class="ticker-wrap-2">
