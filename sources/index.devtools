          <div style="display:flex; align-items:center; gap:4px;"><div style="width:8px; height:8px; border-radius:50%; background:var(--o); border:2px solid var(--o);"></div><span style="color:var(--o);">نشطة</span></div>
          <div style="display:flex; align-items:center; gap:4px;"><div style="width:6px; height:6px; border-radius:50%; background:#fff;"></div><span style="color:#888;">قادمة</span></div>
