  /* ===== شريط التحكم السفلي (Bottom Tab Bar) ===== */

/* إخفاء الشريط في الكمبيوتر، وإظهاره في الجوال فقط */
@media (min-width: 769px) {
  .btb, .btb-overlay, .btb-toast, .btb-loader { display: none !important; }
}

@media (max-width: 768px) {
  /* حماية المحتوى من التغطية بالشريط السفلي */
  body, .pg, .mnav {
    padding-bottom: 80px !important; /* مساحة أمان ترفع المحتوى فوق الشريط */
  }
  
  /* رفع زر حفظ التحليل ليطفو بأناقة فوق الشريط السفلي في الجوال */
  #radar-floating-btn {
    bottom: calc(85px + env(safe-area-inset-bottom, 0px)) !important;
  }
}
  
.btb {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  background: #050505; /* خلفية سوداء */
  border-top: 1px solid #1a1a1a;
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 9998;
  padding: 0 4px;
  box-shadow: 0 -4px 15px rgba(0,0,0,0.8);
}

.btb-btn {
  flex: 1;
  height: 100%;
  background: transparent;
  border: none;
  outline: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  transition: background 0.15s ease;
  -webkit-tap-highlight-color: transparent;
}

.btb-btn:active {
  background: #111111;
}

.btb-btn svg {
  width: 22px;
  height: 22px;
  stroke: #ffffff; /* الأيقونات باللون الأبيض */
  fill: none;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.btb-btn span {
  color: #ffffff;
  font-size: 0.6rem;
  letter-spacing: 0.2px;
  font-weight: 600;
  font-family: 'Cairo', sans-serif;
}

/* ===== نوافذ البحث والتوثيق ===== */
.btb-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.9);
  z-index: 9999;
  padding: 20px 12px;
  overflow-y: auto;
}
.btb-overlay.open { display: flex; animation: fadeIn 0.3s ease; }
.btb-modal { width: 100%; max-width: 520px; margin: 0 auto; background: #000; border: 1px solid #1a1a1a; border-radius: 8px; padding: 14px; box-shadow: 0 10px 30px rgba(0,0,0,0.9);}
.btb-input { width: 100%; background: #0a0a0a; border: 1px solid #2a2a2a; color: #fff; padding: 12px; border-radius: 4px; font-family: 'Cairo', sans-serif; font-size: 0.95rem; text-align: right; outline: none; margin-bottom: 12px; }
.btb-input:focus { border-color: var(--o); }
.btb-result-item { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 4px; padding: 10px 12px; margin-bottom: 6px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; transition: border-color 0.15s ease; }
.btb-result-item:active { border-color: var(--o); background: #060606; }
.btb-result-en { color: #fff; font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; font-weight: bold; }
.btb-result-ar { color: #888; font-family: 'Cairo', sans-serif; font-size: 0.7rem; text-align: right; flex: 1; margin-right: 10px; }

/* ===== إشعار وشاشة التحميل ===== */
.btb-toast { position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%); background: #0a0a0a; border: 1px solid var(--o); border-radius: 4px; padding: 10px 18px; color: #fff; font-family: 'Cairo', sans-serif; font-size: 0.75rem; font-weight: bold; z-index: 10000; opacity: 0; pointer-events: none; transition: opacity 0.25s ease; box-shadow: 0 4px 10px rgba(0,0,0,0.8); }
.btb-toast.show { opacity: 1; }
.btb-loader { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 10001; justify-content: center; align-items: center; flex-direction: column; gap: 12px; }
.btb-loader.show { display: flex; }
.btb-spinner { width: 36px; height: 36px; border: 3px solid #1a1a1a; border-top-color: var(--o); border-radius: 50%; animation: btb-spin 0.7s linear infinite; }
@keyframes btb-spin { to { transform: rotate(360deg); } }

/* ===== Footer منصة 360° (3D Solid UI) ===== */
.ftr {
  background: var(--bg);
  padding: 24px 12px 30px;
  max-width: 600px;
  margin: 30px auto 0;
  border-top: 2px solid var(--o);
}

.ftr-brand { text-align: center; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--b); }
.ftr-logo { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.ftr-logo-icon { width: 36px; height: 36px; background: var(--s); border: 1px solid var(--b); border-top: 1px solid #444; border-left: 1px solid #333; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--o); font-family: 'Share Tech Mono', monospace; font-size: 0.9rem; font-weight: 900; box-shadow: 0 4px 10px rgba(0,0,0,0.8), inset 0 1px 1px rgba(255,255,255,0.05); }
.ftr-name { color: var(--t); font-size: 1.1rem; font-weight: 900; font-family: 'Cairo', sans-serif; }
.ftr-name span { color: var(--o); }
.ftr-tagline { color: var(--t2); font-size: 0.75rem; line-height: 1.7; font-family: 'Cairo', sans-serif; font-weight: 600; }

.ftr-section { margin-bottom: 20px; }
.ftr-section-title { color: var(--o); font-size: 0.65rem; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin-bottom: 12px; text-align: center; font-weight: bold; }

.ftr-socials { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
.ftr-social { 
  background: linear-gradient(180deg, #1c1c1c 0%, #111111 100%); 
  border: 1px solid #222; border-top: 1px solid #444; border-left: 1px solid #333;
  border-radius: 8px; padding: 14px 8px; 
  display: flex; flex-direction: column; align-items: center; gap: 8px; 
  text-decoration: none; transition: all 0.2s ease; cursor: pointer; 
  box-shadow: 0 6px 15px rgba(0,0,0,0.9), 0 2px 5px rgba(0,0,0,0.5);
}
.ftr-social:active { transform: translateY(4px); box-shadow: 0 0 0 #000, inset 0 3px 6px rgba(0,0,0,0.9); border-top-color: #111; background: #0a0a0a; }
.ftr-social svg { width: 24px; height: 24px; stroke: var(--t); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; filter: drop-shadow(0 2px 2px rgba(0,0,0,0.8)); transition: stroke 0.2s ease; }
.ftr-social:active svg { stroke: var(--o); }
.ftr-social-label { font-family: 'Share Tech Mono', monospace; font-size: 0.65rem; color: var(--t2); font-weight: bold; letter-spacing: 0.5px; }
.ftr-social-handle { color: var(--t); font-family: 'Cairo', sans-serif; font-size: 0.7rem; font-weight: bold; }

.ftr-disclaimer { background: linear-gradient(180deg, #1c1c1c 0%, #111111 100%); border: 1px solid #222; border-right: 3px solid var(--o); border-top: 1px solid #444; border-bottom: 1px solid #111; border-radius: 8px; padding: 14px; margin-bottom: 20px; box-shadow: 0 6px 15px rgba(0,0,0,0.8); }
.ftr-disclaimer-title { color: var(--o); font-size: 0.7rem; font-weight: 900; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; font-family: 'Cairo', sans-serif; }
.ftr-disclaimer-text { color: var(--t2); font-size: 0.7rem; line-height: 1.8; font-family: 'Cairo', sans-serif; text-align: justify; }

.ftr-links { display: flex; justify-content: center; flex-wrap: wrap; gap: 16px; margin-bottom: 16px; padding-top: 16px; border-top: 1px solid var(--b); }
.ftr-link { color: var(--t3); font-size: 0.7rem; text-decoration: none; cursor: pointer; font-family: 'Cairo', sans-serif; font-weight: 600; transition: color 0.2s; }
.ftr-link:hover { color: var(--o); }
.ftr-link-sep { color: var(--b); font-weight: bold; }

.ftr-copy { text-align: center; color: var(--t3); font-size: 0.65rem; font-family: 'Share Tech Mono', monospace; letter-spacing: 1px; line-height: 1.8; }
.ftr-copy-version { color: #555; margin-top: 4px; font-weight: bold; }

/* نوافذ الفوتر المنبثقة */
.ftr-modal-bg { display: none; position: fixed; inset: 0; background: rgba(0, 0, 0, 0.85); z-index: 99999; padding: 20px 12px; overflow-y: auto; backdrop-filter: blur(5px); }
.ftr-modal-bg.show { display: block; animation: fadeIn 0.3s ease; }
.ftr-modal-card { max-width: 480px; margin: 40px auto; background: linear-gradient(180deg, #1c1c1c 0%, #111111 100%); border: 1px solid #222; border-top: 2px solid var(--o); border-left: 1px solid #333; border-radius: 12px; padding: 20px; box-shadow: 0 20px 50px rgba(0,0,0,1); }
.ftr-modal-head { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--b); padding-bottom: 14px; margin-bottom: 16px; }
.ftr-modal-title { color: var(--t); font-size: 1.1rem; font-weight: 900; font-family: 'Cairo', sans-serif; }
.ftr-modal-close { color: var(--o); background: var(--od); border: 1px solid var(--o); padding: 6px 14px; border-radius: 6px; cursor: pointer; font-size: 0.8rem; font-weight: 900; font-family: 'Cairo', sans-serif; text-transform: uppercase; transition: 0.2s; }
.ftr-modal-close:active { background: var(--o); color: var(--bg); }
.ftr-modal-content { color: var(--t2); font-size: 0.8rem; line-height: 2; font-family: 'Cairo', sans-serif; text-align: justify; }
.ftr-modal-content h4 { color: var(--o); font-size: 0.85rem; font-weight: 900; margin: 16px 0 8px; border-bottom: 1px dashed var(--b); padding-bottom: 4px; }
.ftr-modal-content ul { padding-right: 20px; margin: 8px 0; }
.ftr-modal-content li { margin-bottom: 8px; }
.ftr-modal-content p { margin-bottom: 10px; text-align: justify; }

/* TOKEN SCANNER — Visual Architecture */
#pg-tscan .tscan-input-full {
    width: 100%;
    background: var(--bg);
    border: 2px solid var(--b);
    color: var(--t);
    padding: 14px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 16px;
    text-align: center;
    letter-spacing: 3px;
    margin-bottom: 10px;
    border-radius: 4px;
}
#pg-tscan .tscan-input-full:focus {
    border-color: var(--o);
    outline: none;
}
#pg-tscan .tscan-tier-badge {
    display: inline-block;
    font-size: 9px;
    background: var(--o);
    color: var(--bg);
    padding: 4px 12px;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    letter-spacing: 2px;
    margin-top: 8px;
    border-radius: 2px;
}
#pg-tscan .tscan-class-card {
    background: var(--s);
    border: 3px solid var(--t);
    padding: 22px;
    margin-bottom: 16px;
    text-align: center;
    border-radius: 4px;
}
#pg-tscan .tscan-class-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--t3);
    letter-spacing: 3px;
    margin-bottom: 8px;
}
#pg-tscan .tscan-class-name {
    font-family: 'Share Tech Mono', monospace;
    font-size: 16px;
    color: var(--t);
    font-weight: 900;
    margin-bottom: 6px;
}
#pg-tscan .tscan-class-result {
    font-family: 'Share Tech Mono', monospace;
    font-size: 48px;
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1.1;
}
#pg-tscan .tscan-class-score {
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    color: var(--t3);
    margin-top: 6px;
}
#pg-tscan .tscan-class-bar {
    width: 100%;
    height: 10px;
    background: var(--b);
    margin-top: 14px;
    border-radius: 2px;
    overflow: hidden;
}
#pg-tscan .tscan-class-fill {
    height: 100%;
    transition: width 0.5s ease;
}
#pg-tscan .tscan-class-scale {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
}
#pg-tscan .tscan-class-scale span {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: var(--t3);
}
#pg-tscan .tscan-section {
    background: var(--s);
    border: 1px solid var(--b);
    padding: 18px;
    margin-bottom: 16px;
    border-radius: 4px;
}
#pg-tscan .tscan-section-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--o);
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--b);
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 2px;
}
#pg-tscan .tscan-score-row {
    margin-bottom: 10px;
}
#pg-tscan .tscan-score-info {
    display: flex;
    justify-content: space-between;
    margin-bottom: 5px;
}
#pg-tscan .tscan-score-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--t2);
    letter-spacing: 1px;
    font-weight: 700;
}
#pg-tscan .tscan-score-val {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    font-weight: 900;
}
#pg-tscan .tscan-score-bar {
    width: 100%;
    height: 5px;
    background: var(--b);
    border-radius: 2px;
    overflow: hidden;
}
#pg-tscan .tscan-score-fill {
    height: 100%;
    transition: width 0.5s ease;
}
#pg-tscan .tscan-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
}
#pg-tscan .tscan-grid-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
}
#pg-tscan .tscan-cell {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 12px 10px;
    border-radius: 2px;
}
#pg-tscan .tscan-cell-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--t3);
    letter-spacing: 1px;
    margin-bottom: 5px;
    font-weight: 700;
}
#pg-tscan .tscan-cell-value {
    font-family: 'Share Tech Mono', monospace;
    font-size: 15px;
    font-weight: 900;
}
#pg-tscan .tscan-cell-center {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 12px 6px;
    text-align: center;
    border-radius: 2px;
}
#pg-tscan .tscan-cell-big {
    font-family: 'Share Tech Mono', monospace;
    font-size: 20px;
    font-weight: 900;
    color: var(--t);
}
#pg-tscan .tscan-exchanges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
}
#pg-tscan .tscan-exchange-badge {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 7px 14px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--t);
    font-weight: 700;
    border-radius: 2px;
}
#pg-tscan .tscan-supply-bar-wrap {
    margin-top: 14px;
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 14px;
    border-radius: 2px;
}
#pg-tscan .tscan-supply-bar-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--t3);
    margin-bottom: 8px;
    font-weight: 700;
}
#pg-tscan .tscan-supply-bar-track {
    width: 100%;
    height: 22px;
    background: var(--b);
    position: relative;
    border-radius: 2px;
    overflow: hidden;
}
#pg-tscan .tscan-supply-bar-fill {
    height: 100%;
    background: var(--t);
    transition: width 0.5s ease;
}
#pg-tscan .tscan-supply-bar-pct {
    position: absolute;
    left: 50%;
    top: 3px;
    transform: translateX(-50%);
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--bg);
    font-weight: 900;
}
#pg-tscan .tscan-supply-bar-legend {
    display: flex;
    justify-content: space-between;
    margin-top: 5px;
}
#pg-tscan .tscan-supply-bar-legend span {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: var(--t2);
}
#pg-tscan .tscan-gh-status {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    padding: 12px;
    background: var(--bg);
    border: 1px solid var(--b);
    border-radius: 2px;
}
#pg-tscan .tscan-gh-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
}
#pg-tscan .tscan-gh-status-info {
    flex: 1;
}
#pg-tscan .tscan-gh-status-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    color: var(--t);
    font-weight: 900;
}
#pg-tscan .tscan-gh-status-url {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--t3);
    margin-top: 2px;
}
#pg-tscan .tscan-gh-status-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    font-weight: 900;
}
#pg-tscan .tscan-verdict {
    background: var(--s);
    border-right: 4px solid var(--t);
    padding: 20px;
    margin-bottom: 16px;
    border-radius: 4px;
}
#pg-tscan .tscan-verdict-text {
    font-size: 14px;
    color: var(--t);
    line-height: 2.1;
    text-align: justify;
    font-family: 'Cairo', sans-serif;
    margin-bottom: 14px;
}
#pg-tscan .tscan-disclaimer {
    padding: 12px;
    background: var(--bg);
    border: 1px solid var(--b);
    font-size: 11px;
    color: var(--t2);
    line-height: 1.7;
    font-family: 'Cairo', sans-serif;
    border-radius: 2px;
    text-align: center;
}
#pg-tscan .tscan-guide {
    background: var(--s);
    border: 1px solid var(--b);
    padding: 18px;
    margin-top: 16px;
    border-radius: 4px;
}
#pg-tscan .tscan-guide-title {
    font-size: 13px;
    color: var(--o);
    font-weight: 700;
    margin-bottom: 12px;
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 1px;
}
#pg-tscan .tscan-guide-text {
    font-size: 13px;
    color: var(--t2);
    line-height: 2.1;
    font-family: 'Cairo', sans-serif;
    text-align: justify;
}

/* ================== CHART PATTERNS TOOL ================== */
#pg-chart-patterns .ch-cat-btn {
  padding: 10px 16px;
  background: #050505;
  color: var(--t3);
  border: 1px solid #111;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  white-space: nowrap;
  cursor: pointer;
  letter-spacing: 1px;
  border-radius: 4px;
  transition: all 0.2s ease;
}
#pg-chart-patterns .ch-cat-active {
  background: rgba(255, 106, 0, 0.1);
  color: var(--o);
  border-color: var(--o);
}
#pg-chart-patterns .ch-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
#pg-chart-patterns .ch-card {
  background: #050505;
  border: 1px solid #111;
  padding: 12px;
  cursor: pointer;
  border-radius: 6px;
  transition: all 0.2s ease;
}
#pg-chart-patterns .ch-card:hover {
  background: #0a0a0a;
  border-color: var(--o);
  transform: translateY(-2px);
}
#pg-chart-patterns .ch-card-svg {
  width: 100%;
  height: 70px;
  margin-bottom: 8px;
}
#pg-chart-patterns .ch-card-name {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--t);
  font-weight: 900;
  margin-bottom: 2px;
}
#pg-chart-patterns .ch-card-ar {
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  color: var(--o);
  font-weight: 700;
  margin-bottom: 4px;
}
#pg-chart-patterns .ch-card-type {
  font-family: 'Share Tech Mono', monospace;
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 1px;
  margin-bottom: 6px;
}
#pg-chart-patterns .ch-card-rel-row {
  display: flex;
  justify-content: space-between;
}
#pg-chart-patterns .ch-card-rel-l {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  color: var(--t3);
}
#pg-chart-patterns .ch-card-rel-v {
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px;
  font-weight: 900;
}
#pg-chart-patterns .ch-card-bar {
  width: 100%;
  height: 3px;
  background: #111;
  margin-top: 3px;
  border-radius: 2px;
  overflow: hidden;
}
#pg-chart-patterns .ch-card-fill {
  height: 100%;
}
#pg-chart-patterns .ch-back {
  display: inline-block;
  background: none;
  border: 1px solid #1a1a1a;
  color: var(--o);
  padding: 8px 16px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  cursor: pointer;
  margin-bottom: 14px;
  font-weight: 700;
  border-radius: 4px;
  transition: all 0.2s ease;
}
#pg-chart-patterns .ch-back:hover {
  background: rgba(255, 106, 0, 0.1);
  border-color: var(--o);
}
#pg-chart-patterns .ch-detail {
  background: #050505;
  border: 1px solid #111;
  padding: 20px;
  border-radius: 8px;
}
#pg-chart-patterns .ch-detail-svg {
  width: 100%;
  height: 160px;
  margin-bottom: 16px;
}
#pg-chart-patterns .ch-detail-name {
  font-family: 'Share Tech Mono', monospace;
  font-size: 16px;
  color: var(--t);
  font-weight: 900;
}
#pg-chart-patterns .ch-detail-ar {
  font-family: 'Cairo', sans-serif;
  font-size: 20px;
  color: var(--o);
  font-weight: 900;
  margin-top: 4px;
  margin-bottom: 10px;
}
#pg-chart-patterns .ch-detail-badge {
  display: inline-block;
  color: #000;
  padding: 4px 12px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 1px;
  margin-bottom: 14px;
  border-radius: 4px;
}
#pg-chart-patterns .ch-detail-rel-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}
#pg-chart-patterns .ch-detail-rel-l {
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px;
  color: var(--t2);
}
#pg-chart-patterns .ch-detail-rel-v {
  font-family: 'Share Tech Mono', monospace;
  font-size: 22px;
  font-weight: 900;
}
#pg-chart-patterns .ch-detail-bar {
  width: 100%;
  height: 6px;
