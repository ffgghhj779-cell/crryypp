#pg-vip4 .vip4-gt { font-size:12px; color:var(--o); font-weight:700; margin-bottom:10px; font-family:'Share Tech Mono',monospace; letter-spacing:0.5px; }
#pg-vip4 .vip4-gx { font-size:12px; color:var(--t2); line-height:1.8; font-family:'Cairo',sans-serif; text-align:justify; }
/* Trading Limit Order (TLO) — Visual Architecture */
#pg-tlo .tlo-input-full {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--b);
    color: var(--t);
    padding: 10px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    text-align: center;
    margin-bottom: 10px;
    box-sizing: border-box;
    border-radius: 4px;
    outline: none;
}
#pg-tlo .tlo-tier-badge {
    display: inline-block;
    font-size: 9px;
    background: var(--o);
    color: #000;
    padding: 3px 8px;
    margin-top: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    letter-spacing: 1px;
    border-radius: 2px;
}
#pg-tlo .tlo-master {
    background: var(--s);
    border: 2px solid var(--t);
    padding: 20px;
    margin-bottom: 15px;
    text-align: center;
    border-radius: 4px;
}
#pg-tlo .tlo-ml {
    font-size: 10px;
    color: var(--t3);
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 2px;
    margin-bottom: 10px;
}
#pg-tlo .tlo-mg {
    font-size: 42px;
    font-weight: 900;
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 3px;
    line-height: 1;
    margin-bottom: 8px;
}
#pg-tlo .tlo-mb {
    font-size: 13px;
    font-family: 'Cairo', sans-serif;
    font-weight: 900;
    letter-spacing: 1px;
    margin-top: 8px;
}
#pg-tlo .tlo-mbar {
    width: 100%;
    height: 8px;
    background: var(--bg);
    margin-top: 12px;
    border-radius: 2px;
    overflow: hidden;
    border: 1px solid var(--b);
}
#pg-tlo .tlo-mbar-f {
    height: 100%;
    background: var(--t);
    transition: width 1s ease;
}
#pg-tlo .tlo-mstats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    margin-top: 15px;
}
#pg-tlo .tlo-ms {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 10px 6px;
    text-align: center;
    border-radius: 2px;
}
#pg-tlo .tlo-msl {
    font-size: 8px;
    color: var(--t3);
    font-family: 'Share Tech Mono', monospace;
    margin-bottom: 4px;
}
#pg-tlo .tlo-msv {
    font-size: 13px;
    font-weight: 900;
    color: var(--o);
    font-family: 'Share Tech Mono', monospace;
}
#pg-tlo .tlo-tc {
    background: var(--s);
    border: 1px solid var(--b);
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 4px;
}
#pg-tlo .tlo-th {
    display: flex;
    align-items: center;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--b);
    margin-bottom: 12px;
}
#pg-tlo .tlo-ttf {
    background: var(--o);
    color: #000;
    padding: 6px 10px;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    font-size: 14px;
    letter-spacing: 1px;
    border-radius: 2px;
}
#pg-tlo .tlo-thd {
    flex: 1;
    text-align: center;
    padding: 0 10px;
}
#pg-tlo .tlo-tar {
    font-size: 13px;
    color: var(--t);
    font-family: 'Cairo', sans-serif;
    font-weight: 700;
}
#pg-tlo .tlo-ten {
    font-size: 9px;
    color: var(--t3);
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 1px;
    margin-top: 2px;
}
#pg-tlo .tlo-tgr {
    font-size: 22px;
    font-weight: 900;
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 2px;
}
#pg-tlo .tlo-no-trade {
    text-align: center;
    padding: 20px;
    background: var(--bg);
    border: 1px solid var(--b);
    border-radius: 2px;
}
#pg-tlo .tlo-sr {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}
#pg-tlo .tlo-sb {
    padding: 4px 10px;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    font-size: 11px;
    letter-spacing: 1px;
    border-radius: 2px;
}
#pg-tlo .tlo-ss {
    font-size: 11px;
    color: var(--o);
    font-family: 'Share Tech Mono', monospace;
    font-weight: 700;
}
#pg-tlo .tlo-sbar {
    width: 100%;
    height: 4px;
    background: var(--b);
    margin-bottom: 12px;
    border-radius: 2px;
    overflow: hidden;
}
#pg-tlo .tlo-sfill {
    height: 100%;
}
#pg-tlo .tlo-zones-section {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 12px;
    margin-bottom: 14px;
    border-radius: 2px;
}
#pg-tlo .tlo-zones-title {
    font-size: 11px;
    color: var(--o);
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    letter-spacing: 1px;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--b);
}
#pg-tlo .tlo-zone-row {
    background: var(--s);
    padding: 10px;
    margin-bottom: 8px;
    border-right: 3px solid var(--b);
    border-radius: 2px;
}
#pg-tlo .tlo-zone-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
}
#pg-tlo .tlo-zone-name {
    font-size: 11px;
    font-weight: 700;
    font-family: 'Share Tech Mono', monospace;
    flex: 1;
}
#pg-tlo .tlo-fresh-badge {
    background: var(--t);
    color: var(--bg);
    padding: 2px 6px;
    font-size: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    letter-spacing: 0.5px;
    border-radius: 2px;
}
#pg-tlo .tlo-zone-priority {
    font-size: 9px;
    color: var(--o);
    font-family: 'Share Tech Mono', monospace;
    font-weight: 700;
}
#pg-tlo .tlo-zone-prices {
    display: flex;
    justify-content: space-between;
    font-family: 'Share Tech Mono', monospace;
}
#pg-tlo .tlo-zone-range {
    font-size: 11px;
    color: var(--t);
    font-weight: 700;
}
#pg-tlo .tlo-zone-mid {
    font-size: 10px;
    color: var(--o);
    font-weight: 700;
}
#pg-tlo .tlo-trade-section {
    margin-bottom: 12px;
}
#pg-tlo .tlo-trade-section-title {
    font-size: 10px;
    color: var(--t3);
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 1px;
    margin-bottom: 8px;
}
#pg-tlo .tlo-tbl {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Share Tech Mono', monospace;
}
#pg-tlo .tlo-tl {
    padding: 9px 4px;
    color: var(--t2);
    font-size: 11px;
    font-weight: 700;
    width: 22%;
    border-bottom: 1px solid var(--bg);
}
#pg-tlo .tlo-tp {
    padding: 9px 4px;
    font-size: 14px;
    font-weight: 900;
    text-align: center;
    border-bottom: 1px solid var(--bg);
    width: 28%;
    direction: ltr;
}
#pg-tlo .tlo-tm {
    padding: 9px 4px;
    color: var(--t3);
    font-size: 10px;
    text-align: left;
    border-bottom: 1px solid var(--bg);
    direction: ltr;
}
#pg-tlo .tlo-sep td {
    padding: 3px 0;
    border-bottom: 1px solid var(--b);
}
#pg-tlo .tlo-sl-condition {
    background: var(--bg);
    border: 1px solid var(--b);
    border-right: 3px solid var(--o);
    padding: 10px;
    margin-top: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'Share Tech Mono', monospace;
    border-radius: 2px;
}
#pg-tlo .tlo-sl-cond-label {
    font-size: 10px;
    color: var(--t2);
    font-weight: 700;
}
#pg-tlo .tlo-sl-cond-val {
    font-size: 10px;
    color: var(--o);
    font-weight: 900;
}
#pg-tlo .tlo-tf2 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid var(--b);
}
#pg-tlo .tlo-fi {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 10px 4px;
    text-align: center;
    font-family: 'Share Tech Mono', monospace;
    border-radius: 2px;
}
#pg-tlo .tlo-fl {
    display: block;
    font-size: 8px;
    color: var(--t3);
    margin-bottom: 3px;
}
#pg-tlo .tlo-fv {
    display: block;
    font-size: 12px;
    color: var(--t);
    font-weight: 900;
    direction: ltr;
}
#pg-tlo .tlo-ts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    margin-top: 10px;
}
#pg-tlo .tlo-chip {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 6px 4px;
    text-align: center;
    font-family: 'Share Tech Mono', monospace;
    border-radius: 2px;
}
#pg-tlo .tlo-ci {
    display: block;
    font-size: 9px;
    color: var(--t);
    font-weight: 900;
}
#pg-tlo .tlo-cg {
    display: block;
    font-size: 9px;
    color: var(--o);
    font-weight: 700;
    margin-top: 2px;
}
#pg-tlo .tlo-card {
    background: var(--s);
    border: 1px solid var(--b);
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 4px;
}
#pg-tlo .tlo-ct {
    font-size: 13px;
    font-weight: 700;
    color: var(--o);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--b);
    letter-spacing: 0.5px;
    font-family: 'Share Tech Mono', monospace;
}
#pg-tlo .tlo-mxh {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 4px;
    padding: 8px 0;
    border-bottom: 1px solid var(--b);
    margin-bottom: 6px;
    text-align: center;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
}
#pg-tlo .tlo-mxr {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 4px;
    padding: 6px 0;
    border-bottom: 1px solid var(--bg);
    align-items: center;
}
#pg-tlo .tlo-mxt {
    font-size: 10px;
    color: var(--t);
    font-weight: 700;
    font-family: 'Share Tech Mono', monospace;
    padding-right: 4px;
    direction: ltr;
    text-align: left;
}
#pg-tlo .tlo-mxc {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 5px 3px;
    text-align: center;
    font-family: 'Share Tech Mono', monospace;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    border-radius: 2px;
}
#pg-tlo .tlo-step {
    padding: 12px;
    background: var(--bg);
    margin-bottom: 10px;
    border-right: 3px solid var(--b);
    border-radius: 2px;
}
#pg-tlo .tlo-step-t {
    font-size: 11px;
    color: var(--o);
    font-family: 'Share Tech Mono', monospace;
    font-weight: 700;
    margin-bottom: 6px;
}
#pg-tlo .tlo-step-d {
    font-size: 11px;
    color: var(--t);
    line-height: 1.6;
}
#pg-tlo .tlo-step-note {
    padding: 10px;
    background: var(--s);
    border: 1px solid var(--b);
    font-size: 10px;
    color: var(--t3);
    line-height: 1.6;
    text-align: center;
    margin-top: 8px;
    border-radius: 2px;
}
#pg-tlo .tlo-analysis {
    background: var(--bg);
    border: 1px solid var(--b);
    border-right: 4px solid var(--t);
    padding: 18px;
    margin-bottom: 15px;
    border-radius: 4px;
}
#pg-tlo .tlo-at {
    font-size: 11px;
    color: var(--t3);
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 2px;
    margin-bottom: 12px;
    font-weight: bold;
}
#pg-tlo .tlo-atx {
    font-size: 13px;
    color: var(--t);
    line-height: 2;
    text-align: justify;
    margin-bottom: 12px;
    font-family: 'Cairo', sans-serif;
}
#pg-tlo .tlo-disc {
    margin-top: 12px;
    padding: 12px;
    background: var(--bg);
    border: 1px solid var(--b);
    font-size: 10px;
    color: var(--t3);
    line-height: 1.7;
    text-align: justify;
    font-family: 'Cairo', sans-serif;
    border-radius: 2px;
}
#pg-tlo .tlo-guide {
    background: var(--bg);
    border: 1px solid var(--b);
    padding: 15px;
    margin-top: 20px;
    border-radius: 4px;
    border-right: 3px solid var(--o);
}
#pg-tlo .tlo-gt {
    font-size: 12px;
    color: var(--o);
    font-weight: 700;
    margin-bottom: 10px;
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 0.5px;
}
#pg-tlo .tlo-gx {
    font-size: 12px;
    color: var(--t2);
    line-height: 1.8;
    font-family: 'Cairo', sans-serif;
    text-align: justify;
}

  /* FLASH Scalping Engine — Visual Architecture */
#pg-flash .fl-input-full {
    width: 100%;
    background: var(--bg);
    border: 2px solid var(--b);
    color: var(--t);
    padding: 14px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 16px;
    text-align: center;
    letter-spacing: 3px;
    margin-bottom: 10px;
    border-radius: 4px;
}
#pg-flash .fl-input-full:focus {
    border-color: var(--o);
    outline: none;
}
#pg-flash .fl-tier-badge {
    display: inline-block;
    font-size: 9px;
    background: var(--o);
    color: var(--bg);
    padding: 5px 14px;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
    letter-spacing: 2px;
    margin-top: 8px;
    border-radius: 2px;
}
#pg-flash .fl-master {
    background: var(--s);
    border: 3px solid var(--t);
    padding: 22px;
    margin-bottom: 18px;
    border-radius: 4px;
}
#pg-flash .fl-master-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--b);
}
#pg-flash .fl-master-label {
    font-size: 10px;
    color: var(--o);
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 3px;
    font-weight: 900;
}
#pg-flash .fl-master-sym {
    font-size: 14px;
    color: var(--t);
    font-family: 'Share Tech Mono', monospace;
    font-weight: 900;
}
#pg-flash .fl-master-body {
    display: flex;
    justify-content: space-between;
