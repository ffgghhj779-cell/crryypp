/* ===== TSA — Time Series Analysis Tool ===== */
#pg-tsa { background: #000; color: #fff; font-family: 'Cairo', sans-serif; direction: rtl; min-height: 100vh; }
.tsa-wrap { padding: 14px; max-width: 900px; margin: 0 auto; }

.tsa-header { border-bottom: 1px solid #1f1f1f; padding-bottom: 14px; margin-bottom: 18px; display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
.tsa-tag { font-size: 11px; color: var(--o); font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin-bottom: 6px; }
.tsa-title { font-size: 22px; font-weight: 700; margin: 0; color: #fff; letter-spacing: 0.5px; }
.tsa-sub { font-size: 11px; color: #888; margin-top: 4px; }
.tsa-badge { border: 1px solid var(--o); padding: 6px 10px; font-family: 'Share Tech Mono', monospace; font-size: 10px; color: var(--o); white-space: nowrap; }

.tsa-input-bar { display: flex; gap: 8px; margin-bottom: 20px; }
.tsa-input-bar input { flex: 1; background: #0a0a0a; border: 1px solid #1f1f1f; color: #fff; padding: 12px 14px; font-family: 'Share Tech Mono', monospace; font-size: 14px; letter-spacing: 2px; outline: none; text-transform: uppercase; }
.tsa-input-bar input:focus { border-color: var(--o); }
.tsa-input-bar button { background: var(--o); color: #000; border: none; padding: 12px 22px; font-family: 'Cairo', sans-serif; font-size: 13px; font-weight: 700; cursor: pointer; letter-spacing: 1px; }
.tsa-input-bar button:disabled { opacity: 0.5; cursor: wait; }

.tsa-status { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: #888; padding: 10px 0; min-height: 18px; letter-spacing: 1px; }
.tsa-status.tsa-error { color: var(--o); }

.tsa-result { display: none; }
.tsa-result.tsa-show { display: block; }

/* SECTION HEADER */
.tsa-section-title { font-size: 12px; color: var(--o); font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin-bottom: 10px; border-bottom: 1px solid #1f1f1f; padding-bottom: 6px; margin-top: 22px; }
.tsa-section-title:first-of-type { margin-top: 0; }

/* MASTER VERDICT CARD */
.tsa-master { border: 1px solid; background: #0a0a0a; padding: 20px; margin-bottom: 18px; position: relative; }
.tsa-master-up { border-color: #fff; }
.tsa-master-dn { border-color: var(--o); }
.tsa-master-nu { border-color: #888; }
.tsa-master-label { position: absolute; top: 0; right: 0; color: #000; padding: 4px 12px; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 2px; }
.tsa-master-up .tsa-master-label { background: #fff; }
.tsa-master-dn .tsa-master-label { background: var(--o); }
.tsa-master-nu .tsa-master-label { background: #888; }

.tsa-master-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 14px; }
@media (max-width: 600px) { .tsa-master-grid { grid-template-columns: 1fr; gap: 16px; } }

.tsa-mk-label { color: #888; font-size: 10px; font-family: 'Share Tech Mono', monospace; letter-spacing: 1px; margin-bottom: 6px; }
.tsa-bias-name { font-size: 38px; font-weight: 700; line-height: 1; font-family: 'Cairo', sans-serif; }
.tsa-bias-en { font-size: 11px; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin-top: 4px; }
.tsa-up { color: #fff; }
.tsa-dn { color: var(--o); }
.tsa-nu { color: #888; }

.tsa-strength { margin-top: 16px; }
.tsa-strength-val { display: flex; align-items: baseline; gap: 8px; }
.tsa-strength-num { font-size: 32px; font-family: 'Share Tech Mono', monospace; font-weight: 700; }
.tsa-strength-max { color: #888; font-family: 'Share Tech Mono', monospace; font-size: 12px; }
.tsa-strength-bar { height: 4px; background: #1f1f1f; margin-top: 6px; position: relative; }
.tsa-strength-fill { height: 100%; }

.tsa-model-name { font-size: 22px; color: #fff; font-family: 'Share Tech Mono', monospace; font-weight: 700; letter-spacing: 1px; }
.tsa-model-list { margin-top: 14px; display: grid; gap: 8px; }
.tsa-model-row { display: flex; justify-content: space-between; border-bottom: 1px solid #1f1f1f; padding-bottom: 6px; }
.tsa-model-row:last-child { border: none; padding-bottom: 0; }
.tsa-model-row span:first-child { color: #888; font-size: 11px; }
.tsa-model-row span:last-child { font-family: 'Share Tech Mono', monospace; font-size: 12px; }

.tsa-reason { margin-top: 18px; padding: 12px; background: rgba(255,106,0,0.04); border-right: 2px solid; font-size: 12px; color: #fff; line-height: 1.7; }
.tsa-master-up .tsa-reason { border-color: #fff; background: rgba(255,255,255,0.04); }
.tsa-master-dn .tsa-reason { border-color: var(--o); }
.tsa-master-nu .tsa-reason { border-color: #888; background: rgba(136,136,136,0.04); }

/* KEY LEVELS */
.tsa-keys { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
.tsa-key { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 14px; }
.tsa-key-val { font-family: 'Share Tech Mono', monospace; font-size: 20px; margin-top: 6px; }
.tsa-key-meta { color: #888; font-size: 10px; font-family: 'Share Tech Mono', monospace; margin-top: 4px; }

/* FORECAST TABLES */
.tsa-fcard { border: 1px solid #1f1f1f; background: #0a0a0a; margin-bottom: 14px; }
.tsa-fhead { padding: 10px 14px; border-bottom: 1px solid #1f1f1f; display: flex; justify-content: space-between; align-items: center; }
.tsa-fhead-title { color: #fff; font-family: 'Share Tech Mono', monospace; font-size: 13px; letter-spacing: 1px; }
.tsa-fhead-sub { color: #888; font-size: 10px; font-family: 'Cairo', sans-serif; margin-top: 2px; }
.tsa-fhead-count { color: #888; font-family: 'Share Tech Mono', monospace; font-size: 10px; }
.tsa-ftable-wrap { overflow-x: auto; }
.tsa-ftable { width: 100%; border-collapse: collapse; font-family: 'Share Tech Mono', monospace; font-size: 11px; }
.tsa-ftable th { padding: 8px 10px; text-align: right; color: #888; font-weight: normal; border-bottom: 1px solid #1f1f1f; background: #050505; white-space: nowrap; }
.tsa-ftable th.tsa-th-up { color: #fff; }
.tsa-ftable th.tsa-th-dn { color: var(--o); }
.tsa-ftable td { padding: 7px 10px; border-bottom: 1px solid #1f1f1f; white-space: nowrap; }
.tsa-ftable td:nth-child(1) { color: #888; }
.tsa-ftable td.tsa-up { color: #fff; }
.tsa-ftable td.tsa-dn { color: var(--o); }
.tsa-ftable td .tsa-pct { font-size: 9px; margin-right: 6px; }
.tsa-ftable tr:last-child td { border-bottom: none; }

/* DIAGNOSTIC PANEL */
.tsa-adf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
@media (max-width: 600px) { .tsa-adf-row { grid-template-columns: 1fr; } }
.tsa-adf { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 14px; }
.tsa-adf-row-inner { display: flex; justify-content: space-between; margin-bottom: 4px; font-size: 11px; }
.tsa-adf-row-inner span:first-child { color: #888; }
.tsa-adf-row-inner span:last-child { font-family: 'Share Tech Mono', monospace; font-size: 12px; }
.tsa-adf-decision { font-size: 11px; color: #fff; line-height: 1.6; margin-top: 8px; }

.tsa-chart-card { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 14px; margin-bottom: 10px; }
.tsa-chart-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 8px; }
.tsa-chart-title { color: #fff; font-family: 'Share Tech Mono', monospace; font-size: 12px; letter-spacing: 1px; }
.tsa-chart-sub { color: #888; font-size: 10px; margin-top: 2px; }
.tsa-legend { display: flex; gap: 10px; font-family: 'Share Tech Mono', monospace; font-size: 9px; }
.tsa-legend-item { display: flex; align-items: center; gap: 4px; color: #888; }
.tsa-legend-sw { width: 8px; height: 8px; display: inline-block; }
.tsa-chart-bars { display: flex; align-items: center; gap: 1px; height: 120px; }
.tsa-bar-col { flex: 1 0 auto; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 120px; position: relative; min-width: 8px; }
.tsa-bar-top { height: 50%; display: flex; align-items: flex-end; width: 100%; justify-content: center; }
.tsa-bar-bot { height: 50%; display: flex; align-items: flex-start; width: 100%; justify-content: center; }
.tsa-bar-line { width: 100%; height: 1px; background: #2a2a2a; position: absolute; top: 50%; left: 0; }
.tsa-bar-pos { width: 70%; background: #fff; min-height: 1px; }
.tsa-bar-neg { width: 70%; background: var(--o); min-height: 1px; }
.tsa-bar-ci { width: 100%; height: 1px; background: rgba(255,255,255,0.15); position: absolute; left: 0; border-top: 1px dashed rgba(255,255,255,0.25); }
.tsa-pattern { margin-top: 8px; font-size: 11px; color: #fff; line-height: 1.6; }
.tsa-pattern span { color: #888; font-family: 'Share Tech Mono', monospace; font-size: 10px; }

/* RESIDUAL DIAGNOSTICS */
.tsa-resid-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
@media (max-width: 600px) { .tsa-resid-row { grid-template-columns: 1fr; } }
.tsa-resid-card { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 14px; }
.tsa-resid-note { margin-top: 8px; padding: 6px 10px; background: rgba(255,255,255,0.04); border-right: 2px solid #fff; font-size: 11px; }
.tsa-resid-note.tsa-warn { background: rgba(255,106,0,0.04); border-color: var(--o); }
.tsa-quality { border: 1px solid; background: #0a0a0a; padding: 14px; margin-top: 10px; display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
.tsa-quality-up { border-color: #fff; }
.tsa-quality-dn { border-color: var(--o); }
.tsa-quality-name { font-family: 'Share Tech Mono', monospace; font-size: 18px; margin-top: 4px; }
.tsa-quality-desc { font-size: 11px; line-height: 1.7; max-width: 60%; }
@media (max-width: 600px) { .tsa-quality-desc { max-width: 100%; } }

/* READING GUIDE */
.tsa-guide { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 16px; line-height: 1.9; font-size: 12px; }
.tsa-guide-block { margin-bottom: 14px; }
.tsa-guide-block:last-child { margin-bottom: 0; }
.tsa-guide-h { color: var(--o); font-family: 'Share Tech Mono', monospace; font-size: 11px; letter-spacing: 1px; }
.tsa-guide-p { margin-top: 4px; color: #fff; }

/* DISCLAIMER */
.tsa-disc { border: 1px solid var(--o); background: rgba(255,106,0,0.04); padding: 14px; font-size: 11px; line-height: 1.8; color: #fff; margin-top: 18px; }
.tsa-disc-h { color: var(--o); font-family: 'Share Tech Mono', monospace; font-size: 11px; letter-spacing: 2px; margin-bottom: 8px; }

/* FOOTER */
.tsa-footer { margin-top: 20px; text-align: center; color: #555; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 2px; padding-bottom: 30px; }

/* ===== CCD — Current Candle Decoder ===== */
#pg-ccd { background: #000; color: #fff; font-family: 'Cairo', sans-serif; direction: rtl; min-height: 100vh; }
.ccd-wrap { padding: 14px; max-width: 900px; margin: 0 auto; }

.ccd-header { border-bottom: 1px solid #1f1f1f; padding-bottom: 14px; margin-bottom: 18px; display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
.ccd-tag { font-size: 11px; color: var(--o); font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin-bottom: 6px; }
.ccd-title { font-size: 22px; font-weight: 700; margin: 0; color: #fff; letter-spacing: 0.5px; }
.ccd-sub { font-size: 11px; color: #888; margin-top: 4px; }
.ccd-badge { border: 1px solid var(--o); padding: 6px 10px; font-family: 'Share Tech Mono', monospace; font-size: 10px; color: var(--o); white-space: nowrap; }

.ccd-input-bar { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
.ccd-input-bar input { flex: 1 1 140px; background: #0a0a0a; border: 1px solid #1f1f1f; color: #fff; padding: 12px 14px; font-family: 'Share Tech Mono', monospace; font-size: 14px; letter-spacing: 2px; outline: none; text-transform: uppercase; }
.ccd-input-bar input:focus { border-color: var(--o); }
.ccd-input-bar select { background: #0a0a0a; border: 1px solid #1f1f1f; color: #fff; padding: 12px 14px; font-family: 'Share Tech Mono', monospace; font-size: 14px; letter-spacing: 1px; outline: none; cursor: pointer; }
.ccd-input-bar button { background: var(--o); color: #000; border: none; padding: 12px 22px; font-family: 'Cairo', sans-serif; font-size: 13px; font-weight: 700; cursor: pointer; letter-spacing: 1px; }
.ccd-input-bar button:disabled { opacity: 0.5; cursor: wait; }
.ccd-refresh-btn { background: transparent !important; color: #fff !important; border: 1px solid #1f1f1f !important; padding: 12px 18px !important; font-family: 'Share Tech Mono', monospace !important; font-size: 11px !important; letter-spacing: 1px; }
.ccd-refresh-btn:hover { border-color: var(--o) !important; }

.ccd-status { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: #888; padding: 10px 0; min-height: 18px; letter-spacing: 1px; }
.ccd-status.ccd-error { color: var(--o); }
.ccd-status.ccd-cached { color: #fff; }

.ccd-result { display: none; }
.ccd-result.ccd-show { display: block; }

/* TIMER BAR */
.ccd-timer { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 12px 14px; margin-bottom: 18px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
.ccd-timer-left { display: flex; gap: 14px; align-items: center; }
.ccd-pulse { width: 8px; height: 8px; background: var(--o); border-radius: 50%; animation: ccdPulse 2s infinite; }
@keyframes ccdPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
.ccd-timer-label { font-family: 'Share Tech Mono', monospace; font-size: 12px; color: #fff; }
.ccd-timer-right { display: flex; gap: 14px; font-family: 'Share Tech Mono', monospace; font-size: 11px; }
.ccd-timer-right span { color: #888; }
.ccd-timer-right span span { color: #fff; }
.ccd-timer-right .ccd-time-left span { color: var(--o); }

/* SECTION HEADER */
.ccd-section { font-size: 12px; color: var(--o); font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin: 22px 0 10px; border-bottom: 1px solid #1f1f1f; padding-bottom: 6px; }
.ccd-section:first-of-type { margin-top: 0; }

/* MASTER VERDICT */
.ccd-master { border: 1px solid; background: #0a0a0a; padding: 20px; margin-bottom: 18px; position: relative; }
.ccd-master-up { border-color: #fff; }
.ccd-master-dn { border-color: var(--o); }
.ccd-master-nu { border-color: #888; }
.ccd-master-label { position: absolute; top: 0; right: 0; color: #000; padding: 4px 12px; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 2px; }
.ccd-master-up .ccd-master-label { background: #fff; }
.ccd-master-dn .ccd-master-label { background: var(--o); }
.ccd-master-nu .ccd-master-label { background: #888; }

.ccd-master-grid { display: grid; grid-template-columns: 1fr 200px; gap: 20px; margin-top: 14px; }
@media (max-width: 600px) { .ccd-master-grid { grid-template-columns: 1fr; } }

.ccd-mk-label { color: #888; font-size: 10px; font-family: 'Share Tech Mono', monospace; letter-spacing: 1px; margin-bottom: 6px; }
.ccd-verdict-name { font-size: 28px; font-weight: 700; line-height: 1; font-family: 'Cairo', sans-serif; }
.ccd-verdict-en { font-size: 11px; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin-top: 4px; }
.ccd-up { color: #fff; }
.ccd-dn { color: var(--o); }
.ccd-nu { color: #888; }

.ccd-strength { margin-top: 16px; }
.ccd-strength-val { display: flex; align-items: baseline; gap: 8px; }
.ccd-strength-num { font-size: 24px; font-family: 'Share Tech Mono', monospace; font-weight: 700; }
.ccd-strength-max { color: #888; font-family: 'Share Tech Mono', monospace; font-size: 12px; }
.ccd-strength-bar { height: 4px; background: #1f1f1f; margin-top: 6px; }
.ccd-strength-fill { height: 100%; }

.ccd-summary-box { margin-top: 16px; padding: 12px; background: rgba(255,255,255,0.04); border-right: 2px solid; font-size: 12px; line-height: 1.7; }
.ccd-master-up .ccd-summary-box { border-color: #fff; }
.ccd-master-dn .ccd-summary-box { border-color: var(--o); background: rgba(255,106,0,0.04); }
.ccd-master-nu .ccd-summary-box { border-color: #888; background: rgba(136,136,136,0.04); }

/* CANDLE VISUAL */
.ccd-candle-card { background: #000; border: 1px solid #1f1f1f; padding: 14px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.ccd-candle-label { color: #888; font-size: 9px; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin-bottom: 12px; }
.ccd-candle-vis { display: flex; flex-direction: column; align-items: center; height: 140px; width: 60px; position: relative; }
.ccd-wick { width: 2px; }
.ccd-body { width: 36px; }
.ccd-wick-up, .ccd-body-up { background: #fff; }
.ccd-wick-up + .ccd-body { border: 1px solid #fff; }
.ccd-wick-dn, .ccd-body-dn { background: var(--o); }
.ccd-wick-dn + .ccd-body { border: 1px solid var(--o); }
.ccd-candle-info { margin-top: 12px; text-align: center; font-family: 'Share Tech Mono', monospace; font-size: 11px; }
.ccd-candle-price { color: #fff; font-weight: 700; font-size: 14px; }
.ccd-candle-pct { color: #888; font-size: 9px; margin-top: 2px; }

/* OHLC */
.ccd-ohlc { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 18px; }
.ccd-ohlc-card { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 12px; }
.ccd-ohlc-card.ccd-live { border-color: #fff; }
.ccd-ohlc-label { color: #888; font-size: 10px; font-family: 'Share Tech Mono', monospace; letter-spacing: 1px; }
.ccd-ohlc-val { font-family: 'Share Tech Mono', monospace; font-size: 15px; margin-top: 6px; color: #fff; }
.ccd-ohlc-val.ccd-dn { color: var(--o); }
.ccd-ohlc-val.ccd-live-val { font-weight: 700; }

/* CONTENT CARDS */
.ccd-card { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 16px; margin-bottom: 18px; }
.ccd-card-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
.ccd-card-title { color: #fff; font-family: 'Cairo', sans-serif; font-size: 18px; font-weight: 700; }
.ccd-card-en { color: #888; font-family: 'Share Tech Mono', monospace; font-size: 11px; letter-spacing: 1px; margin-top: 2px; }
.ccd-card-tag { padding: 4px 10px; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 2px; }
.ccd-tag-strong { background: #fff; color: #000; }
.ccd-tag-mod { background: #888; color: #000; }
.ccd-tag-weak { background: #1f1f1f; color: #fff; border: 1px solid #2a2a2a; }

.ccd-card-desc { padding: 12px; background: rgba(255,255,255,0.04); border-right: 2px solid #fff; font-size: 12px; line-height: 1.7; margin-bottom: 14px; }
.ccd-card-desc.ccd-orange { background: rgba(255,106,0,0.04); border-right-color: var(--o); }

/* DETAIL GRID */
.ccd-detail-grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
.ccd-detail-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
@media (max-width: 600px) {
  .ccd-detail-grid-3 { grid-template-columns: repeat(2, 1fr); }
}
.ccd-detail-row { padding: 10px; background: #000; border: 1px solid #1f1f1f; display: flex; justify-content: space-between; align-items: center; }
.ccd-detail-label { color: #fff; font-size: 12px; }
.ccd-detail-note { color: #888; font-size: 10px; margin-top: 2px; }
.ccd-detail-val { font-family: 'Share Tech Mono', monospace; font-size: 14px; font-weight: 700; }
.ccd-detail-cell { padding: 10px; background: #000; border: 1px solid #1f1f1f; }
.ccd-detail-cell-label { color: #888; font-size: 10px; font-family: 'Share Tech Mono', monospace; letter-spacing: 1px; }
.ccd-detail-cell-val { font-family: 'Share Tech Mono', monospace; font-size: 13px; margin-top: 4px; font-weight: 600; }
.ccd-detail-cell-meta { color: #555; font-size: 10px; margin-top: 2px; }

/* VOLUME BAR */
.ccd-vol-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 14px; }
.ccd-vol-ratio { font-family: 'Share Tech Mono', monospace; font-size: 22px; font-weight: 700; }
.ccd-vol-labels { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 10px; font-family: 'Share Tech Mono', monospace; color: #888; }
.ccd-vol-bar { height: 24px; background: #000; border: 1px solid #1f1f1f; position: relative; margin-bottom: 4px; }
.ccd-vol-avg-line { position: absolute; left: 50%; top: -4px; bottom: -4px; width: 1px; background: #888; transform: translateX(-50%); }
.ccd-vol-fill { height: 100%; opacity: 0.85; }
.ccd-vol-numbers { display: flex; justify-content: space-between; margin-top: 4px; font-size: 10px; font-family: 'Share Tech Mono', monospace; color: #555; }
.ccd-vol-numbers span:last-child { color: #fff; }

/* FORECAST */
.ccd-forecast-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
@media (max-width: 600px) { .ccd-forecast-grid { grid-template-columns: 1fr; } }
.ccd-forecast-num { font-family: 'Share Tech Mono', monospace; font-size: 24px; font-weight: 700; margin-top: 6px; }
.ccd-forecast-range { color: #888; font-size: 10px; font-family: 'Share Tech Mono', monospace; margin-top: 4px; }
.ccd-forecast-bias { font-family: 'Cairo', sans-serif; font-size: 18px; font-weight: 700; margin-top: 6px; }
.ccd-forecast-prob { margin-top: 10px; display: flex; align-items: baseline; gap: 6px; }
.ccd-forecast-prob-label { color: #888; font-size: 10px; font-family: 'Share Tech Mono', monospace; }
.ccd-forecast-prob-val { color: #fff; font-family: 'Share Tech Mono', monospace; font-size: 16px; font-weight: 700; }

/* HISTORICAL STATS */
.ccd-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 12px; }
@media (max-width: 600px) { .ccd-stats-grid { grid-template-columns: repeat(2, 1fr); } }
.ccd-stat { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 12px; }
.ccd-stat-label { color: #888; font-size: 10px; font-family: 'Share Tech Mono', monospace; letter-spacing: 1px; }
.ccd-stat-val { font-family: 'Share Tech Mono', monospace; font-size: 18px; font-weight: 700; margin-top: 6px; }
.ccd-stat-sub { color: #555; font-size: 9px; margin-top: 2px; }

/* TABLE */
.ccd-table-wrap { border: 1px solid #1f1f1f; background: #0a0a0a; margin-bottom: 18px; overflow: hidden; }
.ccd-table-scroll { overflow-x: auto; }
.ccd-table { width: 100%; border-collapse: collapse; font-family: 'Share Tech Mono', monospace; font-size: 11px; }
.ccd-table th { padding: 10px; text-align: right; color: #888; font-weight: normal; border-bottom: 1px solid #1f1f1f; background: #050505; white-space: nowrap; }
.ccd-table td { padding: 10px; border-bottom: 1px solid #1f1f1f; white-space: nowrap; }
.ccd-table tr:last-child td { border-bottom: none; }
.ccd-similarity { display: inline-block; padding: 2px 6px; background: #000; border: 1px solid #1f1f1f; color: #fff; font-size: 10px; }
.ccd-result-bullish { color: #fff; }
.ccd-result-bearish { color: var(--o); }
.ccd-result-mixed { color: #888; }
.ccd-table-date-sub { color: #555; font-size: 9px; margin-top: 2px; }

/* READING GUIDE */
.ccd-guide { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 16px; line-height: 1.9; font-size: 12px; margin-bottom: 18px; }
.ccd-guide-block { margin-bottom: 14px; }
.ccd-guide-block:last-child { margin-bottom: 0; }
.ccd-guide-h { color: var(--o); font-family: 'Share Tech Mono', monospace; font-size: 11px; letter-spacing: 1px; }
.ccd-guide-p { margin-top: 4px; color: #fff; }

/* DISCLAIMER */
.ccd-disc { border: 1px solid var(--o); background: rgba(255,106,0,0.04); padding: 14px; font-size: 11px; line-height: 1.8; color: #fff; }
.ccd-disc-h { color: var(--o); font-family: 'Share Tech Mono', monospace; font-size: 11px; letter-spacing: 2px; margin-bottom: 8px; }

/* FOOTER */
.ccd-footer { margin-top: 20px; text-align: center; color: #555; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 2px; padding-bottom: 30px; }

  /* ===== PDC — Project Data Check ===== */
#pg-pdc { background: #000; color: #fff; font-family: 'Cairo', sans-serif; direction: rtl; min-height: 100vh; }
.pdc-wrap { padding: 14px; max-width: 900px; margin: 0 auto; }

.pdc-header { border-bottom: 1px solid #1f1f1f; padding-bottom: 14px; margin-bottom: 16px; display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
.pdc-tag { font-size: 11px; color: var(--o); font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin-bottom: 6px; }
.pdc-title { font-size: 22px; font-weight: 700; margin: 0; color: #fff; }
.pdc-sub { font-size: 11px; color: #888; margin-top: 4px; }
.pdc-badge { border: 1px solid var(--o); padding: 6px 10px; font-family: 'Share Tech Mono', monospace; font-size: 10px; color: var(--o); white-space: nowrap; letter-spacing: 1px; }

.pdc-input-bar { display: flex; gap: 8px; margin-bottom: 14px; }
.pdc-input-bar input { flex: 1; background: #0a0a0a; border: 1px solid #1f1f1f; color: #fff; padding: 12px 14px; font-family: 'Share Tech Mono', monospace; font-size: 14px; letter-spacing: 2px; outline: none; text-transform: uppercase; }
.pdc-input-bar input:focus { border-color: var(--o); }
.pdc-input-bar button { background: var(--o); color: #000; border: none; padding: 12px 22px; font-family: 'Cairo', sans-serif; font-size: 13px; font-weight: 700; cursor: pointer; letter-spacing: 1px; }
.pdc-input-bar button:disabled { opacity: 0.5; cursor: wait; }

.pdc-status { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: #888; padding: 8px 0; min-height: 18px; letter-spacing: 1px; }
.pdc-status.pdc-error { color: var(--o); }

.pdc-result { display: none; }
.pdc-result.pdc-show { display: block; }

/* SECTION TITLE */
.pdc-section { font-size: 11px; color: var(--o); font-family: 'Share Tech Mono', monospace; letter-spacing: 3px; margin: 24px 0 10px; border-bottom: 1px solid #1f1f1f; padding-bottom: 8px; font-weight: 700; }
.pdc-section:first-of-type { margin-top: 8px; }

/* BLOCK HEADER */
.pdc-block-head { padding: 10px 14px; background: #050505; border: 1px solid #1f1f1f; border-bottom: none; font-family: 'Share Tech Mono', monospace; font-size: 11px; color: #fff; letter-spacing: 2px; }
.pdc-block-head.pdc-orange { color: var(--o); border-color: var(--o); }
.pdc-block-head.pdc-white { color: #fff; border-color: #fff; }

/* TABLES */
.pdc-table { width: 100%; border-collapse: collapse; font-family: 'Share Tech Mono', monospace; font-size: 12px; border: 1px solid #1f1f1f; background: #0a0a0a; margin-bottom: 12px; }
.pdc-table.pdc-no-border-top { border-top: none; }
.pdc-table.pdc-orange-border { border-color: var(--o); }
.pdc-table.pdc-white-border { border-color: #fff; }
.pdc-table thead tr { background: #050505; }
.pdc-table th { padding: 11px 14px; color: #888; font-weight: normal; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 1px; border-bottom: 1px solid #1f1f1f; }
.pdc-table th.pdc-th-right { text-align: right; }
.pdc-table th.pdc-th-left { text-align: left; }
.pdc-table td { padding: 11px 14px; border-bottom: 1px solid #1f1f1f; }
.pdc-table tr:last-child td { border-bottom: none; }

.pdc-cell-label { color: #888; font-family: 'Cairo', sans-serif; font-size: 13px; text-align: right; }
.pdc-cell-value { color: #fff; font-family: 'Share Tech Mono', monospace; font-size: 13px; text-align: left; font-weight: 700; }
.pdc-cell-value.pdc-orange { color: var(--o); }
.pdc-cell-meta { color: #888; font-family: 'Share Tech Mono', monospace; font-size: 11px; text-align: left; }
.pdc-cell-meta.pdc-orange { color: var(--o); }
.pdc-cell-meta.pdc-white { color: #fff; }

/* MASTER VERDICT BOX */
.pdc-master { border: 2px solid #fff; background: #0a0a0a; padding: 20px; margin-bottom: 12px; }
.pdc-master.pdc-master-orange { border-color: var(--o); }
.pdc-master-top { display: flex; justify-content: space-between; align-items: baseline; padding-bottom: 14px; border-bottom: 1px solid #1f1f1f; margin-bottom: 14px; flex-wrap: wrap; gap: 12px; }
.pdc-master-grade-label { font-size: 10px; color: #888; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; }
.pdc-master-grade { font-size: 64px; font-weight: 700; color: #fff; font-family: 'Share Tech Mono', monospace; line-height: 1; margin-top: 4px; }
.pdc-master-grade.pdc-orange { color: var(--o); }
.pdc-master-trust { padding: 4px 10px; background: #fff; color: #000; display: inline-block; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 2px; font-weight: 700; margin-top: 8px; }
.pdc-master-trust.pdc-orange { background: var(--o); }
.pdc-master-score-block { text-align: left; }
.pdc-master-score-label { font-size: 10px; color: #888; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; }
.pdc-master-score-num { font-size: 52px; font-weight: 700; color: #fff; font-family: 'Share Tech Mono', monospace; }
.pdc-master-score-num.pdc-orange { color: var(--o); }
.pdc-master-score-max { font-size: 20px; color: #888; font-family: 'Share Tech Mono', monospace; margin-right: 6px; }
.pdc-master-trust-ar { font-size: 11px; color: #fff; font-weight: 600; margin-top: 8px; text-align: left; font-family: 'Cairo', sans-serif; }

.pdc-verdict-text { font-size: 13px; color: #fff; line-height: 1.8; margin-bottom: 14px; padding: 12px; background: rgba(255,255,255,0.04); border-right: 2px solid #fff; font-family: 'Cairo', sans-serif; }
.pdc-master-orange .pdc-verdict-text { background: rgba(255,106,0,0.04); border-right-color: var(--o); }

/* PILLARS TABLE */
.pdc-pillars { width: 100%; border-collapse: collapse; }
.pdc-pillars tr td { padding: 12px 0; border-bottom: 1px solid #1f1f1f; }
.pdc-pillars tr:last-child td { border-bottom: none; }
.pdc-pillar-name { font-family: 'Cairo', sans-serif; font-size: 13px; color: #fff; font-weight: 600; width: 120px; }
.pdc-pillar-en { padding: 12px 14px; font-family: 'Share Tech Mono', monospace; font-size: 10px; color: #888; letter-spacing: 2px; width: 110px; }
.pdc-pillar-bar-cell { padding: 12px 14px; width: 60%; }
.pdc-pillar-bar { height: 6px; background: #1f1f1f; position: relative; }
.pdc-pillar-bar-fill { height: 100%; background: #fff; }
.pdc-pillar-bar-fill.pdc-orange { background: var(--o); }
.pdc-pillar-score { padding: 12px 14px; font-family: 'Share Tech Mono', monospace; font-size: 16px; font-weight: 700; text-align: left; color: #fff; }
.pdc-pillar-score.pdc-orange { color: var(--o); }
.pdc-pillar-score-max { color: #888; font-size: 11px; }

/* FLAGS COUNTER */
.pdc-flags-counter { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid #1f1f1f; background: #0a0a0a; margin-bottom: 12px; }
.pdc-flags-counter > div { padding: 14px; }
.pdc-flags-counter > div:first-child { border-left: 1px solid #1f1f1f; }
.pdc-flags-counter-label { font-size: 10px; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; }
.pdc-flags-counter-num { font-family: 'Share Tech Mono', monospace; font-size: 24px; font-weight: 700; margin-top: 4px; }
.pdc-flags-counter-sub { font-size: 11px; color: #888; margin-top: 2px; font-family: 'Cairo', sans-serif; }

/* STATUS BADGE */
.pdc-status-badge { padding: 3px 8px; font-family: 'Share Tech Mono', monospace; font-size: 9px; letter-spacing: 1px; font-weight: 700; display: inline-block; }
.pdc-badge-white { background: #fff; color: #000; }
.pdc-badge-orange { background: var(--o); color: #000; }
.pdc-badge-dim { background: #888; color: #000; }

/* YES/NO BADGE */
.pdc-yn { padding: 4px 10px; font-family: 'Share Tech Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 1px; display: inline-block; }
.pdc-yn-good { background: #fff; color: #000; }
.pdc-yn-bad { background: var(--o); color: #000; }

/* FLAG ROW */
.pdc-flag-row td { vertical-align: top; }
.pdc-flag-level-cell { padding: 12px 14px; width: 90px; }
.pdc-flag-level { padding: 3px 8px; background: var(--o); color: #000; font-family: 'Share Tech Mono', monospace; font-size: 9px; letter-spacing: 1px; font-weight: 700; }
.pdc-flag-content { padding: 12px 14px; }
.pdc-flag-text { font-size: 13px; font-weight: 700; color: #fff; font-family: 'Cairo', sans-serif; }
.pdc-flag-detail { font-size: 12px; color: #fff; line-height: 1.7; margin-top: 4px; font-family: 'Cairo', sans-serif; }
.pdc-green-bar { width: 4px; height: 20px; background: #fff; }
.pdc-green-bar-cell { padding: 12px 14px; width: 40px; }

/* READING GUIDE */
.pdc-guide { border: 1px solid #1f1f1f; background: #0a0a0a; padding: 16px; line-height: 1.9; font-size: 12px; margin-bottom: 14px; }
.pdc-guide-block { margin-bottom: 14px; }
.pdc-guide-block:last-child { margin-bottom: 0; }
.pdc-guide-h { color: var(--o); font-family: 'Share Tech Mono', monospace; font-size: 11px; letter-spacing: 1px; }
.pdc-guide-p { margin-top: 4px; color: #fff; }

/* DISCLAIMER */
.pdc-disc { border: 1px solid var(--o); background: rgba(255,106,0,0.04); padding: 14px; font-size: 11px; line-height: 1.8; color: #fff; }
.pdc-disc-h { color: var(--o); font-family: 'Share Tech Mono', monospace; font-size: 11px; letter-spacing: 2px; margin-bottom: 8px; }

/* FOOTER */
.pdc-footer { margin-top: 20px; text-align: center; color: #555; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 2px; padding-bottom: 30px; }

/* MOBILE */
@media (max-width: 600px) {
  .pdc-master-top { flex-direction: column; align-items: flex-start; }
  .pdc-master-score-block { text-align: right; }
  .pdc-master-score-num { font-size: 42px; }
  .pdc-master-grade { font-size: 52px; }
}

/* ===== SCA — Smart Contract Audit ===== */
#pg-sca { background: #000; color: #fff; font-family: 'Cairo', sans-serif; direction: rtl; min-height: 100vh; }
.sca-wrap { padding: 14px; max-width: 900px; margin: 0 auto; }

.sca-header { border-bottom: 1px solid #1f1f1f; padding-bottom: 14px; margin-bottom: 16px; display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
.sca-tag { font-size: 11px; color: var(--o); font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; margin-bottom: 6px; }
.sca-title { font-size: 22px; font-weight: 700; margin: 0; color: #fff; }
.sca-sub { font-size: 11px; color: #888; margin-top: 4px; }
.sca-badge { border: 1px solid var(--o); padding: 6px 10px; font-family: 'Share Tech Mono', monospace; font-size: 10px; color: var(--o); white-space: nowrap; letter-spacing: 1px; }

.sca-input-bar { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
.sca-input-bar input { flex: 1 1 140px; background: #0a0a0a; border: 1px solid #1f1f1f; color: #fff; padding: 12px 14px; font-family: 'Share Tech Mono', monospace; font-size: 14px; letter-spacing: 2px; outline: none; text-transform: uppercase; }
.sca-input-bar input:focus { border-color: var(--o); }
.sca-input-bar select { background: #0a0a0a; border: 1px solid #1f1f1f; color: #fff; padding: 12px 14px; font-family: 'Share Tech Mono', monospace; font-size: 13px; letter-spacing: 1px; outline: none; cursor: pointer; }
.sca-input-bar button { background: var(--o); color: #000; border: none; padding: 12px 22px; font-family: 'Cairo', sans-serif; font-size: 13px; font-weight: 700; cursor: pointer; letter-spacing: 1px; }
.sca-input-bar button:disabled { opacity: 0.5; cursor: wait; }

.sca-status { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: #888; padding: 8px 0; min-height: 18px; letter-spacing: 1px; }
.sca-status.sca-error { color: var(--o); }

.sca-result { display: none; }
.sca-result.sca-show { display: block; }

/* ===== SECTION TITLE ===== */
.sca-section { font-size: 11px; color: var(--o); font-family: 'Share Tech Mono', monospace; letter-spacing: 3px; margin: 24px 0 10px; border-bottom: 1px solid #1f1f1f; padding-bottom: 8px; font-weight: 700; }
.sca-section:first-of-type { margin-top: 8px; }

/* ===== BLOCK HEADER ===== */
.sca-block-head { padding: 10px 14px; background: #050505; border: 1px solid #1f1f1f; border-bottom: none; font-family: 'Share Tech Mono', monospace; font-size: 11px; color: #fff; letter-spacing: 2px; display: flex; justify-content: space-between; align-items: center; gap: 10px; }
.sca-block-head.sca-orange-head { color: var(--o); border-color: var(--o); }
.sca-block-head.sca-white-head { color: #fff; border-color: #fff; }
.sca-block-head-right { font-size: 10px; font-weight: 700; }

/* ===== TABLES (مع معالجة التناسق) ===== */
.sca-table {
  width: 100%;
  border-collapse: collapse;
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px;
  border: 1px solid #1f1f1f;
  background: #0a0a0a;
  border-top: none;
  margin-bottom: 12px;
  table-layout: fixed;
}
.sca-table.sca-orange-border { border-color: var(--o); }
.sca-table.sca-white-border { border-color: #fff; }
.sca-table thead tr { background: #050505; }
.sca-table th {
  padding: 11px 12px;
  color: #888;
  font-weight: normal;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 1px;
  border-bottom: 1px solid #1f1f1f;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.sca-table th.sca-th-right { text-align: right; }
.sca-table th.sca-th-left { text-align: left; }
.sca-table td {
  padding: 11px 12px;
  border-bottom: 1px solid #1f1f1f;
  vertical-align: middle;
  overflow: hidden;
  text-overflow: ellipsis;
}
.sca-table tr:last-child td { border-bottom: none; }

/* ===== CELL TYPES ===== */
.sca-cell-label {
  color: #888;
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  text-align: right;
  word-break: normal;
}
.sca-cell-label-desc {
  color: #555;
  font-size: 10px;
  margin-top: 3px;
  font-family: 'Cairo', sans-serif;
  white-space: normal;
  line-height: 1.4;
}
.sca-cell-en {
  color: #888;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 1px;
  text-align: right;
  white-space: nowrap;
}
.sca-cell-value {
  color: #fff;
  font-family: 'Share Tech Mono', monospace;
  font-size: 13px;
  text-align: left;
  font-weight: 700;
  word-break: break-word;
}
.sca-cell-value.sca-orange { color: var(--o); }
.sca-cell-value.sca-big { font-size: 18px; }
.sca-cell-meta {
  color: #888;
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  text-align: left;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.sca-cell-meta.sca-orange { color: var(--o); }
.sca-cell-meta.sca-white { color: #fff; }
.sca-cell-meta-desc {
  color: #555;
  font-size: 10px;
  margin-top: 3px;
  font-family: 'Cairo', sans-serif;
  white-space: normal;
  line-height: 1.4;
}
.sca-cell-action {
  padding: 11px 12px;
  text-align: left;
  white-space: nowrap;
}
.sca-cell-mono {
  color: #888;
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== YES/NO BADGE ===== */
.sca-yn {
  padding: 4px 10px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  display: inline-block;
  white-space: nowrap;
}
.sca-yn-good { background: #fff; color: #000; }
.sca-yn-bad { background: var(--o); color: #000; }

/* ===== SAFE/RISK LABEL ===== */
.sca-sr {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  letter-spacing: 1px;
  font-weight: 700;
  white-space: nowrap;
}
.sca-sr.sca-safe { color: #fff; }
.sca-sr.sca-risk { color: var(--o); }

/* ===== CRITICAL TAG ===== */
.sca-critical {
  margin-right: 8px;
  padding: 1px 5px;
  background: var(--o);
  color: #000;
  font-family: 'Share Tech Mono', monospace;
  font-size: 8px;
  letter-spacing: 1px;
  white-space: nowrap;
  display: inline-block;
}

/* ===== LOCKED/UNLOCKED BADGE ===== */
.sca-lock {
  padding: 3px 8px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  letter-spacing: 1px;
  font-weight: 700;
  display: inline-block;
  white-space: nowrap;
}
.sca-lock-yes { background: #fff; color: #000; }
.sca-lock-no { background: var(--o); color: #000; }

/* ===== STATUS BADGE (Passed/Failed) ===== */
.sca-status-badge {
  padding: 4px 10px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 1px;
  font-weight: 700;
  white-space: nowrap;
  display: inline-block;
}
.sca-status-passed { background: #fff; color: #000; }
.sca-status-failed { background: var(--o); color: #000; }

/* ===== CEX CHIP ===== */
.sca-cex-chips { display: flex; flex-wrap: wrap; gap: 6px; }
.sca-cex-chip {
  padding: 4px 10px;
  border: 1px solid #1f1f1f;
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  color: #fff;
  letter-spacing: 1px;
  white-space: nowrap;
}

/* ===== FINAL VERDICT BOX ===== */
.sca-master { border: 2px solid #fff; background: #0a0a0a; margin-bottom: 14px; position: relative; }
.sca-master.sca-master-orange { border-color: var(--o); }
.sca-master-tag {
  position: absolute; top: 0; right: 0;
  background: #fff; color: #000;
  padding: 4px 12px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px; letter-spacing: 2px; font-weight: 700;
}
.sca-master-orange .sca-master-tag { background: var(--o); }
.sca-master-inner { padding: 24px 20px; }

.sca-master-top { display: grid; grid-template-columns: 1fr auto; gap: 20px; align-items: center; margin-bottom: 18px; }
.sca-master-status-label { font-size: 10px; color: #888; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; }
.sca-master-status {
  font-size: 28px; font-weight: 700; color: #fff;
  margin-top: 6px; line-height: 1.1;
  font-family: 'Cairo', sans-serif;
}
.sca-master-status.sca-orange { color: var(--o); }
.sca-master-status-en {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px; letter-spacing: 2px;
  color: #fff; margin-top: 6px;
}
.sca-master-status-en.sca-orange { color: var(--o); }

.sca-master-grade-box { text-align: left; min-width: 100px; }
.sca-master-grade-label { font-size: 10px; color: #888; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; }
.sca-master-grade {
  font-size: 64px; font-weight: 700; color: #fff;
  font-family: 'Share Tech Mono', monospace; line-height: 1; margin-top: 4px;
}
.sca-master-grade.sca-orange { color: var(--o); }
.sca-master-score-line {
  font-family: 'Share Tech Mono', monospace;
  font-size: 14px; color: #888; margin-top: 4px;
}

.sca-master-verdict {
  padding: 12px;
  background: rgba(255,255,255,0.04);
  border-right: 2px solid #fff;
  font-size: 13px; color: #fff;
  line-height: 1.8;
  font-family: 'Cairo', sans-serif;
}
.sca-master-orange .sca-master-verdict {
  background: rgba(255,106,0,0.04);
  border-right-color: var(--o);
}

.sca-master-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-top: 16px;
  border-top: 1px solid #1f1f1f;
  padding-top: 16px;
}
.sca-master-stat { text-align: center; }
.sca-master-stat-label {
  font-size: 10px; color: #888;
  font-family: 'Share Tech Mono', monospace;
  letter-spacing: 1px;
}
.sca-master-stat-value {
  font-family: 'Share Tech Mono', monospace;
  font-size: 20px; font-weight: 700;
  color: #fff; margin-top: 4px;
}
.sca-master-stat-value.sca-orange { color: var(--o); }

/* ===== TOTAL ROW (in DEX table) ===== */
.sca-total-row td {
  background: #050505 !important;
  border-top: 1px solid #1f1f1f !important;
  padding: 14px !important;
  font-weight: 700;
}

/* ===== FLAG ROW ===== */
.sca-flag-level {
  padding: 3px 8px;
  background: var(--o); color: #000;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  letter-spacing: 1px;
  font-weight: 700;
  white-space: nowrap;
}
.sca-flag-bar {
  width: 4px;
  height: 20px;
  background: #fff;
}
.sca-flag-text {
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  font-family: 'Cairo', sans-serif;
}
.sca-flag-detail {
  font-size: 12px;
  color: #fff;
  line-height: 1.7;
  margin-top: 4px;
  font-family: 'Cairo', sans-serif;
}

/* ===== NO RED FLAGS BLOCK ===== */
.sca-no-flags {
  border: 1px solid #fff;
  background: rgba(255,255,255,0.04);
  padding: 14px;
  font-size: 12px;
  color: #fff;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 14px;
}
.sca-no-flags-badge {
  padding: 4px 10px;
  background: #fff; color: #000;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  font-weight: 700;
  white-space: nowrap;
}

/* ===== NO AUDITS BLOCK ===== */
.sca-no-audits {
  border: 1px solid var(--o);
  background: rgba(255,106,0,0.04);
  padding: 14px;
  font-size: 12px;
  color: #fff;
  margin-bottom: 12px;
}
.sca-no-audits-title {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  color: var(--o);
  letter-spacing: 2px;
  margin-bottom: 6px;
}

/* ===== READING GUIDE ===== */
.sca-guide {
  border: 1px solid #1f1f1f;
  background: #0a0a0a;
  padding: 16px;
  line-height: 1.9;
  font-size: 12px;
  margin-bottom: 14px;
}
.sca-guide-block { margin-bottom: 14px; }
.sca-guide-block:last-child { margin-bottom: 0; }
.sca-guide-h {
  color: var(--o);
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  letter-spacing: 1px;
}
.sca-guide-p {
  margin-top: 4px;
  color: #fff;
}

/* ===== DISCLAIMER ===== */
.sca-disc {
  border: 1px solid var(--o);
  background: rgba(255,106,0,0.04);
  padding: 14px;
  font-size: 11px;
  line-height: 1.8;
  color: #fff;
}
.sca-disc-h {
  color: var(--o);
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  margin-bottom: 8px;
}

/* ===== FOOTER ===== */
.sca-footer {
  margin-top: 20px;
  text-align: center;
  color: #555;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  padding-bottom: 30px;
}

/* ===== MOBILE RESPONSIVE ===== */
@media (max-width: 600px) {
  .sca-master-top { grid-template-columns: 1fr; }
  .sca-master-grade-box { text-align: right; }
  .sca-master-grade { font-size: 52px; }
  .sca-master-status { font-size: 22px; }
  .sca-master-stats { grid-template-columns: repeat(2, 1fr); }
  .sca-master-stat-value { font-size: 18px; }
  .sca-table { font-size: 11px; }
  .sca-table td, .sca-table th { padding: 9px 8px; }
  .sca-cell-label { font-size: 12px; }
  .sca-cell-value { font-size: 12px; }
  .sca-cell-meta { font-size: 10px; }
}

 /* ===== STB — Stablecoins Analytics ===== */
#pg-stb {
  background: #000;
  color: #fff;
  font-family: 'Cairo', sans-serif;
  direction: rtl;
  min-height: 100vh;
}
.stb-wrap { padding: 14px; max-width: 900px; margin: 0 auto; }

/* HEADER */
.stb-header {
  border-bottom: 2px solid var(--o);
  padding-bottom: 12px;
  margin-bottom: 14px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 12px;
}
.stb-tag {
  font-size: 10px;
  color: var(--o);
  font-family: 'Share Tech Mono', monospace;
  letter-spacing: 3px;
  margin-bottom: 4px;
}
.stb-title { font-size: 22px; font-weight: 700; margin: 0; color: #fff; }
.stb-header-meta {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: #888;
  text-align: left;
  line-height: 1.5;
  white-space: nowrap;
}
.stb-header-meta span { color: var(--o); }

/* STATUS */
.stb-status {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  color: #888;
  padding: 8px 0;
  min-height: 18px;
  letter-spacing: 1px;
}
.stb-status.stb-error { color: var(--o); }

/* RESULT */
.stb-result { display: none; }
.stb-result.stb-show { display: block; }

/* SECTION TITLE */
.stb-section {
  font-size: 11px;
  color: var(--o);
  font-family: 'Share Tech Mono', monospace;
  letter-spacing: 3px;
  margin: 20px 0 8px;
  border-bottom: 1px solid #1f1f1f;
  padding-bottom: 8px;
  font-weight: 700;
}

/* BLOOMBERG PANEL */
.stb-panel {
  background: #0a0a0a;
  border: 1px solid #1f1f1f;
  margin-bottom: 12px;
}
.stb-panel-head {
  height: 32px;
  padding: 0 14px;
  background: #050505;
  border-bottom: 1px solid #1f1f1f;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: #888;
  letter-spacing: 2px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.stb-panel-head-right { color: #fff; font-weight: 700; }
.stb-panel-head-right.stb-orange { color: var(--o); }

/* BLOOMBERG LABEL */
.stb-label {
  font-size: 9px;
  color: #888;
  font-family: 'Share Tech Mono', monospace;
  letter-spacing: 1.5px;
  text-transform: uppercase;
}
.stb-label-ar {
  font-size: 10px;
  color: #555;
  margin-top: 4px;
  font-family: 'Cairo', sans-serif;
}

/* BLOOMBERG VALUE */
.stb-value-big {
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  font-size: 20px;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}
.stb-value-big.stb-orange { color: var(--o); }
.stb-value-sub {
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  font-size: 11px;
  color: #888;
  margin-top: 6px;
}
.stb-value-sub.stb-orange { color: var(--o); }
.stb-value-sub.stb-white { color: #fff; }

/* TICKER STRIP */
.stb-ticker {
  background: #050505;
  border: 1px solid #1f1f1f;
  margin-bottom: 14px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
}
.stb-ticker-cell {
  padding: 14px;
  border-right: 1px solid #1f1f1f;
}
.stb-ticker-cell:last-child { border-right: none; }
.stb-ticker-cell .stb-label { margin-bottom: 6px; }
.stb-ticker-cell .stb-value-big { margin-top: 0; }

/* MASTER VERDICT */
.stb-master {
  background: #0a0a0a;
  margin-bottom: 14px;
  position: relative;
  border: 2px solid #fff;
}
.stb-master.stb-master-orange { border-color: var(--o); }
.stb-master-tag {
  position: absolute;
  top: 0;
  right: 0;
  background: #fff;
  color: #000;
  padding: 4px 14px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  font-weight: 700;
}
.stb-master.stb-master-orange .stb-master-tag { background: var(--o); }
.stb-master-inner { padding: 24px 20px; }
.stb-master-top {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 20px;
  align-items: center;
  margin-bottom: 16px;
}
.stb-master-signal {
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  margin-top: 6px;
  line-height: 1.1;
  font-family: 'Cairo', sans-serif;
}
.stb-master-signal.stb-orange { color: var(--o); }
.stb-master-signal-en {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  color: #fff;
  margin-top: 6px;
}
.stb-master-signal-en.stb-orange { color: var(--o); }
.stb-master-score-box { text-align: left; min-width: 110px; }
.stb-master-score {
  font-size: 46px;
  font-weight: 700;
  color: #fff;
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  margin-top: 4px;
}
.stb-master-score.stb-orange { color: var(--o); }
.stb-master-score-range {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: #888;
  margin-top: 4px;
}
.stb-master-verdict {
  padding: 14px;
  background: rgba(255,255,255,0.04);
  border-right: 2px solid #fff;
  font-size: 13px;
  color: #fff;
  line-height: 1.8;
  font-family: 'Cairo', sans-serif;
}
.stb-master.stb-master-orange .stb-master-verdict {
  background: rgba(255,106,0,0.04);
  border-right-color: var(--o);
}

/* ISSUANCE PANEL */
.stb-issuance-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
}
.stb-issuance-cell {
  padding: 16px;
  border-right: 1px solid #1f1f1f;
}
.stb-issuance-cell:last-child { border-right: none; }
.stb-issuance-period {
  font-size: 9px;
  color: #888;
  font-family: 'Share Tech Mono', monospace;
  letter-spacing: 1.5px;
}
.stb-issuance-period-ar {
  font-size: 10px;
  color: #555;
  margin-top: 4px;
  font-family: 'Cairo', sans-serif;
}
.stb-issuance-net-label {
  font-size: 9px;
  color: #888;
  font-family: 'Share Tech Mono', monospace;
  letter-spacing: 1px;
  margin-top: 14px;
}
.stb-issuance-net {
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  font-size: 22px;
  font-weight: 700;
  color: #fff;
  margin-top: 4px;
  line-height: 1;
}
.stb-issuance-net.stb-orange { color: var(--o); }
.stb-issuance-bar {
  display: flex;
  height: 24px;
  margin-top: 14px;
  margin-bottom: 10px;
  border: 1px solid #1f1f1f;
}
.stb-issuance-bar-mint {
  background: #fff;
  color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  overflow: hidden;
}
.stb-issuance-bar-burn {
  background: var(--o);
  color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  overflow: hidden;
}
.stb-issuance-amounts {
  display: flex;
  justify-content: space-between;
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  font-size: 11px;
}
.stb-issuance-amount-label {
  color: #888;
  font-size: 9px;
}
.stb-issuance-amount-mint {
  color: #fff;
  font-weight: 700;
  margin-top: 2px;
}
.stb-issuance-amount-burn {
  color: var(--o);
  font-weight: 700;
  margin-top: 2px;
}

/* TOP EVENTS */
.stb-events-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 12px;
}
@media (max-width: 600px) {
  .stb-events-grid { grid-template-columns: 1fr; }
}
.stb-event-row {
  padding: 10px 14px;
  border-bottom: 1px solid #161616;
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 12px;
  align-items: center;
}
.stb-event-row:last-child { border-bottom: none; }
.stb-event-date {
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  font-size: 10px;
  color: #888;
}
.stb-event-coin {
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px;
  color: #fff;
  font-weight: 700;
}
.stb-event-chain {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: #888;
}
.stb-event-amount {
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  font-size: 14px;
  font-weight: 700;
}
.stb-event-amount.stb-mint { color: #fff; }
.stb-event-amount.stb-burn { color: var(--o); }

/* TABLES */
.stb-table {
  width: 100%;
  border-collapse: collapse;
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  table-layout: fixed;
}
.stb-table thead tr { background: #050505; }
.stb-table th {
  height: 32px;
  padding: 0 12px;
  color: #888;
  font-weight: normal;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 1.5px;
  border-bottom: 1px solid #1f1f1f;
  vertical-align: middle;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.stb-th-right { text-align: right; }
.stb-th-left { text-align: left; }
.stb-table td {
  height: 44px;
  padding: 0 12px;
  border-bottom: 1px solid #1f1f1f;
  vertical-align: middle;
  font-size: 12px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.stb-table tr:last-child td { border-bottom: none; }

/* CELLS */
.stb-cell-period {
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  color: #888;
  text-align: right;
}
.stb-cell-period.stb-total {
  color: #fff;
  font-weight: 700;
}
.stb-cell-period-en {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: #555;
  margin-right: 8px;
}
.stb-cell-num {
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  font-size: 12px;
  font-weight: 700;
  text-align: right;
}
.stb-cell-num.stb-orange { color: var(--o); }
.stb-cell-num.stb-white { color: #fff; }
.stb-cell-num.stb-dim { color: #888; font-weight: normal; }
.stb-cell-symbol {
  font-family: 'Share Tech Mono', monospace;
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  text-align: right;
}
.stb-cell-chain {
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  text-align: right;
}

/* STACKED BAR */
.stb-stacked-bar-wrap {
  padding: 16px;
}
.stb-stacked-bar {
  display: flex;
  height: 28px;
  border: 1px solid #1f1f1f;
}
.stb-stacked-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  color: #000;
  overflow: hidden;
}
.stb-legend {
  margin-top: 12px;
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
}
.stb-legend-item { display: flex; align-items: center; gap: 6px; }
.stb-legend-color { width: 10px; height: 10px; }
.stb-legend-symbol { color: #fff; font-weight: 700; }
.stb-legend-pct { color: #888; }

/* DOMINANCE GRID */
.stb-dom-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
}
.stb-dom-cell {
  padding: 14px;
  border-right: 1px solid #1f1f1f;
}
.stb-dom-cell:last-child { border-right: none; }
.stb-dom-value {
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  font-weight: 700;
  margin-top: 8px;
  line-height: 1;
}
.stb-dom-value.stb-big { font-size: 24px; }
.stb-dom-value.stb-small { font-size: 18px; }
.stb-dom-value.stb-orange { color: var(--o); }
.stb-dom-value.stb-white { color: #fff; }

/* INTERPRETATION */
.stb-interp {
  padding: 14px;
  margin-bottom: 12px;
  font-size: 12px;
  color: #fff;
  line-height: 1.7;
  font-family: 'Cairo', sans-serif;
}
.stb-interp.stb-bullish {
  border: 1px solid #fff;
  background: rgba(255,255,255,0.04);
}
.stb-interp.stb-bearish {
  border: 1px solid var(--o);
  background: rgba(255,106,0,0.04);
}
.stb-interp-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  margin-bottom: 6px;
}
.stb-interp.stb-bullish .stb-interp-label { color: #fff; }
.stb-interp.stb-bearish .stb-interp-label { color: var(--o); }
.stb-interp strong.stb-white { color: #fff; font-weight: 700; }
.stb-interp strong.stb-orange { color: var(--o); font-weight: 700; }

/* SIGNALS */
.stb-priority {
  padding: 3px 8px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  letter-spacing: 1px;
  font-weight: 700;
  white-space: nowrap;
  display: inline-block;
}
.stb-priority-bullish { background: #fff; color: #000; }
.stb-priority-bearish { background: var(--o); color: #000; }
.stb-priority-neutral { background: #888; color: #000; }

.stb-signals-table td {
  height: 56px;
  padding: 12px;
  white-space: normal;
}
.stb-signal-text {
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  color: #fff;
  font-weight: 700;
  line-height: 1.4;
}
.stb-signal-impact {
  font-family: 'Cairo', sans-serif;
  font-size: 12px;
  line-height: 1.5;
}
.stb-signal-impact.stb-orange { color: var(--o); }
.stb-signal-impact.stb-white { color: #fff; }

/* GUIDE */
.stb-guide {
  border: 1px solid #1f1f1f;
  background: #0a0a0a;
  padding: 16px;
  line-height: 1.9;
  font-size: 12px;
  margin-bottom: 14px;
}
.stb-guide-block { margin-bottom: 14px; }
.stb-guide-block:last-child { margin-bottom: 0; }
.stb-guide-h {
  color: var(--o);
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  letter-spacing: 1px;
}
.stb-guide-p {
  margin-top: 4px;
  color: #fff;
  font-family: 'Cairo', sans-serif;
}

/* DISCLAIMER */
.stb-disc {
  border: 1px solid var(--o);
  background: rgba(255,106,0,0.04);
  padding: 14px;
  font-size: 11px;
  line-height: 1.8;
  color: #fff;
  font-family: 'Cairo', sans-serif;
}
.stb-disc-h {
  color: var(--o);
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  margin-bottom: 8px;
}

/* FOOTER */
.stb-footer {
  margin-top: 20px;
  text-align: center;
  color: #555;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  padding-bottom: 30px;
}

/* MOBILE */
@media (max-width: 600px) {
  .stb-ticker { grid-template-columns: 1fr 1fr; }
  .stb-ticker-cell:nth-child(2) { border-right: none; }
  .stb-ticker-cell:nth-child(1), .stb-ticker-cell:nth-child(2) { border-bottom: 1px solid #1f1f1f; }
  .stb-issuance-grid { grid-template-columns: 1fr; }
  .stb-issuance-cell { border-right: none; border-bottom: 1px solid #1f1f1f; }
  .stb-issuance-cell:last-child { border-bottom: none; }
  .stb-dom-grid { grid-template-columns: 1fr 1fr; }
  .stb-dom-cell:nth-child(2) { border-right: none; }
  .stb-dom-cell:nth-child(1), .stb-dom-cell:nth-child(2) { border-bottom: 1px solid #1f1f1f; }
  .stb-master-top { grid-template-columns: 1fr; }
  .stb-master-score-box { text-align: right; }
  .stb-master-score { font-size: 40px; }
  .stb-master-signal { font-size: 22px; }
  .stb-table th, .stb-table td { padding: 0 8px; font-size: 11px; }
  .stb-cell-symbol, .stb-cell-chain { font-size: 12px; }
  .stb-cell-period { font-size: 12px; }
}

  /* ===== MATRIX Q — Quarterly Theory Tracker ===== */
#pg-mq {
  background: #000;
  color: #fff;
  font-family: 'Cairo', sans-serif;
  direction: rtl;
  min-height: 100vh;
}
.mq-wrap { padding: 16px 14px 40px; max-width: 960px; margin: 0 auto; }

/* HEADER */
.mq-hdr {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid #2a2a2a;
  margin-bottom: 14px;
}
.mq-hdr-eye {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--o);
  letter-spacing: 3px;
  margin-bottom: 6px;
}
.mq-hdr-title {
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.5px;
  line-height: 1.1;
  margin: 0;
}
.mq-hdr-sub {
  margin-top: 6px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: #555;
  letter-spacing: 1px;
}
.mq-hdr-tag {
  flex-shrink: 0;
  padding: 7px 14px;
  border: 1px solid var(--o);
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--o);
  letter-spacing: 2px;
  background: rgba(255,106,0,0.05);
  white-space: nowrap;
}

/* ASSET TABS */
.mq-asset-tabs {
  display: flex;
  height: 36px;
  border: 1px solid #2a2a2a;
  background: #080808;
  margin-bottom: 14px;
  overflow: hidden;
}
.mq-at-label {
  display: flex;
  align-items: center;
  padding: 0 14px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  color: #555;
  letter-spacing: 2px;
  border-left: 1px solid #2a2a2a;
  white-space: nowrap;
  flex-shrink: 0;
}
.mq-at-btn {
  flex: 1;
  height: 100%;
  background: transparent;
  border: none;
  border-left: 1px solid #2a2a2a;
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px;
  color: #888;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.15s;
}
.mq-at-btn:last-child { border-left: none; }
.mq-at-btn:hover { background: rgba(255,255,255,0.04); color: #fff; }
.mq-at-btn.active { background: #fff; color: #000; font-weight: 700; }

/* STATUS */
.mq-status {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  color: #888;
  padding: 4px 0 12px;
  min-height: 20px;
  letter-spacing: 1px;
}
.mq-status.mq-error { color: var(--o); }

/* RESULT */
.mq-result { display: none; }
.mq-result.mq-show { display: block; }

/* SECTION LABEL */
.mq-section-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--o);
  letter-spacing: 3px;
  padding-bottom: 8px;
  border-bottom: 1px solid #2a2a2a;
  margin: 28px 0 12px;
  text-transform: uppercase;
}

/* VERDICT BLOCK */
.mq-verdict {
  background: #080808;
  border: 1px solid #fff;
  position: relative;
  margin-bottom: 0;
}
.mq-verdict.mq-bear { border-color: var(--o); }
.mq-v-stamp {
  position: absolute;
  top: -1px;
  right: -1px;
  padding: 5px 14px;
  background: #fff;
  color: #000;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
}
.mq-verdict.mq-bear .mq-v-stamp { background: var(--o); }
.mq-v-body { padding: 26px 20px 20px; }

.mq-v-row {
  display: grid;
  grid-template-columns: 1fr 1px 220px;
  margin-bottom: 18px;
}
.mq-v-divider { background: #2a2a2a; margin: 0 20px; }
.mq-v-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  color: #555;
  letter-spacing: 2px;
  margin-bottom: 10px;
  text-transform: uppercase;
}
.mq-v-signal-ar {
  font-family: 'Cairo', sans-serif;
  font-size: 24px;
  font-weight: 700;
  color: #fff;
  line-height: 1.15;
}
.mq-v-signal-ar.mq-bear { color: var(--o); }
.mq-v-signal-en {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  color: #bbb;
  margin-top: 6px;
  text-transform: uppercase;
}
.mq-v-signal-en.mq-bear { color: var(--o); }

.mq-v-pct {
  font-family: 'Share Tech Mono', monospace;
  font-size: 52px;
  font-weight: 400;
  letter-spacing: -2px;
  line-height: 1;
  color: #fff;
  margin-top: 4px;
  margin-bottom: 12px;
}
.mq-v-pct.mq-bear { color: var(--o); }
.mq-v-track { width: 100%; height: 4px; background: #2a2a2a; overflow: hidden; }
.mq-v-fill { height: 100%; }
.mq-v-fill.mq-bull { background: #fff; }
.mq-v-fill.mq-bear { background: var(--o); }
.mq-v-ticks { display: flex; justify-content: space-between; margin-top: 5px; }
.mq-v-ticks span { font-family: 'Share Tech Mono', monospace; font-size: 9px; color: #333; }
.mq-v-zones { display: grid; grid-template-columns: repeat(5, 1fr); gap: 2px; margin-top: 7px; }
.mq-vz { height: 2px; }
.mq-vz1 { background: var(--o); }
.mq-vz2 { background: rgba(255,106,0,0.35); }
.mq-vz3 { background: #2a2a2a; }
.mq-vz4 { background: rgba(255,255,255,0.35); }
.mq-vz5 { background: #fff; }

.mq-v-prose {
  padding: 14px 16px;
  border-right: 2px solid #fff;
  background: rgba(255,255,255,0.03);
  font-family: 'Cairo', sans-serif;
  font-size: 13px;
  color: #fff;
  line-height: 1.85;
}
.mq-verdict.mq-bear .mq-v-prose {
  border-right-color: var(--o);
  background: rgba(255,106,0,0.06);
}
.mq-v-prose strong.mq-bull { color: #fff; font-weight: 700; }
.mq-v-prose strong.mq-bear { color: var(--o); font-weight: 700; }

.mq-cache-strip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 32px;
  padding: 0 14px;
  border: 1px solid #2a2a2a;
  border-top: none;
  background: #0f0f0f;
  margin-bottom: 14px;
}
.mq-cs-label { font-family: 'Share Tech Mono', monospace; font-size: 9px; color: #333; letter-spacing: 2px; }
.mq-cs-val { font-family: 'Share Tech Mono', monospace; font-size: 9px; color: #555; letter-spacing: 0.5px; }
.mq-cs-val em { font-style: normal; color: var(--o); }

/* QUARTER CARDS */
.mq-q-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border: 1px solid #2a2a2a;
  border-top: none;
  background: #080808;
}
.mq-q-card {
  padding: 18px 14px 16px;
  border-right: 1px solid #2a2a2a;
  position: relative;
}
.mq-q-card:last-child { border-right: none; }
.mq-q-card.active { background: rgba(255,255,255,0.025); }
.mq-q-card.active::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: #fff;
}
.mq-q-now {
  display: inline-block;
  padding: 3px 8px;
  background: #fff;
  color: #000;
  font-family: 'Share Tech Mono', monospace;
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 1.5px;
  margin-bottom: 8px;
}
.mq-q-name {
  font-family: 'Share Tech Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  color: #888;
  letter-spacing: 1px;
  margin-bottom: 3px;
}
.mq-q-card.active .mq-q-name { color: #fff; }
.mq-q-months {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  color: #333;
  letter-spacing: 1px;
  margin-bottom: 16px;
}
.mq-q-bars {
  display: flex;
  align-items: flex-end;
  gap: 3px;
  height: 48px;
  margin-bottom: 14px;
}
.mq-q-bar {
  flex: 1;
  height: 100%;
  position: relative;
  cursor: default;
}
.mq-q-bar-fill {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  border-radius: 1px 1px 0 0;
}
.mq-q-bar-fill.mq-bull { background: #fff; }
.mq-q-bar-fill.mq-bear { background: var(--o); }
.mq-q-bar-fill.mq-dim  { background: #333; }
.mq-q-bar:hover .mq-q-tooltip { display: block; }
.mq-q-tooltip {
  display: none;
  position: absolute;
  bottom: calc(100% + 5px);
  left: 50%;
  transform: translateX(-50%);
  padding: 4px 8px;
  background: #0f0f0f;
  border: 1px solid #2a2a2a;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: #fff;
  white-space: nowrap;
  z-index: 20;
}
.mq-q-avg-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 10px;
}
.mq-q-avg-label { font-family: 'Share Tech Mono', monospace; font-size: 9px; color: #333; letter-spacing: 1px; }
.mq-q-avg-val { font-family: 'Share Tech Mono', monospace; font-size: 15px; font-variant-numeric: tabular-nums; font-weight: 700; }
.mq-q-avg-val.mq-bull { color: #fff; }
.mq-q-avg-val.mq-bear { color: var(--o); }
.mq-q-sep { height: 1px; background: #1e1e1e; margin: 10px 0; }
.mq-q-stat { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px; }
.mq-q-stat:last-of-type { margin-bottom: 0; }
.mq-q-stat-label { font-family: 'Share Tech Mono', monospace; font-size: 9px; color: #555; letter-spacing: 1px; }
.mq-q-stat-val { font-family: 'Share Tech Mono', monospace; font-size: 11px; font-variant-numeric: tabular-nums; }
.mq-q-stat-val.mq-bull { color: #fff; }
.mq-q-stat-val.mq-bear { color: var(--o); }
.mq-q-stat-val.mq-dim  { color: #555; }
.mq-q-wr-label { font-family: 'Share Tech Mono', monospace; font-size: 9px; color: #555; letter-spacing: 1px; margin-bottom: 6px; }
.mq-q-wr-track { height: 3px; background: #2a2a2a; overflow: hidden; }
.mq-q-wr-fill { height: 100%; }
.mq-q-wr-fill.mq-bull { background: #fff; }
.mq-q-wr-fill.mq-bear { background: var(--o); }
.mq-q-wr-pct { font-family: 'Share Tech Mono', monospace; font-size: 12px; font-variant-numeric: tabular-nums; margin-top: 5px; }
.mq-q-wr-pct.mq-bull { color: #fff; }
.mq-q-wr-pct.mq-bear { color: var(--o); }

/* TABLE */
.mq-tbl-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 38px;
  padding: 0 14px;
  background: #0f0f0f;
  border: 1px solid #2a2a2a;
  border-top: none;
  margin-top: 6px;
}
.mq-tbl-head-l { font-family: 'Share Tech Mono', monospace; font-size: 10px; color: #888; letter-spacing: 2px; }
.mq-tbl-head-r { font-family: 'Share Tech Mono', monospace; font-size: 10px; color: #fff; letter-spacing: 1px; }
.mq-table {
  width: 100%;
  border-collapse: collapse;
  background: #080808;
  border: 1px solid #2a2a2a;
  border-top: none;
  table-layout: fixed;
  margin-bottom: 14px;
}
.mq-table thead tr { background: #0f0f0f; border-bottom: 1px solid #2a2a2a; }
.mq-table th {
  height: 34px;
  padding: 0 12px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  font-weight: normal;
  color: #555;
  letter-spacing: 1.5px;
  text-align: right;
  vertical-align: middle;
  white-space: nowrap;
}
.mq-table td {
  height: 42px;
  padding: 0 12px;
  border-bottom: 1px solid #1e1e1e;
  vertical-align: middle;
  text-align: right;
  white-space: nowrap;
  font-family: 'Share Tech Mono', monospace;
  font-variant-numeric: tabular-nums;
  font-size: 12px;
}
.mq-table tbody tr:last-child td { border-bottom: none; }
.mq-table tbody tr:hover { background: rgba(255,255,255,0.015); }
.mq-table tbody tr.active-row { background: rgba(255,255,255,0.03); }
.mq-td-year { color: #fff; font-weight: 700; }
.mq-td-bull { color: #fff; }
.mq-td-bear { color: var(--o); }
.mq-td-dim  { color: #555; }
.mq-td-bar { padding: 0 12px; vertical-align: middle; }
.mq-bar-bg { width: 100%; height: 3px; background: #2a2a2a; position: relative; overflow: hidden; }
.mq-bar-fill { height: 100%; position: absolute; top: 0; }
.mq-bar-fill.mq-bull { background: #fff; right: 0; }
.mq-bar-fill.mq-bear { background: var(--o); left: 0; }

/* HEATMAP */
.mq-hm-wrap { border: 1px solid #2a2a2a; border-top: none; background: #080808; margin-bottom: 14px; }
.mq-hm-inner { padding: 16px 14px 14px; }
.mq-hm-grid { display: grid; grid-template-columns: 50px repeat(4, 1fr); gap: 0; }
.mq-hm-corner { height: 30px; }
.mq-hm-col-head {
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: #555;
  letter-spacing: 1.5px;
  border-bottom: 1px solid #2a2a2a;
}
.mq-hm-col-head.active { color: #fff; font-weight: 700; }
.mq-hm-yr {
  height: 36px;
  display: flex;
  align-items: center;
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  color: #888;
  border-bottom: 1px solid #1e1e1e;
}
.mq-hm-yr:last-of-type { border-bottom: none; }
.mq-hm-cell {
  height: 36px;
  border: 1px solid #000;
  border-bottom: 1px solid #1e1e1e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px;
  font-variant-numeric: tabular-nums;
  position: relative;
  cursor: default;
}
.mq-hm-cell:last-child { border-bottom: none; }
.mq-hm-cell:hover { z-index: 5; outline: 1px solid rgba(255,255,255,0.3); }

/* Heatmap Colors */
.mq-b1 { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.45); }
.mq-b2 { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.72); }
.mq-b3 { background: rgba(255,255,255,0.22); color: rgba(255,255,255,0.92); }
.mq-b4 { background: rgba(255,255,255,0.38); color: #fff; }
.mq-r1 { background: rgba(255,106,0,0.07); color: rgba(255,106,0,0.55); }
.mq-r2 { background: rgba(255,106,0,0.16); color: rgba(255,106,0,0.80); }
.mq-r3 { background: rgba(255,106,0,0.28); color: rgba(255,106,0,0.95); }
.mq-r4 { background: rgba(255,106,0,0.46); color: var(--o); }
.mq-dim-cell { background: #0f0f0f; color: #333; }
.mq-hm-cell.now { outline: 1px solid var(--o); z-index: 2; }

.mq-hm-legend { display: flex; align-items: center; gap: 4px; margin-top: 14px; justify-content: flex-end; }
.mq-hm-leg-txt { font-family: 'Share Tech Mono', monospace; font-size: 9px; color: #333; letter-spacing: 1px; }
.mq-hm-leg-box { width: 20px; height: 10px; }

/* SIGNALS TABLE */
.mq-badge {
  display: inline-block;
  padding: 3px 8px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1.5px;
  white-space: nowrap;
}
.mq-badge.bull { background: #fff; color: #000; }
.mq-badge.bear { background: var(--o); color: #000; }
.mq-badge.neut { background: #333; color: #888; }
.mq-sig-table td { height: 54px; padding: 10px 12px; vertical-align: middle; }
.mq-sig-text { font-family: 'Cairo', sans-serif; font-size: 13px; color: #fff; font-weight: 700; white-space: normal; line-height: 1.45; }
.mq-sig-impact { font-family: 'Cairo', sans-serif; font-size: 12px; line-height: 1.5; white-space: normal; }
.mq-sig-impact.up { color: #fff; }
.mq-sig-impact.dn { color: var(--o); }

/* GUIDE & DISC */
.mq-guide { background: #080808; border: 1px solid #2a2a2a; border-top: none; padding: 18px 16px; margin-bottom: 14px;}
.mq-guide-block { padding: 13px 0; border-bottom: 1px solid #1e1e1e; }
.mq-guide-block:first-child { padding-top: 0; }
.mq-guide-block:last-child  { padding-bottom: 0; border-bottom: none; }
.mq-guide-h { font-family: 'Share Tech Mono', monospace; font-size: 10px; color: var(--o); letter-spacing: 1.5px; margin-bottom: 8px; }
.mq-guide-p { font-family: 'Cairo', sans-serif; font-size: 13px; color: #888; line-height: 1.8; }

.mq-disc { border: 1px solid #2a2a2a; border-right: 2px solid var(--o); background: rgba(255,106,0,0.06); padding: 14px 16px; }
.mq-disc-h { font-family: 'Share Tech Mono', monospace; font-size: 9px; letter-spacing: 2.5px; color: var(--o); margin-bottom: 8px; }
.mq-disc p { font-family: 'Cairo', sans-serif; font-size: 12px; color: #888; line-height: 1.85; }
.mq-footer { margin-top: 32px; text-align: center; font-family: 'Share Tech Mono', monospace; font-size: 10px; color: #555; letter-spacing: 2px; }

/* MOBILE RESPONSIVE */
@media (max-width: 640px) {
  .mq-q-grid { grid-template-columns: repeat(2, 1fr); }
  .mq-q-card:nth-child(2) { border-right: none; }
  .mq-q-card:nth-child(3), .mq-q-card:nth-child(4) { border-top: 1px solid #2a2a2a; }
  .mq-v-row { grid-template-columns: 1fr; }
  .mq-v-divider { display: none; }
  .mq-v-meter { border-top: 1px solid #2a2a2a; padding-top: 16px; margin-top: 16px; }
  .mq-v-pct { font-size: 40px; }
  .mq-table th, .mq-table td { padding: 0 8px; font-size: 11px; }
  .mq-hm-cell { font-size: 10px; }
}
@media (max-width: 400px) {
  .mq-q-grid { grid-template-columns: 1fr; }
  .mq-q-card { border-right: none; border-top: 1px solid #2a2a2a; }
  .mq-q-card:first-child { border-top: none; }
  .mq-asset-tabs { overflow-x: auto; }
}


</style>

