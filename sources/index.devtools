<div class="pg" id="pg-ict">
  <div class="tp" style="max-width: 650px; margin: 0 auto; padding: 10px;">

    <div style="background:var(--s); border:1px solid var(--b); border-radius:4px; padding:8px 12px; margin-bottom:6px; display:flex; justify-content:space-between; align-items:center; margin-top:56px;">
      <div style="display:flex; align-items:center; gap:8px;">
        <span style="color:var(--o); font-size:0.9rem; font-weight:bold; font-family:'Share Tech Mono',monospace; letter-spacing:1px;">ICT ENGINE</span>
        <span style="color:var(--t3);">|</span>
        <span style="color:var(--t2); font-size:0.55rem; font-family:'Share Tech Mono',monospace; letter-spacing:1px;">INSTITUTIONAL CONCEPTS</span>
      </div>
      <div class="ict-tier-badge" style="margin-top:0;">VIP TIER</div>
    </div>

    <div style="background:var(--s); border:1px solid var(--b); border-radius:4px; padding:16px; margin-bottom:10px;">
      <div style="margin-bottom:14px;">
        <label style="font-size:0.7rem; color:var(--t2); margin-bottom:5px; display:block; font-weight:600;">رمز الأصل المالي (Spot)</label>
        <input type="text" id="ict-symbol" placeholder="BTCUSDT" value="BTCUSDT" class="ict-input-full" />
      </div>
      
      <div class="ict-tf-row">
        <button class="ict-tf-btn ict-tf-active" onclick="ictSelectTf(this,'1h')">1H</button>
        <button class="ict-tf-btn" onclick="ictSelectTf(this,'4h')">4H</button>
        <button class="ict-tf-btn" onclick="ictSelectTf(this,'1d')">1D</button>
      </div>

      <button onclick="runIctEngine()" style="width:100%; padding:12px; background:var(--o); color:#000; font-weight:900; border:none; border-radius:4px; cursor:pointer; font-family:'Cairo',sans-serif; font-size:0.9rem; letter-spacing:1px; margin-top:4px;">تحليل مؤسسي (ICT)</button>
    </div>

    <div id="ict-loading" style="display:none; text-align:center; padding:30px; color:var(--o); font-family:'Share Tech Mono',monospace; font-size:13px; font-weight:bold;">جاري رسم هيكل ICT ومسح السيولة...</div>
    <div id="ict-dashboard" style="display:none; flex-direction:column; gap:6px;"></div>

  </div>
</div>

  <div class="moon-modal" id="capitalModal">
  <div class="moon-wrap" style="max-width: 520px; width: 95%; background: #000; max-height: 88vh; overflow-y: auto; padding: 12px; border: 1px solid #1a1a1a; border-radius: 8px;">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px; border-bottom:1px solid #1a1a1a; padding-bottom:12px;">
      <div style="display:flex; align-items:center; gap:8px;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="6" y1="7" x2="6" y2="19" stroke="#ffffff"></line><rect x="4" y="10" width="4" height="6" fill="#ffffff" rx="0.5" stroke="none"></rect>
          <line x1="12" y1="4" x2="12" y2="16" stroke="#ff6a00"></line><rect x="10" y="6" width="4" height="7" fill="#ff6a00" rx="0.5" stroke="none"></rect>
          <line x1="18" y1="8" x2="18" y2="20" stroke="#ffffff"></line><rect x="16" y="12" width="4" height="5" fill="#ffffff" rx="0.5" stroke="none"></rect>
        </svg>
        <span style="color:#ffffff; font-size:1.05rem; font-weight:700; font-family:'Cairo', sans-serif;">حساب نسبة رأس المال</span>
      </div>
      <div onclick="document.getElementById('capitalModal').style.display='none'" style="color:var(--o); cursor:pointer; display:flex; align-items:center; gap:6px; background: rgba(255, 106, 0, 0.1); padding: 4px 12px; border-radius: 4px; border: 1px solid var(--o);">
        <span style="font-size:14px; font-weight:700; font-family:'Cairo', sans-serif;">إغلاق</span>
        <span style="font-size:30px; line-height:0.8;">&times;</span>
      </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-bottom:12px;">
      <button id="cap-tab-recovery" onclick="capSwitchTab('recovery')" style="background:#0a0a0a; border:1px solid var(--o); color:var(--o); padding:10px 4px; border-radius:4px; font-family:'Cairo', sans-serif; font-size:0.65rem; font-weight:bold; cursor:pointer; transition:0.3s; line-height: 1.4;">
        النسبة المطلوبه لعودة رأس المال
      </button>
      <button id="cap-tab-compound" onclick="capSwitchTab('compound')" style="background:#060606; border:1px solid #1a1a1a; color:#888; padding:10px 4px; border-radius:4px; font-family:'Cairo', sans-serif; font-size:0.65rem; font-weight:bold; cursor:pointer; transition:0.3s; line-height: 1.4;">
        النمو المركب (الربح)
      </button>
    </div>

    <div id="cap-pane-recovery" style="display:block; animation:fadeIn 0.3s ease;">
      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:14px; margin-bottom:10px;">
        <div style="color:#888; font-size:0.6rem; font-family:'Share Tech Mono',monospace; letter-spacing:2px; margin-bottom:10px; text-align:center;">DRAWDOWN RECOVERY SIMULATOR</div>

        <div style="margin-bottom:10px;">
          <label style="display:block; color:var(--o); font-size:0.7rem; font-family:'Cairo',sans-serif; margin-bottom:6px; text-align:center; font-weight:bold;">نسبة التراجع (الخسارة) في المحفظة (%)</label>
          <input type="number" id="cap-dd-input" min="0" max="99" step="0.5" value="20" oninput="capCalcRecovery()" style="width:100%; background:#000; border:1px solid var(--o); color:var(--o); padding:10px; border-radius:4px; font-family:'Share Tech Mono',monospace; font-size:1.2rem; font-weight:bold; direction:ltr; text-align:center; outline:none;">
        </div>

        <div style="margin-bottom:6px;">
          <input type="range" id="cap-dd-slider" min="0" max="95" step="1" value="20" oninput="capSliderSync()" style="width:100%; accent-color:var(--o);">
        </div>
      </div>

      <div style="background:#060606; border:1px solid #1a1a1a; border-radius:4px; padding:18px 12px; text-align:center; margin-bottom:10px; border-top:2px solid #ffffff;">
        <div style="color:#ffffff; font-size:0.6rem; font-family:'Share Tech Mono',monospace; letter-spacing:2px; margin-bottom:8px;">REQUIRED GAIN TO BREAKEVEN</div>
        <div id="cap-dd-result" style="color:#ffffff; font-size:2.4rem; font-weight:bold; font-family:'Share Tech Mono',monospace; direction:ltr;">+25.00%</div>
        <div id="cap-dd-multiplier" style="color:#888; font-size:0.7rem; font-family:'Share Tech Mono',monospace; margin-top:6px; direction:ltr;">×1.25 من القاع</div>
      </div>

      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:14px; margin-bottom:10px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
          <span style="color:var(--o); font-size:0.6rem; font-family:'Share Tech Mono',monospace; font-weight:bold;">LOSS (DROP)</span>
          <span style="color:#ffffff; font-size:0.6rem; font-family:'Share Tech Mono',monospace; font-weight:bold;">RECOVERY NEEDED</span>
        </div>
        <div style="display:flex; gap:2px; height:14px; border-radius:4px; overflow:hidden; background:#000;">
          <div id="cap-bar-drop" style="height:100%; width:30%; background:var(--o); transition:width 0.4s ease;"></div>
          <div id="cap-bar-recovery" style="height:100%; width:30%; background:#ffffff; transition:width 0.4s ease;"></div>
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:6px;">
          <span id="cap-bar-drop-lbl" style="color:var(--o); font-size:0.65rem; font-family:'Share Tech Mono',monospace; direction:ltr; font-weight:bold;">-20%</span>
          <span id="cap-bar-recovery-lbl" style="color:#ffffff; font-size:0.65rem; font-family:'Share Tech Mono',monospace; direction:ltr; font-weight:bold;">+25%</span>
        </div>
      </div>

      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:12px; margin-bottom:10px;">
        <div style="color:#ffffff; font-size:0.65rem; font-family:'Cairo',sans-serif; font-weight:bold; margin-bottom:10px; text-align:center;">مقارنة: الخسارة مقابل متطلبات التعافي</div>
        <table style="width:100%; border-collapse:collapse; font-family:'Share Tech Mono',monospace; font-size:0.7rem;">
          <thead>
            <tr style="border-bottom:1px solid #1a1a1a;">
              <th style="padding:6px 4px; color:var(--o); font-weight:bold; text-align:center;">الخسارة</th>
              <th style="padding:6px 4px; color:#ffffff; font-weight:bold; text-align:center;">المطلوب للتعافي</th>
              <th style="padding:6px 4px; color:var(--o); font-weight:normal; text-align:center;">العبء الإضافي</th>
            </tr>
          </thead>
          <tbody id="cap-dd-table"></tbody>
        </table>
      </div>

      <div style="background:#060606; border:1px solid #1a1a1a; border-right:3px solid var(--o); border-radius:4px; padding:12px;">
        <div style="color:var(--o); font-size:0.65rem; font-family:'Cairo',sans-serif; font-weight:bold; margin-bottom:8px;">نصيحة الانضباط (VERDICT)</div>
        <div id="cap-dd-verdict" style="color:#ccc; font-size:0.72rem; font-family:'Cairo',sans-serif; line-height:1.8;">--</div>
      </div>
    </div>

    <div id="cap-pane-compound" style="display:none; animation:fadeIn 0.3s ease;">
      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:14px; margin-bottom:10px;">
        <div style="color:#888; font-size:0.6rem; font-family:'Share Tech Mono',monospace; letter-spacing:2px; margin-bottom:10px; text-align:center;">COMPOUND GROWTH PROJECTION</div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:8px;">
          <div>
            <label style="display:block; color:#888; font-size:0.65rem; font-family:'Cairo',sans-serif; margin-bottom:4px; text-align:center;">رأس المال الأولي ($)</label>
            <input type="number" id="cap-cg-capital" min="1" step="100" value="1000" oninput="capCalcCompound()" style="width:100%; background:#000; border:1px solid #2a2a2a; color:#ffffff; padding:8px; border-radius:4px; font-family:'Share Tech Mono',monospace; font-size:0.95rem; direction:ltr; text-align:center; outline:none; font-weight:bold;">
          </div>
          <div>
            <label style="display:block; color:#888; font-size:0.65rem; font-family:'Cairo',sans-serif; margin-bottom:4px; text-align:center;">المدة (أشهر)</label>
            <input type="number" id="cap-cg-months" min="1" max="120" step="1" value="12" oninput="capCalcCompound()" style="width:100%; background:#000; border:1px solid #2a2a2a; color:#ffffff; padding:8px; border-radius:4px; font-family:'Share Tech Mono',monospace; font-size:0.95rem; direction:ltr; text-align:center; outline:none; font-weight:bold;">
          </div>
        </div>

        <div>
          <label style="display:block; color:#ffffff; font-size:0.65rem; font-family:'Cairo',sans-serif; margin-bottom:4px; text-align:center; font-weight:bold;">نسبة الربح أو الخسارة الشهرية المتوقعة (%)</label>
          <input type="number" id="cap-cg-rate" min="-50" max="100" step="0.5" value="5" oninput="capCalcCompound()" style="width:100%; background:#000; border:1px solid #ffffff; color:#ffffff; padding:8px; border-radius:4px; font-family:'Share Tech Mono',monospace; font-size:1.1rem; font-weight:bold; direction:ltr; text-align:center; outline:none;">
          <input type="range" id="cap-cg-rate-slider" min="-20" max="20" step="0.5" value="5" oninput="capCgSliderSync()" style="width:100%; accent-color:#ffffff; margin-top:12px;">
        </div>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-bottom:10px;">
        <div style="background:#060606; border:1px solid #1a1a1a; border-radius:4px; padding:12px; text-align:center; border-top:2px solid #ffffff;" id="cap-cg-final-box">
          <div style="color:#888; font-size:0.55rem; font-family:'Cairo',sans-serif; font-weight:bold; margin-bottom:4px;">رأس المال النهائي</div>
          <div id="cap-cg-final" style="color:#ffffff; font-size:1.2rem; font-family:'Share Tech Mono',monospace; font-weight:bold; direction:ltr;">$0.00</div>
        </div>
        <div style="background:#060606; border:1px solid #1a1a1a; border-radius:4px; padding:12px; text-align:center; border-top:2px solid #ffffff;" id="cap-cg-ret-box">
          <div style="color:#888; font-size:0.55rem; font-family:'Cairo',sans-serif; font-weight:bold; margin-bottom:4px;">إجمالي العائد</div>
          <div id="cap-cg-totalret" style="color:#ffffff; font-size:1.2rem; font-family:'Share Tech Mono',monospace; font-weight:bold; direction:ltr;">+0.00%</div>
        </div>
      </div>

      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-right:3px solid #fff; border-radius:4px; padding:10px 12px; margin-bottom:10px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <span style="color:#888; font-size:0.65rem; font-family:'Cairo',sans-serif;">العائد السنوي المُعادل (CAGR):</span>
          <span id="cap-cg-cagr" style="color:#fff; font-size:0.85rem; font-family:'Share Tech Mono',monospace; font-weight:bold; direction:ltr;">+0.00%</span>
        </div>
      </div>

      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:12px; margin-bottom:10px;">
        <div style="color:#ffffff; font-size:0.65rem; font-family:'Cairo',sans-serif; font-weight:bold; margin-bottom:10px; text-align:center;" id="cap-cg-chart-title">منحنى نمو رأس المال</div>
        <svg id="cap-cg-chart" viewBox="0 0 400 180" style="width:100%; height:auto; display:block;" preserveAspectRatio="none"></svg>
        <div style="display:flex; justify-content:space-between; color:#555; font-size:0.55rem; font-family:'Share Tech Mono',monospace; margin-top:4px;">
          <span id="cap-cg-x-start">M0</span>
          <span id="cap-cg-x-end">M12</span>
        </div>
      </div>

      <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:12px; margin-bottom:10px;">
        <div style="max-height:180px; overflow-y:auto; border:1px solid #111; scrollbar-width:none;">
          <table style="width:100%; border-collapse:collapse; font-family:'Share Tech Mono',monospace; font-size:0.7rem;">
            <thead style="position:sticky; top:0; background:#000;">
              <tr style="border-bottom:1px solid #1a1a1a;">
                <th style="padding:6px 4px; color:#888; font-weight:normal; text-align:center;">الشهر</th>
                <th style="padding:6px 4px; color:#ffffff; font-weight:normal; text-align:center;">الرصيد التراكمي</th>
                <th style="padding:6px 4px; color:#ffffff; font-weight:normal; text-align:center;" id="cap-cg-col-profit">العائد الصافي</th>
              </tr>
            </thead>
            <tbody id="cap-cg-table"></tbody>
          </table>
        </div>
      </div>

      <div style="background:#060606; border:1px solid #1a1a1a; border-right:3px solid #ffffff; border-radius:4px; padding:12px;" id="cap-cg-verdict-box">
        <div style="color:#ffffff; font-size:0.65rem; font-family:'Cairo',sans-serif; font-weight:bold; margin-bottom:8px;" id="cap-cg-verdict-title">نصيحة الانضباط (VERDICT)</div>
        <div id="cap-cg-verdict" style="color:#ccc; font-size:0.72rem; font-family:'Cairo',sans-serif; line-height:1.8;">--</div>
      </div>
    </div>

  </div>
</div>

  
<div class="pg" id="pg-dbl">
  <div class="tp" style="max-width: 500px; margin: 0 auto; padding: 10px;">
    
    <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:8px 12px; margin-bottom:6px; display:flex; justify-content:space-between; align-items:center; margin-top:56px;">
      <div style="display:flex; align-items:center; gap:8px;">
        <span style="color:var(--o); font-size:0.9rem; font-weight:bold; font-family:'Share Tech Mono',monospace; letter-spacing:1px;">DBL</span>
        <span style="color:#333;">|</span>
        <span style="color:#ccc; font-size:0.55rem; font-family:'Share Tech Mono',monospace; letter-spacing:1px;">DOUBLE TOP / BOTTOM</span>
      </div>
      <span style="color:#888; font-size:0.5rem; font-family:'Share Tech Mono',monospace;">CLASSIC TA</span>
    </div>

    <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:14px; margin-bottom:6px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:10px;">
        <div>
          <div style="font-size:0.5rem; color:#888; font-family:'Share Tech Mono',monospace; margin-bottom:3px;">SYMBOL</div>
          <input type="text" id="dbl-symbol" placeholder="BTC" value="BTC" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; text-transform:uppercase; font-family:'Share Tech Mono',monospace; font-size:0.85rem; text-align:center; outline:none;">
        </div>
        <div>
          <div style="font-size:0.5rem; color:#888; font-family:'Share Tech Mono',monospace; margin-bottom:3px;">TIMEFRAME</div>
          <select id="dbl-tf" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; font-family:'Share Tech Mono',monospace; outline:none;">
            <option value="1h">1H</option>
            <option value="4h" selected>4H</option>
            <option value="1d">1D</option>
            <option value="1w">1W</option>
          </select>
        </div>
      </div>
      <button onclick="if(typeof runDoublePattern === 'function') runDoublePattern();" id="dbl-btn" style="width:100%; padding:10px; background:var(--o); color:#000; font-weight:900; border:none; border-radius:4px; cursor:pointer; font-family:'Share Tech Mono',monospace; font-size:0.9rem; letter-spacing:3px;">START</button>
    </div>

    <div id="dbl-dashboard" style="display:none;">
      <div id="dbl-chart-card"></div>
      <div id="dbl-breakout-card" style="margin-bottom:6px;"></div>
      <div id="dbl-score-card" style="margin-bottom:6px;"></div>
      <div id="dbl-targets-card" style="margin-bottom:6px;"></div>
      
      <div style="background:#080808; border:1px solid #1a1a1a; border-right:3px solid var(--o); border-radius:4px; padding:12px; margin-bottom:6px;">
        <div style="color:var(--o); font-size:0.5rem; font-weight:bold; font-family:'Share Tech Mono',monospace; letter-spacing:2px; margin-bottom:8px;">VERDICT</div>
        <div id="dbl-conclusion" style="font-size:0.72rem; line-height:1.8; color:#ccc; font-family:'Cairo', sans-serif;">--</div>
      </div>

      <div style="background:#060606; border:1px solid #1a1a1a; border-radius:4px; padding:10px 12px; border-right:3px solid var(--o);">
        <div style="font-size:0.6rem; color:#ccc; line-height:1.8; text-align:right; font-family:'Cairo', sans-serif;">
          <span style="color:var(--o); font-weight:bold;">دليل القراءة: </span>
          P1/P2 = القمتان أو القاعان. NK = خط العنق. كسره = تأكيد النموذج.<br>
          TP1=50% | TP2=100% | TP3=161.8% امتداد فيبوناتشي.<br>
          SL = الوقف الهيكلي. تباعد الـ RSI يعزز من موثوقية الانعكاس.<br>
          هذا تحليل فني موضوعي ولا يُعتبر توصية شراء أو بيع.
        </div>
      </div>
    </div>

  </div>
</div>

<div class="pg" id="pg-stb">
  <div class="stb-wrap">

    <div class="stb-header">
      <div>
        <div class="stb-tag">STABLECOINS ANALYTICS · TERMINAL</div>
        <h1 class="stb-title">تحليلات الستيبل كوينز</h1>
      </div>
      <div class="stb-header-meta" id="stb-header-meta">
        <div>REPORT · —</div>
        <div>NEXT IN · <span>—</span></div>
      </div>
    </div>

    <div id="stb-status" class="stb-status"></div>

    <div id="stb-result" class="stb-result"></div>

  </div>
</div>
  
  <div class="pg" id="pg-wedge">
  <div class="tp" style="max-width: 500px; margin: 0 auto; padding: 10px;">

    <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:8px 12px; margin-bottom:6px; display:flex; justify-content:space-between; align-items:center; margin-top:56px;">
      <div style="display:flex; align-items:center; gap:8px;">
        <span style="color:var(--o); font-size:0.9rem; font-weight:bold; font-family:'Share Tech Mono',monospace; letter-spacing:1px;">WEDGE</span>
        <span style="color:#333;">|</span>
        <span style="color:#ccc; font-size:0.55rem; font-family:'Share Tech Mono',monospace; letter-spacing:1px;">WEDGE PATTERN SCANNER</span>
      </div>
      <span style="color:#888; font-size:0.5rem; font-family:'Share Tech Mono',monospace;">CLASSIC TA</span>
    </div>

    <div style="background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:14px; margin-bottom:6px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:10px;">
        <div>
          <div style="font-size:0.5rem; color:#888; font-family:'Share Tech Mono',monospace; margin-bottom:3px;">SYMBOL</div>
          <input type="text" id="wedge-symbol" placeholder="BTC" value="BTC" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; text-transform:uppercase; font-family:'Share Tech Mono',monospace; font-size:0.85rem; text-align:center; outline:none;">
        </div>
        <div>
          <div style="font-size:0.5rem; color:#888; font-family:'Share Tech Mono',monospace; margin-bottom:3px;">TIMEFRAME</div>
          <select id="wedge-tf" style="width:100%; padding:8px; background:#111; border:1px solid #222; border-radius:4px; color:#fff; font-family:'Share Tech Mono',monospace; outline:none;">
            <option value="1h">1H</option>
            <option value="4h" selected>4H</option>
            <option value="1d">1D</option>
            <option value="1w">1W</option>
          </select>
        </div>
      </div>
      <button onclick="if(typeof runWedgeScanner === 'function') runWedgeScanner();" id="wedge-btn" style="width:100%; padding:10px; background:var(--o); color:#000; font-weight:900; border:none; border-radius:4px; cursor:pointer; font-family:'Share Tech Mono',monospace; font-size:0.9rem; letter-spacing:3px;">START</button>
    </div>

