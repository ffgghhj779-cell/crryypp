      </div>
    </div>

  </div>
</div>

<div class="pg" id="pg-triple">
  <div class="tp" style="max-width:500px; margin:0 auto; padding:10px; font-family:'Share Tech Mono', 'Cairo', sans-serif; direction:rtl;">
    
    <style>
      @keyframes fadeUpTriple { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
